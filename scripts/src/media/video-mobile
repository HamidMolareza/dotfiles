#!/usr/bin/env bash
set -euo pipefail

# -------------------------------------------------------------------
# Usage: video-mobile <input_file> [output_file]
# Creates a mobile-friendly MP4 (H.264 + AAC) with:
# - Max dimension 420px (keeps aspect ratio, even dimensions)
# - Loudness normalization (loudnorm: -16 LUFS)
# - yuv420p + faststart for broad compatibility
# -------------------------------------------------------------------

die() { echo "Error: $*" >&2; exit 1; }

need() { command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not found."; }

unique_path() {
  local path="$1"
  local dir base ext n
  dir=$(dirname -- "$path")
  base=$(basename -- "$path")
  ext="${base##*.}"
  base="${base%.*}"
  n=1
  while [[ -e "$dir/$base.$ext" ]]; do
    base="${base%_*}_$n"
    ((n++))
  done
  printf '%s/%s.%s' "$dir" "$base" "$ext"
}

if [[ $# -lt 1 || $# -gt 2 ]]; then
  echo "Usage: $(basename "$0") <input_file> [output_file]"
  exit 1
fi

input_file=$1
output_file=${2-}

need ffmpeg
[[ -r "$input_file" ]] || die "Cannot read input file: $input_file"

filename=$(basename -- "$input_file")
base="${filename%.*}"
current_date=$(date +%F)

if [[ -z "$output_file" ]]; then
  output_file="${base}_mobile_${current_date}.mp4"
fi

output_file=$(unique_path "$output_file")

# Max dimension 420px, keep aspect ratio, ensure even dimensions.
scale_filter="scale='if(gt(iw,ih),floor(min(420,iw)/2)*2,-2)':'if(gt(iw,ih),-2,floor(min(420,ih)/2)*2)':flags=lanczos"

ffmpeg -hide_banner -v warning -stats -i "$input_file" \
  -vf "$scale_filter" \
  -c:v libx264 -crf 28 -preset slow -pix_fmt yuv420p \
  -c:a aac -b:a 96k -af "loudnorm=I=-16:LRA=11:TP=-1.5" \
  -movflags +faststart \
  "$output_file"

echo "Done: $output_file"

#!/usr/bin/env bash

set -Eeuo pipefail

IDE="/home/home/Programs/WebStorm/bin/webstorm"

if [[ ! -x "$IDE" ]]; then
    echo "Error: WebStorm launcher is not executable: $IDE" >&2
    exit 127
fi

if command -v setsid >/dev/null 2>&1; then
    setsid -f "$IDE" "$@" >/dev/null 2>&1
else
    nohup "$IDE" "$@" >/dev/null 2>&1 &
fi

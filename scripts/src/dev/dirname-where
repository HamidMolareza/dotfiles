#!/bin/bash

set -o pipefail

print_usage() {
    cat <<'EOF'
Usage: dirname-where <command-or-path> [more...]

Print the resolved directory for each command or path. If a target resolves
to a file, print its parent directory. If it resolves to a directory, print
that directory.
EOF
}

resolve_path() {
    local input="$1"
    local path=""

    if [[ "$input" == */* ]]; then
        if [[ -e "$input" ]]; then
            echo "$input"
            return 0
        fi
        echo "Error: path not found: $input" >&2
        return 1
    fi

    path=$(type -P -- "$input" 2>/dev/null || true)
    if [[ -n "$path" && -e "$path" ]]; then
        echo "$path"
        return 0
    fi

    local kind=""
    kind=$(type -t -- "$input" 2>/dev/null || true)
    if [[ -n "$kind" ]]; then
        echo "Error: '$input' is a shell $kind, not an external file." >&2
    else
        echo "Error: '$input' not found in PATH." >&2
    fi
    return 1
}

canonicalize_path() {
    local input="$1"
    if command -v realpath >/dev/null 2>&1; then
        realpath -- "$input"
        return 0
    fi
    if command -v readlink >/dev/null 2>&1; then
        readlink -f -- "$input" 2>/dev/null || echo "$input"
        return 0
    fi
    echo "$input"
}

resolve_directory() {
    local input="$1"
    local resolved=""

    resolved=$(resolve_path "$input") || return 1
    resolved=$(canonicalize_path "$resolved")

    if [[ -d "$resolved" ]]; then
        echo "$resolved"
    else
        dirname -- "$resolved"
    fi
}

if [[ $# -eq 0 ]]; then
    print_usage >&2
    exit 1
fi

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    print_usage
    exit 0
fi

exit_code=0

for input in "$@"; do
    resolve_directory "$input" || exit_code=1
done

exit "$exit_code"

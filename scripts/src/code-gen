#!/usr/bin/env python3
import argparse
import secrets
import string
import sys

LETTERS = string.ascii_letters          # A-Z a-z
ALNUM = string.ascii_letters + string.digits

def gen_code(length: int) -> str:
    if length < 1:
        raise ValueError("length must be >= 1")
    first = secrets.choice(LETTERS)  # must start with a letter
    if length == 1:
        return first
    rest = ''.join(secrets.choice(ALNUM) for _ in range(length - 1))
    return first + rest

def main():
    p = argparse.ArgumentParser(description="Generate an alphanumeric code starting with a letter.")
    p.add_argument("length", type=int, help="Total length of the code (>= 1)")
    args = p.parse_args()

    try:
        print(gen_code(args.length))
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()

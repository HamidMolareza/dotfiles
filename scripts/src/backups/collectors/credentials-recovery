#!/usr/bin/env bash

set -Eeuo pipefail

PROJECT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=lib/collector-common
source "$PROJECT_DIR/lib/collector-common"

CONFIG_FILE="${BACKUP_HOME_CREDENTIALS_CONFIG:-$PROJECT_DIR/config/credentials-recovery/local.conf}"
declare -A COMPONENT_PATHS=()
declare -a COMPONENT_ORDER=()

load_config() {
  local line
  local component
  local relative

  [[ -f "$CONFIG_FILE" ]] || collector_fail "Credentials recovery config not found: $CONFIG_FILE"
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -n "$line" && "$line" != \#* ]] || continue
    IFS='|' read -r component relative extra <<<"$line"
    [[ -n "$component" && -n "$relative" && -z "${extra:-}" ]] \
      || collector_fail "Invalid credentials config entry: $line"
    collector_validate_name "$component"
    collector_validate_relative_path "$relative"
    if [[ -z "${COMPONENT_PATHS[$component]+x}" ]]; then
      COMPONENT_ORDER+=("$component")
      COMPONENT_PATHS["$component"]="$relative"
    else
      COMPONENT_PATHS["$component"]+=$'\n'"$relative"
    fi
  done <"$CONFIG_FILE"
  [[ "${#COMPONENT_ORDER[@]}" -gt 0 ]] \
    || collector_fail "Credentials recovery config has no paths"
}

archive_component() {
  local component="$1"
  local archive="$COLLECTOR_STAGE_DIR/$component.tar"
  local list_file="$COLLECTOR_STAGE_DIR/.$component.paths"
  local relative
  local found=0
  local before_signature
  local after_signature

  : >"$list_file"
  while IFS= read -r relative; do
    [[ -n "$relative" ]] || continue
    if [[ -e "$COLLECTOR_SOURCE_HOME/$relative" || -L "$COLLECTOR_SOURCE_HOME/$relative" ]]; then
      printf '%s\0' "$relative" >>"$list_file"
      printf '%s\t%s\n' "$component" "$relative" >>"$COLLECTOR_STAGE_DIR/paths.tsv"
      found=1
    else
      collector_warn "Configured credential path was not found: $relative"
      collector_index credential "$relative" "$component.tar" missing "path not found"
    fi
  done <<<"${COMPONENT_PATHS[$component]}"

  if [[ "$found" -eq 1 ]]; then
    before_signature="$(component_signature "$component")"
    tar --create --file "$archive" --directory "$COLLECTOR_SOURCE_HOME" \
      --null --verbatim-files-from --files-from "$list_file"
    after_signature="$(component_signature "$component")"
    [[ "$before_signature" == "$after_signature" ]] \
      || { rm -f -- "$archive"; collector_fail "Credential files changed while archiving component: $component"; }
    [[ -s "$archive" ]] || collector_fail "Credential archive is empty: $component"
    chmod 600 -- "$archive"
    collector_index credential "$component" "$component.tar" success "metadata-preserving tar"
  fi
  rm -f -- "$list_file"
}

component_signature() {
  local component="$1" relative source
  {
    while IFS= read -r relative; do
      [[ -n "$relative" ]] || continue
      source="$COLLECTOR_SOURCE_HOME/$relative"
      if [[ -d "$source" && ! -L "$source" ]]; then
        find "$source" -printf '%P\t%y\t%s\t%T@\t%l\n'
      elif [[ -e "$source" || -L "$source" ]]; then
        stat -c '%n\t%F\t%s\t%Y\t%N' -- "$source"
      fi
    done <<<"${COMPONENT_PATHS[$component]}"
  } | sort | sha256sum | awk '{print $1}'
}

main() {
  local command
  local component

  for command in awk find mkdir sha256sum sort stat tar xargs; do collector_require_command "$command"; done
  collector_init
  load_config
  printf 'component\trelative_path\n' >"$COLLECTOR_STAGE_DIR/paths.tsv"
  for component in "${COMPONENT_ORDER[@]}"; do archive_component "$component"; done
  cat >"$COLLECTOR_STAGE_DIR/RESTORE.md" <<'EOF'
# Credential recovery

These archives contain sensitive authentication material. Keep the backup and the
recovery session private. Use the guided recovery handler, review every component,
and close Codex, GitHub CLI, browsers, and GPG agents before replacing existing
state. The handler creates a safety archive before an approved replacement and does
not print secret contents.
EOF
  collector_finalize
}

main "$@"

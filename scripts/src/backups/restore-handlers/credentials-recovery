#!/usr/bin/env bash

set -Eeuo pipefail

ACTION="${1:-}"
COMPONENT="${2:-}"
ARTIFACT_DIR="${BACKUP_HOME_ARTIFACT_DIR:-}"
TARGET_HOME="${BACKUP_HOME_TARGET_HOME:-}"
TARGET_UID="${BACKUP_HOME_TARGET_UID:-}"
TARGET_GID="${BACKUP_HOME_TARGET_GID:-}"
SESSION_DIR="${BACKUP_HOME_RESTORE_SESSION_DIR:-}"
DRY_RUN="${BACKUP_HOME_RESTORE_DRY_RUN:-0}"
DESTRUCTIVE_APPROVED="${BACKUP_HOME_DESTRUCTIVE_APPROVED:-0}"

fail() { printf 'Error: %s\n' "$*" >&2; exit 1; }
component_name() { printf '%s\n' "${1#credentials.}"; }
archive_path() { printf '%s/%s.tar\n' "$ARTIFACT_DIR" "$(component_name "$1")"; }

validate_relative() {
  [[ -n "$1" && "$1" != /* && ! "$1" =~ (^|/)\.\.?(/|$) ]] \
    || fail "Unsafe path in credential artifact"
}

component_paths() {
  local name
  name="$(component_name "$1")"
  awk -F '\t' -v wanted="$name" 'NR > 1 && $1 == wanted {print $2}' "$ARTIFACT_DIR/paths.tsv"
}

validate_archive() {
  local member
  while IFS= read -r member; do
    member="${member#./}"
    validate_relative "${member%/}"
  done < <(tar -tf "$(archive_path "$1")")
}

describe() {
  local name
  local label
  local risk
  for name in ssh-gpg keyring github codex; do
    [[ -s "$ARTIFACT_DIR/$name.tar" ]] || continue
    case "$name" in
      ssh-gpg) label="SSH and GnuPG identity material"; risk=destructive ;;
      keyring) label="GNOME keyring"; risk=destructive ;;
      github) label="GitHub CLI authentication configuration"; risk=destructive ;;
      codex) label="Codex authentication and secret configuration"; risk=destructive ;;
    esac
    printf 'component\tcredentials.%s\t%s\tautomatic\t%s\t%s\n' \
      "$name" "$label" "$risk" recommended
  done
}

has_existing() {
  local relative
  while IFS= read -r relative; do
    validate_relative "$relative"
    [[ -e "$TARGET_HOME/$relative" || -L "$TARGET_HOME/$relative" ]] && return 0
  done < <(component_paths "$COMPONENT")
  return 1
}

related_processes_running() {
  local -a user_scope=()
  [[ -z "$TARGET_UID" ]] || user_scope=(-u "$TARGET_UID")
  case "$COMPONENT" in
    credentials.keyring) pgrep "${user_scope[@]}" -x gnome-keyring-daemon >/dev/null 2>&1 ;;
    credentials.ssh-gpg) pgrep "${user_scope[@]}" -x gpg-agent >/dev/null 2>&1 ;;
    credentials.codex) pgrep "${user_scope[@]}" -x codex >/dev/null 2>&1 \
      || pgrep "${user_scope[@]}" -f '[R]ecall-mcp|[m]emorymcp|[m]cp-mssql' >/dev/null 2>&1 ;;
    *) return 1 ;;
  esac
}

preflight() {
  [[ -s "$(archive_path "$COMPONENT")" ]] || { printf 'blocker\tCredential archive is missing\n'; return; }
  validate_archive "$COMPONENT"
  printf 'ok\tCredential archive paths are safe and readable\n'
  if [[ "$COMPONENT" != credentials.github ]] && ! command -v pgrep >/dev/null 2>&1; then
    printf 'blocker\tpgrep is unavailable; credential-user process shutdown cannot be verified\n'
  elif related_processes_running; then
    printf 'blocker\tA process using this credential component is running; restore from a logged-out TTY or stop it first\n'
  fi
  if has_existing; then
    printf 'risk\tdestructive\n'
    printf 'warning\tExisting credential state will be safety-archived before replacement\n'
  fi
}

apply() {
  local relative
  local safety_dir="$SESSION_DIR/safety/$COMPONENT"
  local safety_list="$safety_dir/paths.list"
  local extract_root="$SESSION_DIR/extracted/$COMPONENT"
  local existing=0

  validate_archive "$COMPONENT"
  if [[ "$COMPONENT" != credentials.github ]]; then
    command -v pgrep >/dev/null 2>&1 || fail "pgrep is required to verify process shutdown"
  fi
  if related_processes_running; then
    fail "A process using this credential component is still running"
  fi
  has_existing && existing=1
  [[ "$existing" -eq 0 || "$DESTRUCTIVE_APPROVED" -eq 1 ]] \
    || fail "Existing credentials require component-specific destructive approval"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Would restore %s into %s after creating a safety archive.\n' "$COMPONENT" "$TARGET_HOME"
    return 0
  fi
  mkdir -p -- "$safety_dir" "$TARGET_HOME"
  chmod 700 -- "$safety_dir"
  : >"$safety_list"
  while IFS= read -r relative; do
    validate_relative "$relative"
    if [[ -e "$TARGET_HOME/$relative" || -L "$TARGET_HOME/$relative" ]]; then
      printf '%s\0' "$relative" >>"$safety_list"
    fi
  done < <(component_paths "$COMPONENT")
  if [[ -s "$safety_list" ]]; then
    tar -C "$TARGET_HOME" --null --verbatim-files-from -T "$safety_list" \
      -cf "$safety_dir/pre-restore.tar"
    chmod 600 -- "$safety_dir/pre-restore.tar"
  fi
  rm -rf -- "$extract_root"
  mkdir -p -- "$extract_root"
  chmod 700 -- "$extract_root"
  tar -C "$extract_root" --no-same-owner -xf "$(archive_path "$COMPONENT")"
  rsync -a -- "$extract_root/" "$TARGET_HOME/"
  if [[ -n "$TARGET_UID" && "$TARGET_UID" != "$(id -u)" ]]; then
    command -v sudo >/dev/null 2>&1 || fail "sudo is required to set target ownership"
    while IFS= read -r relative; do
      sudo chown -hR -- "$TARGET_UID:$TARGET_GID" "$TARGET_HOME/$relative"
    done < <(component_paths "$COMPONENT")
  fi
}

verify() {
  local relative
  while IFS= read -r relative; do
    [[ -e "$TARGET_HOME/$relative" || -L "$TARGET_HOME/$relative" ]] \
      || fail "Restored credential path is missing: $relative"
  done < <(component_paths "$COMPONENT")
}

guide() {
  case "$COMPONENT" in
    credentials.ssh-gpg) printf '%s\n' 'Run `ssh-add -l`, test one known host, and verify GnuPG secret-key listings without sharing their output.' ;;
    credentials.keyring) printf '%s\n' 'Log out and back in after restoration, then verify that the login keyring unlocks normally.' ;;
    credentials.github) printf '%s\n' 'Run `env -u GITHUB_TOKEN -u GH_TOKEN gh auth status` and validate each configured account.' ;;
    credentials.codex) printf '%s\n' 'Start Codex only after file ownership is correct; verify MCP connections with read-only calls before making changes.' ;;
    *) fail "Unknown credential component: $COMPONENT" ;;
  esac
}

[[ -n "$ARTIFACT_DIR" && -n "$TARGET_HOME" ]] || fail "Restore environment is incomplete"
case "$ACTION" in
  describe) describe ;;
  preflight) preflight ;;
  apply) apply ;;
  verify) verify ;;
  guide) guide ;;
  *) fail "Unknown restore handler action: $ACTION" ;;
esac

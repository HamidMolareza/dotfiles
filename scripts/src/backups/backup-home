usage() {
  cat <<EOF
Usage:
  $SCRIPT_NAME [global-options] <command> [command-options]

Commands:
  plan       Show profile, excludes, resolved roots, collectors, and retention
  manual     Walk through the manual pre-backup checklist
  run        Create a timestamped rsync snapshot
  list       List finalized snapshots and their status
  verify     Validate a snapshot; add --deep for recorded checksums
  restore    Restore a full snapshot or one absolute path
  restore-plan  Inspect recovery readiness without changing the target
  recover    Run or resume a guided recovery session
  prune      Preview retention candidates; add --yes to delete
  drill      Restore one path to a temporary directory and compare it
  help       Show this help text

Global options:
  --dest PATH             Backup destination root
  --config-file PATH      Profile config (default: $DEFAULT_PROFILE_FILE)
  --manual-file PATH      Manual checklist (default: $DEFAULT_MANUAL_FILE)
  --collectors-file PATH  Collector config (default: $DEFAULT_COLLECTORS_FILE)
  --retention-file PATH   Retention config (default: $DEFAULT_RETENTION_FILE)
  --handlers-file PATH    Local restore handler config (default: $DEFAULT_HANDLERS_FILE)
  --dry-run               Preview write-capable work
  --verbose               Show detailed command output
  --yes                   Confirm real run, restore, or prune operations
  --ignore-errors         Finish diagnostics but preserve a failing exit code
  --log-file PATH         Explicit run log path
  -h, --help              Show help

Command options:
  verify [SNAPSHOT] [--deep]
  restore SNAPSHOT --restore-to PATH [--path ABSOLUTE_PATH] [--yes]
  restore-plan [SNAPSHOT] [--target-user NAME] [--target-home PATH]
               [--staging-dir PATH] [--map-path SOURCE=TARGET]
               [--skip-deep-verify] [--allow-legacy]
  recover [SNAPSHOT] [--component ID ... | --all] [--yes]
          [--approve-destructive ID ...] [--resume SESSION_ID]
          [--target-user NAME] [--target-home PATH] [--staging-dir PATH]
          [--map-path SOURCE=TARGET] [--allow-legacy]
  prune [--keep-last N] [--yes]
  drill SNAPSHOT --path ABSOLUTE_PATH [--dry-run]

Profile format:
  include=/home/alice/Projects
  exclude_file=../excludes/common.exclude
  sensitive=yes
  unencrypted_destination=warn

Collector format:
  required|system-inventory|builtin:system-inventory
  optional|repository-export|/absolute/path/to/wrapper

Restore handler format:
  collector-name|/absolute/path/to/restore-handler
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

die_with_code() {
  local code="$1"
  shift
  printf 'Error: %s\n' "$*" >&2
  exit "$code"
}

warn() {
  printf 'Warning: %s\n' "$*" >&2
}

log_line() {
  local message="$1"
  printf '%s\n' "$message"
  if [[ -n "$ACTIVE_LOG_FILE" ]]; then
    printf '%s\n' "$message" >>"$ACTIVE_LOG_FILE"
  fi
}

warn_line() {
  local message="$1"
  warn "$message"
  if [[ -n "$ACTIVE_LOG_FILE" ]]; then
    printf 'WARNING: %s\n' "$message" >>"$ACTIVE_LOG_FILE"
  fi
}

record_warning() {
  local message="$1"
  RUN_WARNINGS+=("$message")
  warn_line "$message"
}

print_heading() {
  printf '%s\n' "$1"
}

print_label_value() {
  printf '%s %s\n' "$1" "$2"
}

trim_whitespace() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

normalize_config_line() {
  local line="$1"
  line="$(printf '%s\n' "$line" | sed -E 's/[[:space:]]+#.*$//')"
  line="$(trim_whitespace "$line")"
  if [[ "$line" == \#* ]]; then
    printf '\n'
  else
    printf '%s\n' "$line"
  fi
}

reject_control_characters() {
  local value="$1"
  local label="$2"
  [[ "$value" != *$'\t'* && "$value" != *$'\n'* && "$value" != *$'\r'* ]] \
    || die "$label contains unsupported control characters"
}

timestamp_now() {
  date '+%Y-%m-%d_%H-%M-%S'
}

iso_now() {
  date --iso-8601=seconds
}

canonicalize_path() {
  readlink -m -- "$1"
}

require_commands() {
  local command_name
  for command_name in "$@"; do
    command -v "$command_name" >/dev/null 2>&1 || die "Missing required command: $command_name"
  done
}

cleanup_temp_files() {
  local path
  for path in "${TEMP_FILES[@]}"; do
    [[ -n "$path" && -f "$path" ]] && rm -f -- "$path"
  done
  TEMP_FILES=()
}

safe_remove_tree() {
  local path="$1"
  [[ -n "$path" && "$path" != "/" ]] || return 0

  case "$path" in
    "${TMPDIR:-/tmp}"/backup-home-stage.*)
      rm -rf --one-file-system -- "$path"
      ;;
    */snapshots/.incomplete-*)
      rm -rf --one-file-system -- "$path"
      ;;
    *)
      warn "Refusing to clean unexpected temporary path: $path"
      return 1
      ;;
  esac
}

cleanup_run_data() {
  if [[ -n "$RUN_STAGE_DIR" && -e "$RUN_STAGE_DIR" ]]; then
    safe_remove_tree "$RUN_STAGE_DIR" || true
  fi
  RUN_STAGE_DIR=""

  if [[ -n "$INCOMPLETE_SNAPSHOT_DIR" && -e "$INCOMPLETE_SNAPSHOT_DIR" ]]; then
    safe_remove_tree "$INCOMPLETE_SNAPSHOT_DIR" || true
  fi
  INCOMPLETE_SNAPSHOT_DIR=""
}

release_lock() {
  if [[ -n "$LOCK_FD" ]]; then
    if [[ "$LOCK_MODE" == "exclusive" && -n "$LOCK_OWNER_FILE" ]]; then
      rm -f -- "$LOCK_OWNER_FILE" || true
    fi
    flock -u "$LOCK_FD" 2>/dev/null || true
    exec {LOCK_FD}>&-
  fi
  LOCK_FD=""
  LOCK_MODE=""
  LOCK_PATH=""
  LOCK_OWNER_FILE=""
}

manifest_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//$'\t'/\\t}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  printf '%s' "$value"
}

write_failure_report() {
  local message="$1"
  local code="$2"
  local base
  local ended_at

  [[ "$RUN_FAILURE_REPORTED" -eq 0 ]] || return 0
  [[ -n "$DEST_ROOT_REAL" && -d "$DEST_ROOT_REAL/logs" ]] || return 0

  base="$DEST_ROOT_REAL/logs/backup-home-${SNAPSHOT_NAME:-unknown}"
  ended_at="$(iso_now)"
  {
    printf 'schema_version\t1\n'
    printf 'snapshot\t%s\n' "$(manifest_escape "${SNAPSHOT_NAME:-unknown}")"
    printf 'status\tfailed\n'
    printf 'started_at\t%s\n' "$(manifest_escape "${RUN_STARTED_AT:-unknown}")"
    printf 'ended_at\t%s\n' "$(manifest_escape "$ended_at")"
    printf 'exit_code\t%s\n' "$code"
    printf 'message\t%s\n' "$(manifest_escape "$message")"
  } >"$base.failure.tsv"
  {
    printf 'Backup run failed\n\n'
    printf 'Snapshot: %s\n' "${SNAPSHOT_NAME:-unknown}"
    printf 'Started: %s\n' "${RUN_STARTED_AT:-unknown}"
    printf 'Ended: %s\n' "$ended_at"
    printf 'Exit code: %s\n' "$code"
    printf 'Reason: %s\n' "$message"
  } >"$base.failure.txt"
  RUN_FAILURE_REPORTED=1
}

write_log_footer() {
  local status="$1"
  [[ -n "$ACTIVE_LOG_FILE" ]] || return 0
  {
    printf '\nend=%s\n' "$(iso_now)"
    printf 'status=%s\n' "$status"
  } >>"$ACTIVE_LOG_FILE"
}

cleanup() {
  local code=$?
  trap - EXIT
  set +e
  if [[ "$code" -ne 0 && "$RUN_ACTIVE" -eq 1 ]]; then
    write_failure_report "Run aborted before completion" "$code"
    write_log_footer "failed"
  fi
  cleanup_run_data
  cleanup_temp_files
  release_lock
  exit "$code"
}

handle_interrupt() {
  exit 130
}

trap cleanup EXIT
trap handle_interrupt INT TERM

parse_profile_file() {
  local line
  local key
  local value
  local profile_dir
  local exclude_path
  local sensitive_seen=0
  local policy_seen=0

  [[ -f "$PROFILE_FILE" ]] || die "Profile file not found: $PROFILE_FILE"
  PROFILE_FILE="$(canonicalize_path "$PROFILE_FILE")"
  profile_dir="$(dirname "$PROFILE_FILE")"
  INCLUDE_RULES=()
  INCLUDE_ANCHORS=()
  EXCLUDE_FILES=()
  SENSITIVE_PROFILE="no"
  UNENCRYPTED_DESTINATION_POLICY="allow"
  DESTINATION_ENCRYPTION_STATE="not-applicable"

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(normalize_config_line "$line")"
    [[ -n "$line" ]] || continue
    [[ "$line" == *=* ]] || die "Invalid profile entry: $line"
    key="$(trim_whitespace "${line%%=*}")"
    value="$(trim_whitespace "${line#*=}")"
    [[ -n "$value" ]] || die "Profile value is empty for key: $key"
    reject_control_characters "$value" "Profile value"

    case "$key" in
      include)
        [[ "$value" == /* ]] || die "Include values must be absolute: $value"
        [[ "$value" != "/" ]] || die "Include path / is not allowed"
        INCLUDE_RULES+=("${value%/}")
        ;;
      exclude_file)
        if [[ "$value" == /* ]]; then
          exclude_path="$(canonicalize_path "$value")"
        else
          exclude_path="$(canonicalize_path "$profile_dir/$value")"
        fi
        EXCLUDE_FILES+=("$exclude_path")
        ;;
      sensitive)
        [[ "$sensitive_seen" -eq 0 ]] || die "Duplicate profile key: sensitive"
        case "$value" in
          yes|no) SENSITIVE_PROFILE="$value" ;;
          *) die "Profile sensitive value must be yes or no: $value" ;;
        esac
        sensitive_seen=1
        ;;
      unencrypted_destination)
        [[ "$policy_seen" -eq 0 ]] || die "Duplicate profile key: unencrypted_destination"
        case "$value" in
          warn|require|allow) UNENCRYPTED_DESTINATION_POLICY="$value" ;;
          *) die "Profile unencrypted_destination must be warn, require, or allow: $value" ;;
        esac
        policy_seen=1
        ;;
      *)
        die "Unknown profile key: $key"
        ;;
    esac
  done <"$PROFILE_FILE"

  [[ "${#INCLUDE_RULES[@]}" -gt 0 ]] || die "Profile has no include entries: $PROFILE_FILE"
}

parse_exclude_files() {
  local exclude_file
  local line

  EXCLUDE_RULES=()
  for exclude_file in "${EXCLUDE_FILES[@]}"; do
    [[ -f "$exclude_file" ]] || die "Exclude file not found: $exclude_file"
    while IFS= read -r line || [[ -n "$line" ]]; do
      line="$(normalize_config_line "$line")"
      [[ -n "$line" ]] || continue
      [[ "$line" != '!'* ]] || die "Exclude entries must not start with !: $line"
      [[ "$line" != "/" ]] || die "Exclude path / is not allowed"
      reject_control_characters "$line" "Exclude entry"
      EXCLUDE_RULES+=("${line%/}")
    done <"$exclude_file"
  done

  if [[ "${#EXCLUDE_RULES[@]}" -gt 0 ]]; then
    mapfile -t EXCLUDE_RULES < <(printf '%s\n' "${EXCLUDE_RULES[@]}" | awk 'NF && !seen[$0]++')
  fi
}

has_glob_pattern() {
  local value="$1"
  [[ "$value" == *'*'* || "$value" == *'?'* || "$value" == *'['* ]]
}

rule_anchor() {
  local rule="$1"
  local prefix

  if ! has_glob_pattern "$rule"; then
    printf '%s\n' "${rule%/}"
    return 0
  fi

  prefix="$(printf '%s\n' "$rule" | sed -E 's/[*?\[].*$//')"
  prefix="${prefix%/}"
  [[ -n "$prefix" ]] || return 0
  if [[ -e "$prefix" ]]; then
    printf '%s\n' "$prefix"
  else
    dirname -- "$prefix"
  fi
}

populate_include_anchors() {
  local rule
  local anchor
  INCLUDE_ANCHORS=()
  for rule in "${INCLUDE_RULES[@]}"; do
    anchor="$(rule_anchor "$rule")"
    [[ -n "$anchor" ]] && INCLUDE_ANCHORS+=("$(canonicalize_path "$anchor")")
  done
}

is_absolute_rule() {
  [[ "$1" == /* ]]
}

matches_exclude_rule() {
  local path="$1"
  local rule="$2"
  local relative_path
  local suffix

  if is_absolute_rule "$rule"; then
    if has_glob_pattern "$rule"; then
      # shellcheck disable=SC2053 # The configured rule is intentionally a glob.
      [[ "$path" == $rule ]]
    else
      [[ "$path" == "$rule" || "$path" == "$rule"/* ]]
    fi
    return
  fi

  relative_path="${path#/}"
  if has_glob_pattern "$rule"; then
    suffix="$relative_path"
    while :; do
      # shellcheck disable=SC2053 # The configured rule is intentionally a glob.
      if [[ "$suffix" == $rule || "$suffix" == $rule/* ]]; then
        return 0
      fi
      [[ "$suffix" == */* ]] || break
      suffix="${suffix#*/}"
    done
    return 1
  fi

  [[ "$relative_path" == "$rule" || "$relative_path" == "$rule"/* || \
     "$relative_path" == */"$rule" || "$relative_path" == */"$rule"/* ]]
}

is_excluded_path() {
  local path="$1"
  local rule
  for rule in "${EXCLUDE_RULES[@]}"; do
    matches_exclude_rule "$path" "$rule" && return 0
  done
  return 1
}

expand_include_rule() {
  local rule="$1"
  local nullglob_was_set=0
  local dotglob_was_set=0
  local globstar_was_set=0
  local match

  if ! has_glob_pattern "$rule"; then
    if [[ -e "$rule" ]]; then
      printf '%s\n' "$(canonicalize_path "$rule")"
    fi
    return 0
  fi

  shopt -q nullglob && nullglob_was_set=1
  shopt -q dotglob && dotglob_was_set=1
  shopt -q globstar && globstar_was_set=1
  shopt -s nullglob dotglob globstar
  while IFS= read -r match; do
    [[ -n "$match" ]] && printf '%s\n' "$(canonicalize_path "$match")"
  done < <(compgen -G "$rule" || true)
  [[ "$nullglob_was_set" -eq 1 ]] || shopt -u nullglob
  [[ "$dotglob_was_set" -eq 1 ]] || shopt -u dotglob
  [[ "$globstar_was_set" -eq 1 ]] || shopt -u globstar
}

minimize_paths() {
  local path
  local kept
  local skip
  local -a ordered=()
  local -a minimal=()
  local -a input=("$@")

  [[ "${#input[@]}" -gt 0 ]] || return 0
  mapfile -t ordered < <(
    printf '%s\n' "${input[@]}" \
      | awk 'NF && !seen[$0]++ { print }' \
      | awk -F/ '{ print NF "|" length($0) "|" $0 }' \
      | sort -t'|' -k1,1n -k2,2n \
      | cut -d'|' -f3-
  )

  for path in "${ordered[@]}"; do
    skip=0
    for kept in "${minimal[@]}"; do
      if [[ "$path" == "$kept" || "$path" == "$kept"/* ]]; then
        skip=1
        break
      fi
    done
    [[ "$skip" -eq 0 ]] && minimal+=("$path")
  done
  printf '%s\n' "${minimal[@]}"
}

resolve_transfer_paths() {
  local rule
  local candidate
  local matched_count
  local -a raw_paths=()
  local -a raw_expected=()

  RUN_WARNINGS=()
  for rule in "${INCLUDE_RULES[@]}"; do
    candidate="$(rule_anchor "$rule")"
    if [[ -n "$candidate" ]]; then
      candidate="$(canonicalize_path "$candidate")"
      [[ -e "$candidate" ]] && raw_expected+=("$candidate")
    fi

    matched_count=0
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      matched_count=1
      is_excluded_path "$candidate" && continue
      raw_paths+=("$candidate")
    done < <(expand_include_rule "$rule")

    if [[ "$matched_count" -eq 0 ]]; then
      record_warning "No existing path matched include entry: $rule"
    fi
  done

  [[ "${#raw_paths[@]}" -gt 0 ]] || die "No paths matched profile includes: $PROFILE_FILE"
  mapfile -t TRANSFER_PATHS < <(minimize_paths "${raw_paths[@]}")
  mapfile -t EXPECTED_PATHS < <(minimize_paths "${raw_expected[@]}")
  SIZE_REPORT_ENTRIES=()
  SIZE_REPORT_TOTAL=0
  SIZE_REPORT_READY=0
}

load_backup_selection() {
  parse_profile_file
  parse_exclude_files
  populate_include_anchors
  resolve_transfer_paths
}

ensure_dest_required() {
  [[ -n "$DEST_ROOT" ]] || die "--dest is required for the $COMMAND command"
}

ensure_safe_destination() {
  local current_home=""
  ensure_dest_required
  DEST_ROOT_REAL="$(canonicalize_path "$DEST_ROOT")"
  if [[ -n "${HOME:-}" ]]; then
    current_home="$(canonicalize_path "$HOME")"
  fi
  case "$DEST_ROOT_REAL" in
    /)
      die "Dangerous backup destination is not allowed: $DEST_ROOT_REAL"
      ;;
  esac
  [[ -z "$current_home" || "$DEST_ROOT_REAL" != "$current_home" ]] \
    || die "Dangerous backup destination is not allowed: $DEST_ROOT_REAL"
}

ensure_dest_access() {
  local mode="$1"
  local parent
  ensure_safe_destination

  if [[ -d "$DEST_ROOT_REAL" ]]; then
    return 0
  fi
  parent="$(dirname "$DEST_ROOT_REAL")"
  [[ -d "$parent" ]] || die "Destination parent does not exist: $parent"
  [[ -w "$parent" ]] || die "Destination parent is not writable: $parent"
  if [[ "$mode" == "create" ]]; then
    mkdir -p -- "$DEST_ROOT_REAL"
  fi
}

ensure_dest_not_inside_sources() {
  local anchor
  for anchor in "${INCLUDE_ANCHORS[@]}"; do
    case "$DEST_ROOT_REAL" in
      "$anchor"|"$anchor"/*)
        die "Destination must not be inside a configured source: $anchor"
        ;;
    esac
  done
}

detect_destination_encryption() {
  local anchor
  local source
  local filesystems

  if [[ "$SENSITIVE_PROFILE" != "yes" ]]; then
    printf 'not-applicable\n'
    return 0
  fi
  if ! command -v findmnt >/dev/null 2>&1 || ! command -v lsblk >/dev/null 2>&1; then
    printf 'unknown\n'
    return 0
  fi

  anchor="$(existing_ancestor "$DEST_ROOT_REAL")"
  source="$(findmnt -T "$anchor" -n -o SOURCE 2>/dev/null | head -n 1 || true)"
  [[ "$source" == /dev/* ]] || { printf 'unknown\n'; return 0; }
  filesystems="$(lsblk -s -n -o FSTYPE -- "$source" 2>/dev/null || true)"
  [[ -n "$filesystems" ]] || { printf 'unknown\n'; return 0; }
  if grep -qx 'crypto_LUKS' <<<"$filesystems"; then
    printf 'detected\n'
  else
    printf 'not-detected\n'
  fi
}

apply_destination_encryption_policy() {
  DESTINATION_ENCRYPTION_STATE="$(detect_destination_encryption)"
  [[ "$SENSITIVE_PROFILE" == "yes" ]] || return 0
  case "$UNENCRYPTED_DESTINATION_POLICY" in
    allow) return 0 ;;
    warn)
      if [[ "$DESTINATION_ENCRYPTION_STATE" != "detected" ]]; then
        record_warning "Sensitive profile destination encryption was not detected (state=$DESTINATION_ENCRYPTION_STATE)"
      fi
      ;;
    require)
      [[ "$DESTINATION_ENCRYPTION_STATE" == "detected" ]] \
        || die "Sensitive profile requires a detected encrypted destination (state=$DESTINATION_ENCRYPTION_STATE)"
      ;;
  esac
}

snapshot_root_dir() {
  printf '%s\n' "$DEST_ROOT_REAL/snapshots"
}

logs_root_dir() {
  printf '%s\n' "$DEST_ROOT_REAL/logs"
}

state_root_dir() {
  printf '%s\n' "$DEST_ROOT_REAL/.backup-home"
}

snapshot_path_for() {
  printf '%s\n' "$(snapshot_root_dir)/$1"
}

validate_snapshot_name() {
  local name="$1"
  [[ "$name" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}$ ]] \
    || die "Invalid snapshot name: $name"
}

list_snapshot_names() {
  local root
  root="$(snapshot_root_dir)"
  [[ -d "$root" ]] || return 0
  find "$root" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' \
    | awk '/^[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}$/' \
    | sort
}

latest_snapshot_name() {
  list_snapshot_names | tail -n 1
}

resolve_snapshot_name() {
  local resolved="$SNAPSHOT_NAME"
  if [[ -z "$resolved" ]]; then
    resolved="$(latest_snapshot_name || true)"
  fi
  [[ -n "$resolved" ]] || die "No finalized snapshots found under $(snapshot_root_dir)"
  validate_snapshot_name "$resolved"
  printf '%s\n' "$resolved"
}

acquire_lock() {
  local mode="$1"
  local state_dir
  local flock_mode
  local owner=""

  [[ -z "$LOCK_FD" ]] || return 0
  state_dir="$(state_root_dir)"
  if [[ "$mode" == "shared" && ! -d "$state_dir" ]]; then
    return 0
  fi
  mkdir -p -- "$state_dir"
  LOCK_PATH="$state_dir/run.lock"
  LOCK_OWNER_FILE="$state_dir/lock-owner.tsv"
  exec {LOCK_FD}<>"$LOCK_PATH"

  flock_mode="-s"
  [[ "$mode" == "exclusive" ]] && flock_mode="-x"
  if ! flock -n -E 75 "$flock_mode" "$LOCK_FD"; then
    [[ -f "$LOCK_OWNER_FILE" ]] && owner="$(tr '\n' ' ' <"$LOCK_OWNER_FILE")"
    if [[ -n "$owner" ]]; then
      die_with_code 75 "Destination lock is busy: $LOCK_PATH ($owner)"
    fi
    die_with_code 75 "Destination lock is busy: $LOCK_PATH"
  fi

  LOCK_MODE="$mode"
  if [[ "$mode" == "exclusive" ]]; then
    {
      printf 'pid\t%s\n' "$$"
      printf 'command\t%s\n' "$COMMAND"
      printf 'hostname\t%s\n' "$(hostname)"
      printf 'started_at\t%s\n' "$(iso_now)"
      printf 'destination\t%s\n' "$DEST_ROOT_REAL"
    } >"$LOCK_OWNER_FILE"
  fi
}

build_size_report() {
  local path
  local size
  local rule
  local -a command_line=()
  [[ "$SIZE_REPORT_READY" -eq 0 ]] || return 0

  SIZE_REPORT_ENTRIES=()
  SIZE_REPORT_TOTAL=0
  for path in "${TRANSFER_PATHS[@]}"; do
    [[ -e "$path" ]] || continue
    command_line=(du -sb)
    for rule in "${EXCLUDE_RULES[@]}"; do
      command_line+=(--exclude="$rule")
    done
    command_line+=(-- "$path")
    size="$("${command_line[@]}" 2>/dev/null | awk 'NR==1 {print $1}' || true)"
    [[ -n "$size" ]] || size=0
    SIZE_REPORT_TOTAL=$((SIZE_REPORT_TOTAL + size))
    SIZE_REPORT_ENTRIES+=("$size|$path")
  done
  SIZE_REPORT_READY=1
}

format_bytes_human() {
  local value="$1"
  awk -v bytes="$value" '
    function human(x) {
      split("B KiB MiB GiB TiB PiB", units, " ")
      i = 1
      while (x >= 1024 && i < 6) { x /= 1024; i++ }
      return sprintf("%.2f %s", x, units[i])
    }
    BEGIN { print human(bytes + 0) }
  '
}

show_size_report() {
  local entry
  local size
  local path
  build_size_report
  print_heading "Estimated size by backup root:"
  if [[ "${#SIZE_REPORT_ENTRIES[@]}" -eq 0 ]]; then
    printf '  - none\n'
    return 0
  fi
  while IFS= read -r entry; do
    size="${entry%%|*}"
    path="${entry#*|}"
    printf '  - %8s  %s\n' "$(format_bytes_human "$size")" "$path"
  done < <(printf '%s\n' "${SIZE_REPORT_ENTRIES[@]}" | sort -t'|' -k1,1nr -k2,2)
}

available_dest_bytes() {
  local target="$DEST_ROOT_REAL"
  while [[ ! -e "$target" && "$target" != "/" ]]; do
    target="$(dirname "$target")"
  done
  df -B1 --output=avail "$target" | awk 'NR==2 {print $1}'
}

build_exclude_file() {
  local temp_file
  local rule
  temp_file="$(mktemp)"
  TEMP_FILES+=("$temp_file")
  for rule in "${EXCLUDE_RULES[@]}"; do
    if is_absolute_rule "$rule"; then
      printf '%s\n' "${rule#/}" >>"$temp_file"
    elif has_glob_pattern "$rule"; then
      printf '%s\n' "$rule" >>"$temp_file"
    else
      printf '**/%s\n' "$rule" >>"$temp_file"
      printf '**/%s/***\n' "$rule" >>"$temp_file"
    fi
  done
  printf '%s\n' "$temp_file"
}

run_command_logged() {
  if [[ "$VERBOSE" -eq 1 ]]; then
    if [[ -n "$ACTIVE_LOG_FILE" ]]; then
      "$@" 2>&1 | tee -a "$ACTIVE_LOG_FILE"
    else
      "$@"
    fi
  elif [[ -n "$ACTIVE_LOG_FILE" ]]; then
    "$@" >>"$ACTIVE_LOG_FILE" 2>&1
  else
    "$@"
  fi
}

rsync_backup() {
  local exclude_file="$1"
  local destination_dir="$2"
  local link_dest_dir="${3:-}"
  local -a command_line=(
    rsync --archive --hard-links --human-readable --relative --mkpath
    --exclude-from="$exclude_file"
  )
  [[ "$DRY_RUN" -eq 1 ]] && command_line+=(--dry-run)
  [[ "$VERBOSE" -eq 1 ]] && command_line+=(--info=progress2 --itemize-changes)
  [[ -n "$link_dest_dir" ]] && command_line+=(--link-dest="$link_dest_dir")
  command_line+=("${TRANSFER_PATHS[@]}" "$destination_dir/")
  run_command_logged "${command_line[@]}"
}

manual_items() {
  local line
  [[ -f "$MANUAL_FILE" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(normalize_config_line "$line")"
    [[ -n "$line" ]] && printf '%s\n' "$line"
  done <"$MANUAL_FILE"
}

parse_manual_entry() {
  local raw="$1"
  local title
  local description=""
  if [[ "$raw" == *'|'* ]]; then
    title="$(trim_whitespace "${raw%%|*}")"
    description="$(trim_whitespace "${raw#*|}")"
  else
    title="$(trim_whitespace "$raw")"
  fi
  [[ -n "$title" ]] || return 1
  printf '%s\t%s\n' "$title" "$description"
}

manual_entries() {
  local item
  while IFS= read -r item; do
    parse_manual_entry "$item" || true
  done < <(manual_items)
}

manual_task_count() {
  local count=0
  local _
  while IFS= read -r _; do
    count=$((count + 1))
  done < <(manual_entries)
  printf '%s\n' "$count"
}

sanitize_name() {
  local value="$1"
  value="$(printf '%s' "$value" | tr -cs '[:alnum:].@_-' '_' | sed -E 's/^_+//; s/_+$//; s/_+/_/g')"
  [[ -n "$value" ]] || value="item"
  printf '%s\n' "$value"
}

prepare_manual_stage() {
  local target_dir="$RUN_STAGE_DIR/artifacts/manual"
  local title
  local description
  local base_name
  local dir_name
  local count
  local reply
  local total
  declare -A used_names=()

  total="$(manual_task_count)"
  [[ "$total" -gt 0 ]] || return 0
  [[ -t 0 ]] || die "Manual staging requires an interactive terminal for a real run"
  mkdir -p -- "$target_dir"
  {
    printf 'Manual backup artifacts for snapshot %s\n\n' "$SNAPSHOT_NAME"
    printf 'Copy files into the matching task directories before continuing.\n'
  } >"$target_dir/README.txt"

  while IFS=$'\t' read -r title description; do
    base_name="$(sanitize_name "$title")"
    count="${used_names[$base_name]:-0}"
    count=$((count + 1))
    used_names["$base_name"]="$count"
    dir_name="$base_name"
    [[ "$count" -gt 1 ]] && dir_name="${base_name}-${count}"
    mkdir -p -- "$target_dir/$dir_name"
    if [[ -n "$description" ]]; then
      printf 'Title: %s\nDescription: %s\n' "$title" "$description" >"$target_dir/$dir_name/task.txt"
    fi
  done < <(manual_entries)

  printf 'Manual checklist staging: %s task(s)\n' "$total"
  printf 'Copy related files into: %s\n' "$target_dir"
  if command -v xdg-open >/dev/null 2>&1; then
    (xdg-open "$target_dir" >/dev/null 2>&1 &) || true
  fi
  printf 'Press Enter when ready, or type q to abort: '
  read -r reply
  case "$reply" in
    q|Q|quit|QUIT) die "Backup cancelled during manual staging" ;;
  esac
}

parse_collectors_file() {
  local line
  local mode
  local name
  local command_path
  local extra
  local existing

  COLLECTOR_MODES=()
  COLLECTOR_NAMES=()
  COLLECTOR_COMMANDS=()
  COLLECTOR_STATUSES=()
  COLLECTOR_EXIT_CODES=()
  COLLECTOR_STARTED_AT=()
  COLLECTOR_ENDED_AT=()
  [[ -f "$COLLECTORS_FILE" ]] || return 0
  COLLECTORS_FILE="$(canonicalize_path "$COLLECTORS_FILE")"

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(normalize_config_line "$line")"
    [[ -n "$line" ]] || continue
    IFS='|' read -r mode name command_path extra <<<"$line"
    mode="$(trim_whitespace "${mode:-}")"
    name="$(trim_whitespace "${name:-}")"
    command_path="$(trim_whitespace "${command_path:-}")"
    [[ -z "${extra:-}" && -n "$mode" && -n "$name" && -n "$command_path" ]] \
      || die "Invalid collector entry: $line"
    [[ "$mode" == "required" || "$mode" == "optional" ]] \
      || die "Collector mode must be required or optional: $mode"
    [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "Invalid collector name: $name"
    for existing in "${COLLECTOR_NAMES[@]}"; do
      [[ "$existing" != "$name" ]] || die "Duplicate collector name: $name"
    done
    if [[ "$command_path" == builtin:* ]]; then
      [[ "$command_path" == "builtin:system-inventory" ]] || die "Unknown built-in collector: $command_path"
    else
      [[ "$command_path" == /* ]] || die "External collector must be an absolute executable: $command_path"
      [[ -x "$command_path" ]] || die "External collector is not executable: $command_path"
    fi
    COLLECTOR_MODES+=("$mode")
    COLLECTOR_NAMES+=("$name")
    COLLECTOR_COMMANDS+=("$command_path")
    COLLECTOR_STATUSES+=("pending")
    COLLECTOR_EXIT_CODES+=("0")
    COLLECTOR_STARTED_AT+=("")
    COLLECTOR_ENDED_AT+=("")
  done <"$COLLECTORS_FILE"
}

inventory_warning() {
  local output_dir="$1"
  shift
  printf '%s\n' "$*" >>"$output_dir/warnings.txt"
}

collector_system_inventory() {
  local output_dir="$1"
  local user_home="${HOME:?HOME is required for system inventory}"
  local crontab_temp
  local source_path

  mkdir -p -- "$output_dir"
  [[ -f /etc/os-release ]] && cp -- /etc/os-release "$output_dir/os-release"
  hostname >"$output_dir/hostname.txt"
  {
    printf 'backup-home script sha256: %s\n' "$(sha256sum "$SCRIPT_DIR/backup-home" | awk '{print $1}')"
    printf 'bash: %s\n' "${BASH_VERSION}"
    printf 'rsync: %s\n' "$(rsync --version | awk 'NR==1 {print $0}')"
  } >"$output_dir/tool-versions.txt"

  if command -v hostnamectl >/dev/null 2>&1; then
    hostnamectl >"$output_dir/hostnamectl.txt" 2>/dev/null || inventory_warning "$output_dir" "hostnamectl export failed"
  fi
  if command -v dconf >/dev/null 2>&1; then
    dconf dump / >"$output_dir/dconf.ini" 2>/dev/null || inventory_warning "$output_dir" "dconf export failed"
  else
    inventory_warning "$output_dir" "dconf is unavailable"
  fi
  if command -v apt-mark >/dev/null 2>&1; then
    apt-mark showmanual 2>/dev/null | sort >"$output_dir/apt-manual.txt" \
      || inventory_warning "$output_dir" "apt-mark export failed"
  fi
  if command -v dpkg >/dev/null 2>&1; then
    dpkg --get-selections >"$output_dir/dpkg-selections.txt" 2>/dev/null \
      || inventory_warning "$output_dir" "dpkg selections export failed"
  fi
  if command -v snap >/dev/null 2>&1; then
    snap list >"$output_dir/snap-list.txt" 2>/dev/null \
      || inventory_warning "$output_dir" "snap list export failed"
  else
    inventory_warning "$output_dir" "snap is unavailable"
  fi
  if command -v flatpak >/dev/null 2>&1; then
    flatpak list --app --columns=application,branch,origin >"$output_dir/flatpak-apps.tsv" 2>/dev/null \
      || inventory_warning "$output_dir" "flatpak list export failed"
  else
    inventory_warning "$output_dir" "flatpak is unavailable"
  fi
  if command -v crontab >/dev/null 2>&1; then
    crontab_temp="$(mktemp)"
    TEMP_FILES+=("$crontab_temp")
    if crontab -l >"$crontab_temp" 2>/dev/null; then
      cp -- "$crontab_temp" "$output_dir/crontab.txt"
    else
      printf 'No readable user crontab was found.\n' >"$output_dir/crontab-status.txt"
    fi
  fi

  for source_path in "$user_home/.local/share/nautilus/scripts" "$user_home/.config/nautilus"; do
    if [[ -e "$source_path" ]]; then
      mkdir -p -- "$output_dir/nautilus"
      rsync --archive --relative "$source_path" "$output_dir/nautilus/" >/dev/null 2>&1 \
        || inventory_warning "$output_dir" "Could not copy Nautilus data from $source_path"
    fi
  done

  {
    printf '# System inventory restore guidance\n\n'
    printf 'These files are recovery references, not an automatic restore program.\n'
    printf 'Review package lists and settings before applying them to another system.\n'
    printf 'Do not run package installation or dconf import commands without a separate review.\n'
  } >"$output_dir/RESTORE.md"
}

run_collectors() {
  local index
  local mode
  local name
  local command_path
  local output_dir
  local rc
  local status

  for index in "${!COLLECTOR_NAMES[@]}"; do
    mode="${COLLECTOR_MODES[$index]}"
    name="${COLLECTOR_NAMES[$index]}"
    command_path="${COLLECTOR_COMMANDS[$index]}"
    output_dir="$RUN_STAGE_DIR/artifacts/collectors/$name"
    mkdir -p -- "$output_dir"
    COLLECTOR_STARTED_AT[index]="$(iso_now)"
    log_line "Collector started: $name ($mode)"

    set +e
    if [[ "$command_path" == "builtin:system-inventory" ]]; then
      collector_system_inventory "$output_dir"
      rc=$?
    elif [[ "$VERBOSE" -eq 1 ]]; then
      BACKUP_HOME_STAGE_DIR="$output_dir" \
      BACKUP_HOME_SNAPSHOT_NAME="$SNAPSHOT_NAME" \
      BACKUP_HOME_DEST="$DEST_ROOT_REAL" \
      BACKUP_HOME_SOURCE_HOME="${HOME:?HOME is required}" \
      BACKUP_HOME_PROFILE_FILE="$PROFILE_FILE" \
      BACKUP_HOME_RUN_STARTED_AT="$RUN_STARTED_AT" \
        "$command_path"
      rc=$?
    else
      BACKUP_HOME_STAGE_DIR="$output_dir" \
      BACKUP_HOME_SNAPSHOT_NAME="$SNAPSHOT_NAME" \
      BACKUP_HOME_DEST="$DEST_ROOT_REAL" \
      BACKUP_HOME_SOURCE_HOME="${HOME:?HOME is required}" \
      BACKUP_HOME_PROFILE_FILE="$PROFILE_FILE" \
      BACKUP_HOME_RUN_STARTED_AT="$RUN_STARTED_AT" \
        "$command_path" >/dev/null 2>&1
      rc=$?
    fi
    set -e

    COLLECTOR_ENDED_AT[index]="$(iso_now)"
    COLLECTOR_EXIT_CODES[index]="$rc"
    status="success"
    if [[ "$rc" -ne 0 ]]; then
      status="failed"
    elif [[ -s "$output_dir/warnings.txt" ]]; then
      status="warning"
    fi
    COLLECTOR_STATUSES[index]="$status"
    log_line "Collector finished: $name status=$status rc=$rc"

    if [[ "$rc" -ne 0 && "$mode" == "required" ]]; then
      return "$rc"
    fi
    if [[ "$rc" -ne 0 && "$mode" == "optional" ]]; then
      record_warning "Optional collector failed: $name (rc=$rc)"
    elif [[ "$status" == "warning" ]]; then
      record_warning "Collector completed with warnings: $name"
    fi
  done
}

profile_digest() {
  {
    printf 'profile\t%s\t' "$PROFILE_FILE"
    sha256sum "$PROFILE_FILE"
    local exclude_file
    for exclude_file in "${EXCLUDE_FILES[@]}"; do
      printf 'exclude\t%s\t' "$exclude_file"
      sha256sum "$exclude_file"
    done
    if [[ -f "$COLLECTORS_FILE" ]]; then
      printf 'collectors\t%s\t' "$COLLECTORS_FILE"
      sha256sum "$COLLECTORS_FILE"
    fi
  } | sha256sum | awk '{print $1}'
}

script_revision() {
  local revision=""
  if command -v git >/dev/null 2>&1; then
    revision="$(git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null || true)"
  fi
  [[ -n "$revision" ]] && printf 'git:%s\n' "$revision" || printf 'unversioned\n'
}

os_release_value() {
  local key="$1"
  awk -F= -v wanted="$key" '$1 == wanted {value=$2; gsub(/^"|"$/, "", value); print value; exit}' /etc/os-release 2>/dev/null || true
}

write_snapshot_report() {
  local path="$1"
  local status="$2"
  local previous_snapshot="$3"
  local index
  {
    printf 'Backup Home snapshot report\n\n'
    printf 'Snapshot: %s\n' "$SNAPSHOT_NAME"
    printf 'Status: %s\n' "$status"
    printf 'Started: %s\n' "$RUN_STARTED_AT"
    printf 'Generated: %s\n' "$(iso_now)"
    printf 'Profile: %s\n' "$PROFILE_FILE"
    printf 'Sensitive profile: %s\n' "$SENSITIVE_PROFILE"
    printf 'Destination encryption state: %s\n' "$DESTINATION_ENCRYPTION_STATE"
    printf 'Unencrypted destination policy: %s\n' "$UNENCRYPTED_DESTINATION_POLICY"
    printf 'Previous snapshot: %s\n' "${previous_snapshot:-none}"
    printf 'Rsync exit code: %s\n' "$RSYNC_EXIT_CODE"
    printf '\nResolved roots:\n'
    printf '  - %s\n' "${TRANSFER_PATHS[@]}"
    printf '\nCollectors:\n'
    if [[ "${#COLLECTOR_NAMES[@]}" -eq 0 ]]; then
      printf '  - none\n'
    else
      for index in "${!COLLECTOR_NAMES[@]}"; do
        printf '  - %s: %s (%s, rc=%s)\n' \
          "${COLLECTOR_NAMES[$index]}" "${COLLECTOR_STATUSES[$index]}" \
          "${COLLECTOR_MODES[$index]}" "${COLLECTOR_EXIT_CODES[$index]}"
      done
    fi
    printf '\nWarnings:\n'
    if [[ "${#RUN_WARNINGS[@]}" -eq 0 ]]; then
      printf '  - none\n'
    else
      printf '  - %s\n' "${RUN_WARNINGS[@]}"
    fi
  } >"$path"
}

record_snapshot_checksums() {
  local snapshot_dir="$1"
  local checksum_file="$snapshot_dir/.backup-home/checksums.sha256"
  local file
  local relative
  local count=0

  : >"$checksum_file"
  if [[ -f "$snapshot_dir/.backup-home/report.txt" ]]; then
    (cd "$snapshot_dir" && sha256sum -- .backup-home/report.txt) >>"$checksum_file"
    count=$((count + 1))
  fi
  if [[ -d "$snapshot_dir/.backup-home/artifacts" ]]; then
    while IFS= read -r -d '' file; do
      relative="${file#"$snapshot_dir"/}"
      (cd "$snapshot_dir" && sha256sum -- "$relative") >>"$checksum_file"
      count=$((count + 1))
    done < <(find "$snapshot_dir/.backup-home/artifacts" -type f -print0 | sort -z)
  fi
  while IFS= read -r -d '' file; do
    relative="${file#"$snapshot_dir"/}"
    (cd "$snapshot_dir" && sha256sum -- "$relative") >>"$checksum_file"
    count=$((count + 1))
  done < <(
    find "$snapshot_dir" -path "$snapshot_dir/.backup-home" -prune -o \
      -type f -size "-${CHECKSUM_SAMPLE_MAX_BYTES}c" -print0 \
      | shuf -z -n "$CHECKSUM_SAMPLE_COUNT"
  )
  printf '%s\n' "$count"
}

snapshot_payload_bytes() {
  local snapshot_dir="$1"
  find "$snapshot_dir" -path "$snapshot_dir/.backup-home" -prune -o -type f -printf '%s\n' \
    | awk '{sum += $1} END {print sum + 0}'
}

write_snapshot_manifest() {
  local path="$1"
  local status="$2"
  local previous_snapshot="$3"
  local checksum_count="$4"
  local file_count="$5"
  local payload_bytes="$6"
  local ended_at="$7"
  local root
  local rule
  local warning_message
  local index
  local script_hash
  script_hash="$(sha256sum "$SCRIPT_DIR/backup-home" | awk '{print $1}')"

  {
    printf 'schema_version\t2\n'
    printf 'snapshot\t%s\n' "$(manifest_escape "$SNAPSHOT_NAME")"
    printf 'status\t%s\n' "$status"
    printf 'started_at\t%s\n' "$(manifest_escape "$RUN_STARTED_AT")"
    printf 'ended_at\t%s\n' "$(manifest_escape "$ended_at")"
    printf 'hostname\t%s\n' "$(manifest_escape "$(hostname)")"
    printf 'os_id\t%s\n' "$(manifest_escape "$(os_release_value ID)")"
    printf 'os_version_id\t%s\n' "$(manifest_escape "$(os_release_value VERSION_ID)")"
    printf 'source_user\t%s\n' "$(manifest_escape "$(id -un)")"
    printf 'source_uid\t%s\n' "$(id -u)"
    printf 'source_gid\t%s\n' "$(id -g)"
    printf 'source_home\t%s\n' "$(manifest_escape "$(canonicalize_path "${HOME:?HOME is required}")")"
    printf 'profile_name\t%s\n' "$(manifest_escape "$(basename "$PROFILE_FILE")")"
    printf 'sensitive_profile\t%s\n' "$SENSITIVE_PROFILE"
    printf 'destination_encryption_state\t%s\n' "$DESTINATION_ENCRYPTION_STATE"
    printf 'unencrypted_destination_policy\t%s\n' "$UNENCRYPTED_DESTINATION_POLICY"
    printf 'config_digest\t%s\n' "$(profile_digest)"
    printf 'previous_snapshot\t%s\n' "$(manifest_escape "${previous_snapshot:-none}")"
    printf 'rsync_exit_code\t%s\n' "$RSYNC_EXIT_CODE"
    printf 'backup_home_revision\t%s\n' "$(script_revision)"
    printf 'script_sha256\t%s\n' "$script_hash"
    printf 'payload_bytes\t%s\n' "$payload_bytes"
    printf 'file_count\t%s\n' "$file_count"
    printf 'checksum_count\t%s\n' "$checksum_count"
    for root in "${TRANSFER_PATHS[@]}"; do
      printf 'root\t%s\n' "$(manifest_escape "$root")"
    done
    for rule in "${EXCLUDE_RULES[@]}"; do
      printf 'exclude\t%s\n' "$(manifest_escape "$rule")"
    done
    for index in "${!COLLECTOR_NAMES[@]}"; do
      printf 'collector\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "${COLLECTOR_NAMES[$index]}" "${COLLECTOR_MODES[$index]}" \
        "${COLLECTOR_STATUSES[$index]}" "${COLLECTOR_EXIT_CODES[$index]}" \
        "${COLLECTOR_STARTED_AT[$index]}" "${COLLECTOR_ENDED_AT[$index]}"
    done
    for warning_message in "${RUN_WARNINGS[@]}"; do
      printf 'warning\t%s\n' "$(manifest_escape "$warning_message")"
    done
  } >"$path"
}

manifest_value() {
  local manifest="$1"
  local key="$2"
  awk -F '\t' -v wanted="$key" '$1 == wanted {print $2; exit}' "$manifest"
}

self_verify_snapshot() {
  local snapshot_dir="$1"
  local expected_name="$2"
  local manifest="$snapshot_dir/.backup-home/manifest.tsv"
  local root
  local key
  local value
  local name
  local mode
  local status
  local rest

  [[ -s "$manifest" ]] || return 1
  case "$(manifest_value "$manifest" schema_version)" in
    1|2) ;;
    *) return 1 ;;
  esac
  [[ "$(manifest_value "$manifest" snapshot)" == "$expected_name" ]] || return 1
  [[ "$(manifest_value "$manifest" status)" == success* ]] || return 1
  while IFS=$'\t' read -r key value rest; do
    case "$key" in
      root)
        root="$value"
        [[ -e "$snapshot_dir$root" || -L "$snapshot_dir$root" ]] || return 1
        ;;
      collector)
        name="$value"
        mode="${rest%%$'\t'*}"
        rest="${rest#*$'\t'}"
        status="${rest%%$'\t'*}"
        if [[ "$mode" == "required" && "$status" != "success" && "$status" != "warning" ]]; then
          return 1
        fi
        [[ -d "$snapshot_dir/.backup-home/artifacts/collectors/$name" ]] || return 1
        ;;
    esac
  done <"$manifest"
}

confirm_or_exit() {
  local prompt="$1"
  local reply
  [[ "$ASSUME_YES" -eq 1 ]] && return 0
  printf '%s [y/N]: ' "$prompt"
  read -r reply
  case "$reply" in
    y|Y|yes|YES) return 0 ;;
    *) die "Operation cancelled" ;;
  esac
}

show_plan() {
  local rule
  local path
  local index
  local title
  local description
  local manual_count=0
  local keep_last

  require_commands find du df date mkdir mktemp readlink sort awk sed dirname cut tr
  ensure_dest_access "check"
  load_backup_selection
  ensure_dest_not_inside_sources
  apply_destination_encryption_policy
  parse_collectors_file
  keep_last="$(read_keep_last)"
  build_size_report

  print_label_value "Profile:" "$PROFILE_FILE"
  print_label_value "Destination:" "$DEST_ROOT_REAL"
  print_label_value "Sensitive profile:" "$SENSITIVE_PROFILE"
  print_label_value "Destination encryption:" "$DESTINATION_ENCRYPTION_STATE ($UNENCRYPTED_DESTINATION_POLICY policy)"
  print_label_value "Estimated source size:" "$(format_bytes_human "$SIZE_REPORT_TOTAL")"
  print_label_value "Retention keep-last:" "$keep_last"
  printf '\n'
  show_size_report
  printf '\nInclude entries:\n'
  printf '  - %s\n' "${INCLUDE_RULES[@]}"
  printf '\nExclude files:\n'
  if [[ "${#EXCLUDE_FILES[@]}" -eq 0 ]]; then
    printf '  - none\n'
  else
    printf '  - %s\n' "${EXCLUDE_FILES[@]}"
  fi
  printf '\nApplied excludes:\n'
  if [[ "${#EXCLUDE_RULES[@]}" -eq 0 ]]; then
    printf '  - none\n'
  else
    for rule in "${EXCLUDE_RULES[@]}"; do printf '  - %s\n' "$rule"; done
  fi
  printf '\nResolved roots:\n'
  for path in "${TRANSFER_PATHS[@]}"; do printf '  - %s\n' "$path"; done
  printf '\nCollectors:\n'
  if [[ "${#COLLECTOR_NAMES[@]}" -eq 0 ]]; then
    printf '  - none\n'
  else
    for index in "${!COLLECTOR_NAMES[@]}"; do
      printf '  - %s | %s | %s\n' "${COLLECTOR_MODES[$index]}" "${COLLECTOR_NAMES[$index]}" "${COLLECTOR_COMMANDS[$index]}"
    done
  fi
  printf '\nManual checklist:\n'
  while IFS=$'\t' read -r title description; do
    [[ -n "$description" ]] && printf '  - %s | %s\n' "$title" "$description" || printf '  - %s\n' "$title"
    manual_count=$((manual_count + 1))
  done < <(manual_entries)
  [[ "$manual_count" -gt 0 ]] || printf '  - none\n'
}

show_manual() {
  local total
  local index=1
  local title
  local description
  local reply
  total="$(manual_task_count)"
  if [[ "$total" -eq 0 ]]; then
    printf 'No manual checklist items are configured.\n'
    return 0
  fi
  while IFS=$'\t' read -r title description; do
    printf '[%d/%s] %s\n' "$index" "$total" "$title"
    [[ -n "$description" ]] && printf '  %s\n' "$description"
    index=$((index + 1))
    if [[ "$ASSUME_YES" -eq 0 && -t 0 ]]; then
      printf 'Press Enter when done, or type q to stop: '
      read -r reply
      case "$reply" in q|Q|quit|QUIT) printf 'Stopped manual checklist.\n'; return 0 ;; esac
    fi
  done < <(manual_entries)
}

setup_run_log() {
  [[ -n "$LOG_FILE" ]] || LOG_FILE="$(logs_root_dir)/backup-home-$SNAPSHOT_NAME.log"
  mkdir -p -- "$(dirname "$LOG_FILE")"
  ACTIVE_LOG_FILE="$LOG_FILE"
  : >"$ACTIVE_LOG_FILE"
  {
    printf 'command=run\n'
    printf 'profile=%s\n' "$PROFILE_FILE"
    printf 'destination=%s\n' "$DEST_ROOT_REAL"
    printf 'snapshot=%s\n' "$SNAPSHOT_NAME"
    printf 'start=%s\n\n' "$RUN_STARTED_AT"
  } >>"$ACTIVE_LOG_FILE"
}

fail_active_run() {
  local message="$1"
  local code="$2"
  write_failure_report "$message" "$code"
  write_log_footer "failed"
  cleanup_run_data
  RUN_ACTIVE=0
  die_with_code "$code" "$message"
}

run_backup() {
  local snapshot_dir
  local previous_snapshot=""
  local link_dest_dir=""
  local exclude_file
  local estimated_bytes
  local free_bytes
  local collector_rc=0
  local status="success"
  local checksum_count
  local file_count
  local payload_bytes
  local ended_at

  require_commands rsync find du df date mkdir mktemp readlink sort wc awk sed dirname cut tr id \
    sha256sum shuf flock hostname mv rm cp tee
  ensure_dest_access "check"
  load_backup_selection
  ensure_dest_not_inside_sources
  apply_destination_encryption_policy
  parse_collectors_file
  build_size_report
  estimated_bytes="$SIZE_REPORT_TOTAL"
  free_bytes="$(available_dest_bytes)"
  SNAPSHOT_NAME="$(timestamp_now)"
  RUN_STARTED_AT="$(iso_now)"
  previous_snapshot="$(latest_snapshot_name || true)"

  print_label_value "Profile:" "$PROFILE_FILE"
  print_label_value "Destination:" "$DEST_ROOT_REAL"
  print_label_value "Sensitive profile:" "$SENSITIVE_PROFILE"
  print_label_value "Destination encryption:" "$DESTINATION_ENCRYPTION_STATE ($UNENCRYPTED_DESTINATION_POLICY policy)"
  print_label_value "Snapshot:" "$SNAPSHOT_NAME"
  print_label_value "Estimated source size:" "$(format_bytes_human "$estimated_bytes")"
  print_label_value "Available destination space:" "$(format_bytes_human "$free_bytes")"
  show_size_report
  if [[ "$IGNORE_ERRORS" -eq 1 ]]; then
    log_line "Ignore-errors mode: diagnostics may continue, but required failures remain non-zero"
  fi
  if [[ "${#COLLECTOR_NAMES[@]}" -gt 0 ]]; then
    printf 'Collectors:\n'
    local index
    for index in "${!COLLECTOR_NAMES[@]}"; do
      printf '  - would run %s (%s)\n' "${COLLECTOR_NAMES[$index]}" "${COLLECTOR_MODES[$index]}"
    done
  fi

  exclude_file="$(build_exclude_file)"
  snapshot_dir="$(snapshot_path_for "$SNAPSHOT_NAME")"
  [[ -n "$previous_snapshot" ]] && link_dest_dir="$(snapshot_path_for "$previous_snapshot")"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    acquire_lock "shared"
    log_line "Mode: dry-run; collectors and manual staging are not executed"
    set +e
    rsync_backup "$exclude_file" "$snapshot_dir" "$link_dest_dir"
    RSYNC_EXIT_CODE=$?
    set -e
    [[ "$RSYNC_EXIT_CODE" -eq 0 ]] || die_with_code "$RSYNC_EXIT_CODE" "Dry-run rsync failed with exit code $RSYNC_EXIT_CODE"
    log_line "Dry-run finished successfully"
    return 0
  fi

  [[ "$estimated_bytes" -eq 0 || "$free_bytes" -ge "$estimated_bytes" ]] \
    || die "Not enough destination space. Need about $(format_bytes_human "$estimated_bytes"), have $(format_bytes_human "$free_bytes")"
  confirm_or_exit "Create snapshot $SNAPSHOT_NAME under $DEST_ROOT_REAL?"
  ensure_dest_access "create"
  acquire_lock "exclusive"
  mkdir -p -- "$(snapshot_root_dir)" "$(logs_root_dir)"
  previous_snapshot="$(latest_snapshot_name || true)"
  [[ -n "$previous_snapshot" ]] && link_dest_dir="$(snapshot_path_for "$previous_snapshot")" || link_dest_dir=""
  snapshot_dir="$(snapshot_path_for "$SNAPSHOT_NAME")"
  [[ ! -e "$snapshot_dir" ]] || die "Snapshot already exists: $snapshot_dir"
  INCOMPLETE_SNAPSHOT_DIR="$(snapshot_root_dir)/.incomplete-$SNAPSHOT_NAME-$$"
  [[ ! -e "$INCOMPLETE_SNAPSHOT_DIR" ]] || die "Incomplete snapshot path already exists: $INCOMPLETE_SNAPSHOT_DIR"
  RUN_STAGE_DIR="$(mktemp -d "${TMPDIR:-/tmp}/backup-home-stage.$SNAPSHOT_NAME.XXXXXX")"
  RUN_ACTIVE=1
  setup_run_log
  log_line "Previous snapshot: ${previous_snapshot:-none}"

  prepare_manual_stage
  set +e
  run_collectors
  collector_rc=$?
  set -e
  if [[ "$collector_rc" -ne 0 ]]; then
    fail_active_run "Required collector failed with exit code $collector_rc" "$collector_rc"
  fi

  mkdir -p -- "$INCOMPLETE_SNAPSHOT_DIR"
  set +e
  rsync_backup "$exclude_file" "$INCOMPLETE_SNAPSHOT_DIR" "$link_dest_dir"
  RSYNC_EXIT_CODE=$?
  set -e
  if [[ "$RSYNC_EXIT_CODE" -ne 0 ]]; then
    fail_active_run "Backup rsync failed with exit code $RSYNC_EXIT_CODE" "$RSYNC_EXIT_CODE"
  fi

  mkdir -p -- "$INCOMPLETE_SNAPSHOT_DIR/.backup-home/artifacts"
  if [[ -d "$RUN_STAGE_DIR/artifacts" ]]; then
    rsync --archive "$RUN_STAGE_DIR/artifacts/" "$INCOMPLETE_SNAPSHOT_DIR/.backup-home/artifacts/"
  fi
  [[ "${#RUN_WARNINGS[@]}" -eq 0 ]] || status="success-with-warnings"
  write_snapshot_report "$INCOMPLETE_SNAPSHOT_DIR/.backup-home/report.txt" "$status" "$previous_snapshot"
  checksum_count="$(record_snapshot_checksums "$INCOMPLETE_SNAPSHOT_DIR")"
  : >"$INCOMPLETE_SNAPSHOT_DIR/.backup-home/manifest.tsv"
  payload_bytes="$(snapshot_payload_bytes "$INCOMPLETE_SNAPSHOT_DIR")"
  file_count="$(find "$INCOMPLETE_SNAPSHOT_DIR" -type f | wc -l | awk '{print $1}')"
  ended_at="$(iso_now)"
  write_snapshot_manifest "$INCOMPLETE_SNAPSHOT_DIR/.backup-home/manifest.tsv" "$status" \
    "$previous_snapshot" "$checksum_count" "$file_count" "$payload_bytes" "$ended_at"

  if ! self_verify_snapshot "$INCOMPLETE_SNAPSHOT_DIR" "$SNAPSHOT_NAME"; then
    fail_active_run "Snapshot self-verification failed" 1
  fi
  mv -- "$INCOMPLETE_SNAPSHOT_DIR" "$snapshot_dir"
  INCOMPLETE_SNAPSHOT_DIR=""
  cleanup_run_data
  write_log_footer "$status"
  RUN_ACTIVE=0
  log_line "Backup finished: $status"
  print_label_value "Manifest:" "$snapshot_dir/.backup-home/manifest.tsv"
}

snapshot_status() {
  local snapshot_dir="$1"
  local manifest="$snapshot_dir/.backup-home/manifest.tsv"
  if [[ -s "$manifest" ]]; then
    manifest_value "$manifest" status
  else
    printf 'legacy\n'
  fi
}

list_backups() {
  local name
  local found=0
  require_commands find readlink sort awk flock hostname
  ensure_dest_access "check"
  acquire_lock "shared"
  print_heading "Snapshots in $(snapshot_root_dir):"
  while IFS= read -r name; do
    printf '  - %s [%s]\n' "$name" "$(snapshot_status "$(snapshot_path_for "$name")")"
    found=1
  done < <(list_snapshot_names)
  [[ "$found" -eq 1 ]] || printf '  - none\n'
}

verify_snapshot() {
  local snapshot
  local snapshot_dir
  local manifest
  local errors=0
  local key
  local value
  local rest
  local name
  local mode
  local status
  local expected_count
  local actual_count
  local expected_path

  require_commands find du readlink sort awk wc sha256sum flock hostname
  ensure_dest_access "check"
  acquire_lock "shared"
  snapshot="$(resolve_snapshot_name)"
  snapshot_dir="$(snapshot_path_for "$snapshot")"
  [[ -d "$snapshot_dir" ]] || die "Snapshot not found: $snapshot_dir"
  manifest="$snapshot_dir/.backup-home/manifest.tsv"
  print_label_value "Snapshot:" "$snapshot"
  print_label_value "Path:" "$snapshot_dir"

  if [[ ! -s "$manifest" ]]; then
    warn_line "Legacy snapshot has no manifest; using the current profile for basic verification"
    [[ "$DEEP_VERIFY" -eq 0 ]] || die "Deep verification is unavailable for legacy snapshots"
    load_backup_selection
    for expected_path in "${EXPECTED_PATHS[@]}"; do
      if [[ -e "$snapshot_dir$expected_path" || -L "$snapshot_dir$expected_path" ]]; then
        printf '  OK  %s\n' "$expected_path"
      else
        printf '  MISSING  %s\n' "$expected_path"
        errors=$((errors + 1))
      fi
    done
  else
    case "$(manifest_value "$manifest" schema_version)" in
      1|2) ;;
      *) errors=$((errors + 1)) ;;
    esac
    [[ "$(manifest_value "$manifest" snapshot)" == "$snapshot" ]] || errors=$((errors + 1))
    status="$(manifest_value "$manifest" status)"
    [[ "$status" == success* ]] || errors=$((errors + 1))
    while IFS=$'\t' read -r key value rest; do
      case "$key" in
        root)
          if [[ -e "$snapshot_dir$value" || -L "$snapshot_dir$value" ]]; then
            printf '  OK  %s\n' "$value"
          else
            printf '  MISSING  %s\n' "$value"
            errors=$((errors + 1))
          fi
          ;;
        collector)
          name="$value"
          mode="${rest%%$'\t'*}"
          rest="${rest#*$'\t'}"
          status="${rest%%$'\t'*}"
          if [[ "$mode" == "required" && "$status" != "success" && "$status" != "warning" ]]; then
            printf '  FAILED REQUIRED COLLECTOR  %s\n' "$name"
            errors=$((errors + 1))
          fi
          if [[ ! -d "$snapshot_dir/.backup-home/artifacts/collectors/$name" ]]; then
            printf '  MISSING COLLECTOR ARTIFACTS  %s\n' "$name"
            errors=$((errors + 1))
          fi
          ;;
      esac
    done <"$manifest"
    expected_count="$(manifest_value "$manifest" file_count)"
    actual_count="$(find "$snapshot_dir" -type f | wc -l | awk '{print $1}')"
    if [[ "$expected_count" != "$actual_count" ]]; then
      printf '  FILE COUNT MISMATCH  expected=%s actual=%s\n' "$expected_count" "$actual_count"
      errors=$((errors + 1))
    fi
    if [[ "$DEEP_VERIFY" -eq 1 ]]; then
      if [[ ! -s "$snapshot_dir/.backup-home/checksums.sha256" ]]; then
        printf '  CHECKSUM SET MISSING\n'
        errors=$((errors + 1))
      elif ! (cd "$snapshot_dir" && sha256sum -c --strict --quiet .backup-home/checksums.sha256); then
        printf '  CHECKSUM VERIFICATION FAILED\n'
        errors=$((errors + 1))
      else
        printf '  CHECKSUMS OK\n'
      fi
    fi
  fi

  print_label_value "Snapshot size:" "$(du -sh -- "$snapshot_dir" | awk '{print $1}')"
  print_label_value "File count:" "$(find "$snapshot_dir" -type f | wc -l | awk '{print $1}')"
  [[ "$errors" -eq 0 ]] || die "Snapshot verification failed with $errors problem(s)"
  printf 'Snapshot verification succeeded.\n'
}

validate_restore_path() {
  local path="$1"
  [[ "$path" == /* ]] || die "--path must be absolute: $path"
  [[ "$path" != "/" && "$path" != "/.backup-home" && "$path" != "/.backup-home/"* ]] \
    || die "Unsafe restore path: $path"
  case "/${path#/}/" in
    */../*|*/./*) die "Restore path traversal is not allowed: $path" ;;
  esac
}

validate_restore_destination() {
  local destination="$1"
  [[ "$destination" != "/" ]] || die "Restore destination / is not allowed"
  case "$destination" in
    "$DEST_ROOT_REAL"|"$DEST_ROOT_REAL"/*)
      die "Restore destination must not be inside the backup destination"
      ;;
  esac
}

rsync_restore() {
  local source_spec="$1"
  local destination="$2"
  local full_restore="$3"
  local -a command_line=(rsync --archive --hard-links --human-readable --mkpath)
  if [[ "$full_restore" -eq 1 ]]; then
    command_line+=(--exclude='/.backup-home')
  else
    command_line+=(--relative)
  fi
  [[ "$DRY_RUN" -eq 1 ]] && command_line+=(--dry-run)
  [[ "$VERBOSE" -eq 1 ]] && command_line+=(--info=progress2 --itemize-changes)
  command_line+=("$source_spec" "$destination/")
  run_command_logged "${command_line[@]}"
}

restore_snapshot() {
  local snapshot
  local snapshot_dir
  local restore_source
  local source_spec
  local mode="dry-run"
  local full_restore=0
  local rc

  require_commands rsync readlink mkdir flock hostname
  ensure_dest_access "check"
  acquire_lock "shared"
  snapshot="$(resolve_snapshot_name)"
  snapshot_dir="$(snapshot_path_for "$snapshot")"
  [[ -d "$snapshot_dir" ]] || die "Snapshot not found: $snapshot_dir"
  [[ -n "$RESTORE_DEST" ]] || die "Restore requires --restore-to PATH"
  RESTORE_DEST="$(canonicalize_path "$RESTORE_DEST")"
  validate_restore_destination "$RESTORE_DEST"

  if [[ -n "$RESTORE_PATH" ]]; then
    validate_restore_path "$RESTORE_PATH"
    RESTORE_PATH="${RESTORE_PATH%/}"
    restore_source="$snapshot_dir$RESTORE_PATH"
    [[ -e "$restore_source" || -L "$restore_source" ]] || die "Restore path not found: $RESTORE_PATH"
    source_spec="$snapshot_dir/./${RESTORE_PATH#/}"
  else
    restore_source="$snapshot_dir"
    source_spec="$snapshot_dir/"
    full_restore=1
  fi

  if [[ "$DRY_RUN" -eq 0 && "$ASSUME_YES" -eq 1 ]]; then
    mode="real"
    mkdir -p -- "$RESTORE_DEST"
  else
    DRY_RUN=1
    [[ -d "$RESTORE_DEST" || -d "$(dirname "$RESTORE_DEST")" ]] \
      || die "Restore destination parent does not exist: $(dirname "$RESTORE_DEST")"
  fi
  print_label_value "Restore snapshot:" "$snapshot"
  print_label_value "Restore source:" "$restore_source"
  print_label_value "Restore destination:" "$RESTORE_DEST"
  print_label_value "Mode:" "$mode"
  [[ "$mode" == "real" ]] || printf 'Restore defaults to dry-run; add --yes to write.\n'

  set +e
  rsync_restore "$source_spec" "$RESTORE_DEST" "$full_restore"
  rc=$?
  set -e
  [[ "$rc" -eq 0 ]] || die_with_code "$rc" "Restore failed with exit code $rc"
}

drill_snapshot() {
  local snapshot
  local snapshot_dir
  local source_path
  local source_spec
  local drill_dir=""
  local restored_path
  local comparison
  local rc

  require_commands rsync readlink mkdir mktemp rm flock hostname
  ensure_dest_access "check"
  acquire_lock "shared"
  snapshot="$(resolve_snapshot_name)"
  snapshot_dir="$(snapshot_path_for "$snapshot")"
  [[ -d "$snapshot_dir" ]] || die "Snapshot not found: $snapshot_dir"
  [[ -n "$RESTORE_PATH" ]] || die "Drill requires --path ABSOLUTE_PATH"
  validate_restore_path "$RESTORE_PATH"
  RESTORE_PATH="${RESTORE_PATH%/}"
  source_path="$snapshot_dir$RESTORE_PATH"
  [[ -e "$source_path" || -L "$source_path" ]] || die "Drill path not found: $RESTORE_PATH"
  source_spec="$snapshot_dir/./${RESTORE_PATH#/}"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    print_label_value "Drill snapshot:" "$snapshot"
    print_label_value "Drill path:" "$RESTORE_PATH"
    print_label_value "Temporary destination:" "${TMPDIR:-/tmp}/backup-home-drill.$snapshot.XXXXXX"
    printf 'Dry-run: no temporary directory or restored files were created.\n'
    return 0
  fi

  drill_dir="$(mktemp -d "${TMPDIR:-/tmp}/backup-home-stage.drill.$snapshot.XXXXXX")"
  RUN_STAGE_DIR="$drill_dir"
  set +e
  rsync --archive --hard-links --relative "$source_spec" "$drill_dir/" >/dev/null 2>&1
  rc=$?
  set -e
  [[ "$rc" -eq 0 ]] || die_with_code "$rc" "Drill restore failed with exit code $rc"
  restored_path="$drill_dir/${RESTORE_PATH#/}"

  set +e
  if [[ -d "$source_path" && ! -L "$source_path" ]]; then
    comparison="$(rsync --archive --hard-links --checksum --dry-run --delete --itemize-changes "$source_path/" "$restored_path/")"
    rc=$?
  else
    comparison="$(rsync --archive --hard-links --checksum --dry-run --itemize-changes "$source_path" "$(dirname "$restored_path")/")"
    rc=$?
  fi
  set -e
  [[ "$rc" -eq 0 ]] || die_with_code "$rc" "Drill comparison failed with exit code $rc"
  [[ -z "$comparison" ]] || die "Drill comparison found content differences"
  cleanup_run_data
  printf 'Restore drill succeeded for %s.\n' "$RESTORE_PATH"
}

array_contains() {
  local wanted="$1"
  shift
  local item
  for item in "$@"; do
    [[ "$item" == "$wanted" ]] && return 0
  done
  return 1
}

validate_component_id() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || die "Invalid recovery component ID: $1"
}

register_restore_handler() {
  local name="$1"
  local command_path="$2"
  local index
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "Invalid restore handler name: $name"
  [[ "$command_path" == /* ]] || die "Restore handler must be absolute: $command_path"
  [[ -x "$command_path" ]] || die "Restore handler is not executable: $command_path"
  for index in "${!RESTORE_HANDLER_NAMES[@]}"; do
    [[ "${RESTORE_HANDLER_NAMES[$index]}" != "$name" ]] \
      || die "Duplicate restore handler: $name"
  done
  RESTORE_HANDLER_NAMES+=("$name")
  RESTORE_HANDLER_COMMANDS+=("$command_path")
}

parse_restore_handlers() {
  local line
  local name
  local command_path
  local extra
  local builtin
  local -a builtin_names=(
    docker-recovery
    credentials-recovery
    codex-mcp-recovery
    browser-recovery
    github-recovery
    server-recovery
  )

  RESTORE_HANDLER_NAMES=()
  RESTORE_HANDLER_COMMANDS=()
  if [[ -f "$HANDLERS_FILE" ]]; then
    HANDLERS_FILE="$(canonicalize_path "$HANDLERS_FILE")"
    while IFS= read -r line || [[ -n "$line" ]]; do
      line="$(normalize_config_line "$line")"
      [[ -n "$line" ]] || continue
      IFS='|' read -r name command_path extra <<<"$line"
      name="$(trim_whitespace "${name:-}")"
      command_path="$(trim_whitespace "${command_path:-}")"
      [[ -z "${extra:-}" && -n "$name" && -n "$command_path" ]] \
        || die "Invalid restore handler entry: $line"
      register_restore_handler "$name" "$(canonicalize_path "$command_path")"
    done <"$HANDLERS_FILE"
  elif [[ "$HANDLERS_FILE" != "$DEFAULT_HANDLERS_FILE" ]]; then
    die "Restore handler file not found: $HANDLERS_FILE"
  fi

  for name in "${builtin_names[@]}"; do
    array_contains "$name" "${RESTORE_HANDLER_NAMES[@]}" && continue
    builtin="$SCRIPT_DIR/restore-handlers/$name"
    [[ -x "$builtin" ]] && register_restore_handler "$name" "$builtin"
  done
}

restore_handler_command() {
  local wanted="$1"
  local index
  for index in "${!RESTORE_HANDLER_NAMES[@]}"; do
    if [[ "${RESTORE_HANDLER_NAMES[$index]}" == "$wanted" ]]; then
      printf '%s\n' "${RESTORE_HANDLER_COMMANDS[$index]}"
      return 0
    fi
  done
  return 1
}

reset_recovery_components() {
  COMPONENT_IDS=()
  COMPONENT_LABELS=()
  COMPONENT_KINDS=()
  COMPONENT_CAPABILITIES=()
  COMPONENT_RISKS=()
  COMPONENT_RECOMMENDED=()
  COMPONENT_HANDLERS=()
  COMPONENT_SOURCE_PATHS=()
  COMPONENT_DEPENDENCIES=()
  COMPONENT_INDEX=()
}

add_recovery_component() {
  local id="$1"
  local label="$2"
  local kind="$3"
  local capability="$4"
  local risk="$5"
  local recommended="$6"
  local handler="${7:-}"
  local source_path="${8:-}"
  local dependencies="${9:-}"
  local index

  validate_component_id "$id"
  [[ -z "${COMPONENT_INDEX[$id]+x}" ]] || die "Duplicate recovery component ID: $id"
  case "$capability" in automatic|guided|files-only) ;; *) die "Invalid component capability: $capability" ;; esac
  case "$risk" in safe|privileged|destructive|manual) ;; *) die "Invalid component risk: $risk" ;; esac
  case "$recommended" in recommended|optional) ;; *) die "Invalid component recommendation: $recommended" ;; esac
  reject_control_characters "$label" "Component label"
  [[ -z "$source_path" || "$source_path" == /* ]] || die "Component source path must be absolute: $source_path"

  index="${#COMPONENT_IDS[@]}"
  COMPONENT_INDEX["$id"]="$index"
  COMPONENT_IDS+=("$id")
  COMPONENT_LABELS+=("$label")
  COMPONENT_KINDS+=("$kind")
  COMPONENT_CAPABILITIES+=("$capability")
  COMPONENT_RISKS+=("$risk")
  COMPONENT_RECOMMENDED+=("$recommended")
  COMPONENT_HANDLERS+=("$handler")
  COMPONENT_SOURCE_PATHS+=("${source_path%/}")
  COMPONENT_DEPENDENCIES+=("$dependencies")
}

set_component_source_path() {
  local id="$1"
  local path="$2"
  local index="${COMPONENT_INDEX[$id]:-}"
  [[ -n "$index" ]] || die "Handler referenced an unknown component: $id"
  [[ "$path" == /* ]] || die "Handler component path must be absolute: $path"
  COMPONENT_SOURCE_PATHS[index]="${path%/}"
}

add_component_dependency() {
  local id="$1"
  local dependency="$2"
  local index="${COMPONENT_INDEX[$id]:-}"
  [[ -n "$index" ]] || die "Handler referenced an unknown component: $id"
  validate_component_id "$dependency"
  if [[ -n "${COMPONENT_DEPENDENCIES[$index]}" ]]; then
    COMPONENT_DEPENDENCIES[index]+=",$dependency"
  else
    COMPONENT_DEPENDENCIES[index]="$dependency"
  fi
}

infer_source_home_from_snapshot() {
  local inferred=""
  if [[ -s "$RECOVERY_MANIFEST" ]]; then
    inferred="$(awk -F '\t' '$1 == "root" && $2 ~ /^\/home\/[A-Za-z0-9._-]+(\/|$)/ {split($2, p, "/"); print "/home/" p[3]; exit}' "$RECOVERY_MANIFEST")"
  elif [[ -d "$RECOVERY_SNAPSHOT_DIR/home" ]]; then
    inferred="$(find "$RECOVERY_SNAPSHOT_DIR/home" -mindepth 1 -maxdepth 1 -type d -printf '/home/%f\n' | sort | head -n 1)"
  fi
  printf '%s\n' "${inferred:-${HOME:-/home/unknown}}"
}

validate_path_mappings() {
  local mapping
  local source
  local target
  local -a normalized=()
  for mapping in "${PATH_MAPPINGS[@]}"; do
    [[ "$mapping" == *=* ]] || die "--map-path must be SOURCE=TARGET: $mapping"
    source="${mapping%%=*}"
    target="${mapping#*=}"
    [[ "$source" == /* && "$target" == /* ]] || die "Mapped paths must be absolute: $mapping"
    source="$(canonicalize_path "$source")"
    target="$(canonicalize_path "$target")"
    [[ "$source" != "/" && "$target" != "/" ]] || die "Mapping / is not allowed: $mapping"
    reject_control_characters "$source" "Mapped source"
    reject_control_characters "$target" "Mapped target"
    normalized+=("$source=$target")
  done
  PATH_MAPPINGS=("${normalized[@]}")
}

map_recovery_target_path() {
  local source_path="$1"
  local mapping
  local source
  local target
  for mapping in "${PATH_MAPPINGS[@]}"; do
    source="${mapping%%=*}"
    target="${mapping#*=}"
    if [[ "$source_path" == "$source" ]]; then
      printf '%s\n' "$target"
      return 0
    fi
    if [[ "$source_path" == "$source"/* ]]; then
      printf '%s\n' "$target/${source_path#"$source"/}"
      return 0
    fi
  done
  if [[ "$source_path" == "$RECOVERY_SOURCE_HOME" ]]; then
    printf '%s\n' "$TARGET_HOME"
  elif [[ "$source_path" == "$RECOVERY_SOURCE_HOME"/* ]]; then
    printf '%s\n' "$TARGET_HOME/${source_path#"$RECOVERY_SOURCE_HOME"/}"
  fi
}

load_recovery_snapshot_context() {
  local snapshot
  local passwd_entry=""
  local owner_path
  local source_owner=""
  local failed_log

  snapshot="$(resolve_snapshot_name)"
  RECOVERY_SNAPSHOT_DIR="$(snapshot_path_for "$snapshot")"
  [[ -d "$RECOVERY_SNAPSHOT_DIR" ]] || die "Snapshot not found: $RECOVERY_SNAPSHOT_DIR"
  SNAPSHOT_NAME="$snapshot"
  RECOVERY_MANIFEST="$RECOVERY_SNAPSHOT_DIR/.backup-home/manifest.tsv"
  RECOVERY_BLOCKERS=()
  RECOVERY_WARNINGS=()

  if [[ -s "$RECOVERY_MANIFEST" ]]; then
    RECOVERY_SCHEMA="$(manifest_value "$RECOVERY_MANIFEST" schema_version)"
  else
    RECOVERY_SCHEMA="legacy"
  fi

  RECOVERY_SOURCE_HOME="$(manifest_value "$RECOVERY_MANIFEST" source_home 2>/dev/null || true)"
  [[ -n "$RECOVERY_SOURCE_HOME" ]] || RECOVERY_SOURCE_HOME="$(infer_source_home_from_snapshot)"
  RECOVERY_SOURCE_USER="$(manifest_value "$RECOVERY_MANIFEST" source_user 2>/dev/null || true)"
  [[ -n "$RECOVERY_SOURCE_USER" ]] || RECOVERY_SOURCE_USER="$(basename "$RECOVERY_SOURCE_HOME")"
  RECOVERY_SOURCE_UID="$(manifest_value "$RECOVERY_MANIFEST" source_uid 2>/dev/null || true)"
  RECOVERY_SOURCE_GID="$(manifest_value "$RECOVERY_MANIFEST" source_gid 2>/dev/null || true)"
  owner_path="$RECOVERY_SNAPSHOT_DIR$RECOVERY_SOURCE_HOME"
  if [[ -e "$owner_path" ]]; then
    source_owner="$(stat -c '%u:%g' "$owner_path" 2>/dev/null || true)"
  fi
  [[ -n "$RECOVERY_SOURCE_UID" ]] || RECOVERY_SOURCE_UID="${source_owner%%:*}"
  [[ -n "$RECOVERY_SOURCE_GID" ]] || RECOVERY_SOURCE_GID="${source_owner#*:}"
  [[ "$RECOVERY_SCHEMA" == "2" ]] \
    || RECOVERY_WARNINGS+=("Source identity was inferred because the snapshot has no manifest v2 identity fields")

  [[ -n "$TARGET_USER" ]] || TARGET_USER="$(id -un)"
  passwd_entry="$(getent passwd "$TARGET_USER" || true)"
  if [[ -n "$passwd_entry" ]]; then
    IFS=':' read -r _ _ RECOVERY_TARGET_UID RECOVERY_TARGET_GID _ passwd_home _ <<<"$passwd_entry"
    [[ -n "$TARGET_HOME" ]] || TARGET_HOME="$passwd_home"
  else
    RECOVERY_TARGET_UID=""
    RECOVERY_TARGET_GID=""
    RECOVERY_BLOCKERS+=("Target user does not exist: $TARGET_USER")
    [[ -n "$TARGET_HOME" ]] || TARGET_HOME="/home/$TARGET_USER"
  fi
  [[ "$TARGET_HOME" == /* ]] || die "Target home must be absolute: $TARGET_HOME"
  TARGET_HOME="$(canonicalize_path "$TARGET_HOME")"
  [[ "$TARGET_HOME" != "/" ]] || die "Target home / is not allowed"

  validate_path_mappings
  if [[ -z "$STAGING_DIR" ]]; then
    STAGING_DIR="$TARGET_HOME/.backup-home-restore/${RECOVERY_SESSION_ID:-plan-$SNAPSHOT_NAME}"
  fi
  [[ "$STAGING_DIR" == /* ]] || die "Staging directory must be absolute: $STAGING_DIR"
  STAGING_DIR="$(canonicalize_path "$STAGING_DIR")"
  [[ "$STAGING_DIR" != "/" && "$STAGING_DIR" != "$TARGET_HOME" ]] \
    || die "Unsafe staging directory: $STAGING_DIR"
  case "$STAGING_DIR" in
    "$DEST_ROOT_REAL"|"$DEST_ROOT_REAL"/*) die "Staging directory must not be inside the backup destination" ;;
  esac

  if [[ "$RECOVERY_SCHEMA" == "legacy" ]]; then
    RECOVERY_WARNINGS+=("Legacy snapshot has no manifest or recorded artifact checksums")
    while IFS= read -r failed_log; do
      if grep -q '^status=failed$' "$failed_log" 2>/dev/null; then
        RECOVERY_BLOCKERS+=("A matching failed backup log exists: $failed_log")
      fi
    done < <(find "$(logs_root_dir)" -maxdepth 1 -type f \
      \( -name "backup-home-$SNAPSHOT_NAME.log" -o -name "backup-home-$SNAPSHOT_NAME.failure.tsv" \) \
      -print 2>/dev/null || true)
    [[ "$ALLOW_LEGACY" -eq 1 ]] || RECOVERY_BLOCKERS+=("Guided recovery of a legacy snapshot requires --allow-legacy")
  fi
}

validate_recovery_snapshot() {
  local key
  local value
  local rest
  local name
  local mode
  local status
  local expected_count
  local actual_count
  local sensitive_profile
  local encryption_state

  [[ "$RECOVERY_SCHEMA" != "legacy" ]] || return 0
  case "$RECOVERY_SCHEMA" in
    1|2) ;;
    *) RECOVERY_BLOCKERS+=("Unsupported manifest schema: $RECOVERY_SCHEMA"); return 0 ;;
  esac
  [[ "$(manifest_value "$RECOVERY_MANIFEST" snapshot)" == "$SNAPSHOT_NAME" ]] \
    || RECOVERY_BLOCKERS+=("Manifest snapshot name does not match the selected directory")
  status="$(manifest_value "$RECOVERY_MANIFEST" status)"
  [[ "$status" == success* ]] || RECOVERY_BLOCKERS+=("Snapshot status is not successful: $status")
  [[ "$status" != "success-with-warnings" ]] \
    || RECOVERY_WARNINGS+=("The snapshot completed with collector or backup warnings")
  sensitive_profile="$(manifest_value "$RECOVERY_MANIFEST" sensitive_profile)"
  encryption_state="$(manifest_value "$RECOVERY_MANIFEST" destination_encryption_state)"
  if [[ -z "$sensitive_profile" ]]; then
    RECOVERY_WARNINGS+=("Snapshot predates recorded sensitive-profile and destination-encryption fields")
  elif [[ "$sensitive_profile" == "yes" && "$encryption_state" != "detected" ]]; then
    RECOVERY_WARNINGS+=("Snapshot contains sensitive data and destination encryption was not detected (state=${encryption_state:-unknown})")
  fi

  while IFS=$'\t' read -r key value rest; do
    case "$key" in
      root)
        [[ -e "$RECOVERY_SNAPSHOT_DIR$value" || -L "$RECOVERY_SNAPSHOT_DIR$value" ]] \
          || RECOVERY_BLOCKERS+=("Snapshot root is missing: $value")
        ;;
      collector)
        name="$value"
        mode="${rest%%$'\t'*}"
        rest="${rest#*$'\t'}"
        status="${rest%%$'\t'*}"
        if [[ "$mode" == "required" && "$status" != "success" && "$status" != "warning" ]]; then
          RECOVERY_BLOCKERS+=("Required collector is not usable: $name ($status)")
        fi
        [[ -d "$RECOVERY_SNAPSHOT_DIR/.backup-home/artifacts/collectors/$name" ]] \
          || RECOVERY_BLOCKERS+=("Collector artifacts are missing: $name")
        ;;
      warning)
        RECOVERY_WARNINGS+=("Snapshot warning: $value")
        ;;
    esac
  done <"$RECOVERY_MANIFEST"

  expected_count="$(manifest_value "$RECOVERY_MANIFEST" file_count)"
  actual_count="$(find "$RECOVERY_SNAPSHOT_DIR" -type f | wc -l | awk '{print $1}')"
  [[ "$expected_count" == "$actual_count" ]] \
    || RECOVERY_BLOCKERS+=("Snapshot file count mismatch: expected=$expected_count actual=$actual_count")

  if [[ "$SKIP_DEEP_VERIFY" -eq 1 ]]; then
    RECOVERY_WARNINGS+=("Deep verification was skipped by request")
  elif [[ ! -s "$RECOVERY_SNAPSHOT_DIR/.backup-home/checksums.sha256" ]]; then
    RECOVERY_BLOCKERS+=("Recorded checksum set is missing")
  elif ! (cd "$RECOVERY_SNAPSHOT_DIR" && sha256sum -c --strict --quiet .backup-home/checksums.sha256); then
    RECOVERY_BLOCKERS+=("Recorded artifact or payload checksum verification failed")
  fi
}

invoke_restore_handler() {
  local handler="$1"
  local action="$2"
  local component="${3:-}"
  local command_path
  local destructive_approved=0
  command_path="$(restore_handler_command "$handler")" || return 127
  if [[ -n "$component" ]] && array_contains "$component" "${APPROVED_DESTRUCTIVE[@]}"; then
    destructive_approved=1
  fi
  BACKUP_HOME_RESTORE_ACTION="$action" \
  BACKUP_HOME_SNAPSHOT_DIR="$RECOVERY_SNAPSHOT_DIR" \
  BACKUP_HOME_ARTIFACT_DIR="$RECOVERY_SNAPSHOT_DIR/.backup-home/artifacts/collectors/$handler" \
  BACKUP_HOME_RESTORE_STAGING_DIR="$STAGING_DIR" \
  BACKUP_HOME_RESTORE_SESSION_DIR="$RECOVERY_SESSION_DIR" \
  BACKUP_HOME_SOURCE_HOME="$RECOVERY_SOURCE_HOME" \
  BACKUP_HOME_TARGET_USER="$TARGET_USER" \
  BACKUP_HOME_TARGET_UID="$RECOVERY_TARGET_UID" \
  BACKUP_HOME_TARGET_GID="$RECOVERY_TARGET_GID" \
  BACKUP_HOME_TARGET_HOME="$TARGET_HOME" \
  BACKUP_HOME_RESTORE_DRY_RUN="$DRY_RUN" \
  BACKUP_HOME_RESTORE_ASSUME_YES="$ASSUME_YES" \
  BACKUP_HOME_DESTRUCTIVE_APPROVED="$destructive_approved" \
    "$command_path" "$action" ${component:+"$component"}
}

discover_handler_components() {
  local handler="$1"
  local output
  local rc
  local record
  local id
  local label
  local capability
  local risk
  local recommended
  local extra
  local before_count="${#COMPONENT_IDS[@]}"

  if output="$(invoke_restore_handler "$handler" describe)"; then
    rc=0
  else
    rc=$?
  fi
  if [[ "$rc" -ne 0 ]]; then
    RECOVERY_WARNINGS+=("Restore handler describe failed: $handler (rc=$rc)")
    return 1
  fi
  while IFS=$'\t' read -r record id label capability risk recommended extra; do
    [[ -n "$record" ]] || continue
    case "$record" in
      component)
        [[ -z "${extra:-}" && -n "$id" && -n "$label" && -n "$capability" && -n "$risk" && -n "$recommended" ]] \
          || die "Invalid component record from handler $handler"
        add_recovery_component "$id" "$label" handler "$capability" "$risk" "$recommended" "$handler"
        ;;
      path)
        [[ -n "$id" && -n "$label" && -z "${capability:-}${risk:-}${recommended:-}${extra:-}" ]] \
          || die "Invalid path record from handler $handler"
        set_component_source_path "$id" "$label"
        ;;
      dependency)
        [[ -n "$id" && -n "$label" && -z "${capability:-}${risk:-}${recommended:-}${extra:-}" ]] \
          || die "Invalid dependency record from handler $handler"
        add_component_dependency "$id" "$label"
        ;;
      *) die "Unknown record from restore handler $handler: $record" ;;
    esac
  done <<<"$output"
  [[ "${#COMPONENT_IDS[@]}" -gt "$before_count" ]]
}

discover_recovery_components() {
  local root
  local collector
  local handler
  local id
  local index=0
  local -a collectors=()

  reset_recovery_components
  if [[ "$RECOVERY_SCHEMA" == "legacy" ]]; then
    root="$RECOVERY_SOURCE_HOME"
    if [[ -e "$RECOVERY_SNAPSHOT_DIR$root" || -L "$RECOVERY_SNAPSHOT_DIR$root" ]]; then
      add_recovery_component "files.1" "$root" filesystem automatic safe recommended "" "$root"
    else
      RECOVERY_BLOCKERS+=("Could not infer a restorable home root from the legacy snapshot")
    fi
    return 0
  fi

  while IFS= read -r root; do
    [[ -n "$root" ]] || continue
    index=$((index + 1))
    add_recovery_component "files.$index" "$root" filesystem automatic safe recommended "" "$root"
  done < <(awk -F '\t' '$1 == "root" {print $2}' "$RECOVERY_MANIFEST")

  mapfile -t collectors < <(awk -F '\t' '$1 == "collector" {print $2}' "$RECOVERY_MANIFEST")
  for collector in "${collectors[@]}"; do
    if [[ "$collector" == "system-inventory" ]]; then
      add_recovery_component "system.inventory" "System inventory and rebuild guidance" \
        system-inventory guided manual recommended "$collector"
      continue
    fi
    handler="$(restore_handler_command "$collector" || true)"
    if [[ -n "$handler" ]] && discover_handler_components "$collector"; then
      continue
    fi
    id="collector.$(sanitize_name "$collector").artifacts"
    add_recovery_component "$id" "$collector recovery artifacts" fallback files-only manual optional "$collector"
  done
}

preflight_recovery_components() {
  local index
  local id
  local kind
  local handler
  local source_path
  local target_path
  local output
  local rc
  local level
  local message
  local extra

  RECOVERY_PREFLIGHT_LINES=()
  for index in "${!COMPONENT_IDS[@]}"; do
    id="${COMPONENT_IDS[$index]}"
    kind="${COMPONENT_KINDS[$index]}"
    handler="${COMPONENT_HANDLERS[$index]}"
    source_path="${COMPONENT_SOURCE_PATHS[$index]}"
    if [[ -n "$source_path" ]]; then
      if [[ ! -e "$RECOVERY_SNAPSHOT_DIR$source_path" && ! -L "$RECOVERY_SNAPSHOT_DIR$source_path" ]]; then
        RECOVERY_BLOCKERS+=("Component $id source is missing: $source_path")
      else
        target_path="$(map_recovery_target_path "$source_path")"
        if [[ -z "$target_path" ]]; then
          RECOVERY_WARNINGS+=("Component $id has no final path mapping and will remain in staging")
        elif [[ -e "$target_path" || -L "$target_path" ]]; then
          RECOVERY_WARNINGS+=("Component $id has an existing target that requires conflict review: $target_path")
        fi
      fi
    fi
    [[ "$kind" == "handler" ]] || continue
    if output="$(invoke_restore_handler "$handler" preflight "$id")"; then
      rc=0
    else
      rc=$?
    fi
    if [[ "$rc" -ne 0 ]]; then
      RECOVERY_BLOCKERS+=("Handler preflight failed for $id (rc=$rc)")
      continue
    fi
    while IFS=$'\t' read -r level message extra; do
      [[ -n "$level" ]] || continue
      case "$level" in
        ok) RECOVERY_PREFLIGHT_LINES+=("$id|OK|$message") ;;
        warning) RECOVERY_WARNINGS+=("$id: $message") ;;
        blocker) RECOVERY_BLOCKERS+=("$id: $message") ;;
        risk)
          case "$message" in safe|privileged|destructive|manual) COMPONENT_RISKS[index]="$message" ;; *) die "Invalid dynamic risk from handler $handler: $message" ;; esac
          ;;
        *) die "Invalid preflight record from handler $handler: $level" ;;
      esac
      [[ -z "${extra:-}" ]] || die "Invalid preflight record from handler $handler"
    done <<<"$output"
  done
}

existing_ancestor() {
  local path="$1"
  while [[ ! -e "$path" && "$path" != "/" ]]; do path="$(dirname "$path")"; done
  printf '%s\n' "$path"
}

print_recovery_plan() {
  local index
  local entry
  local payload_bytes="unknown"
  local free_bytes
  local stage_anchor
  local sensitive_profile="not-recorded"
  local encryption_state="not-recorded"
  local encryption_policy="not-recorded"

  [[ "$RECOVERY_SCHEMA" == "legacy" ]] \
    || payload_bytes="$(manifest_value "$RECOVERY_MANIFEST" payload_bytes)"
  if [[ "$RECOVERY_SCHEMA" != "legacy" ]]; then
    sensitive_profile="$(manifest_value "$RECOVERY_MANIFEST" sensitive_profile)"
    encryption_state="$(manifest_value "$RECOVERY_MANIFEST" destination_encryption_state)"
    encryption_policy="$(manifest_value "$RECOVERY_MANIFEST" unencrypted_destination_policy)"
    [[ -n "$sensitive_profile" ]] || sensitive_profile="not-recorded"
    [[ -n "$encryption_state" ]] || encryption_state="not-recorded"
    [[ -n "$encryption_policy" ]] || encryption_policy="not-recorded"
  fi
  stage_anchor="$(existing_ancestor "$STAGING_DIR")"
  free_bytes="$(df -B1 --output=avail "$stage_anchor" | awk 'NR==2 {print $1}')"

  print_heading "Recovery plan"
  print_label_value "Snapshot:" "$SNAPSHOT_NAME"
  print_label_value "Manifest schema:" "$RECOVERY_SCHEMA"
  print_label_value "Sensitive profile:" "$sensitive_profile"
  print_label_value "Backup destination encryption:" "$encryption_state ($encryption_policy policy)"
  print_label_value "Source identity:" "$RECOVERY_SOURCE_USER uid=$RECOVERY_SOURCE_UID gid=$RECOVERY_SOURCE_GID home=$RECOVERY_SOURCE_HOME"
  print_label_value "Target identity:" "$TARGET_USER uid=${RECOVERY_TARGET_UID:-missing} gid=${RECOVERY_TARGET_GID:-missing} home=$TARGET_HOME"
  print_label_value "Staging directory:" "$STAGING_DIR"
  if [[ "$payload_bytes" == "unknown" ]]; then
    print_label_value "Snapshot payload:" "unknown (legacy)"
  else
    print_label_value "Snapshot payload:" "$(format_bytes_human "$payload_bytes")"
  fi
  print_label_value "Available staging space:" "$(format_bytes_human "$free_bytes")"

  printf '\nComponents:\n'
  for index in "${!COMPONENT_IDS[@]}"; do
    printf '  - %s | %s | %s | %s | %s\n' \
      "${COMPONENT_IDS[$index]}" "${COMPONENT_CAPABILITIES[$index]}" \
      "${COMPONENT_RISKS[$index]}" "${COMPONENT_RECOMMENDED[$index]}" \
      "${COMPONENT_LABELS[$index]}"
  done

  printf '\nPreflight:\n'
  if [[ "${#RECOVERY_PREFLIGHT_LINES[@]}" -eq 0 ]]; then
    printf '  - no handler-specific checks\n'
  else
    for entry in "${RECOVERY_PREFLIGHT_LINES[@]}"; do
      IFS='|' read -r id level message <<<"$entry"
      printf '  - %s %s: %s\n' "$level" "$id" "$message"
    done
  fi

  printf '\nWarnings:\n'
  if [[ "${#RECOVERY_WARNINGS[@]}" -eq 0 ]]; then
    printf '  - none\n'
  else
    printf '  - %s\n' "${RECOVERY_WARNINGS[@]}"
  fi
  printf '\nBlockers:\n'
  if [[ "${#RECOVERY_BLOCKERS[@]}" -eq 0 ]]; then
    printf '  - none\n'
  else
    printf '  - %s\n' "${RECOVERY_BLOCKERS[@]}"
  fi
}

prepare_recovery_plan() {
  require_commands rsync find du df date mkdir readlink sort awk sed dirname cut tr \
    sha256sum flock hostname id getent stat grep
  ensure_dest_access "check"
  acquire_lock "shared"
  parse_restore_handlers
  load_recovery_snapshot_context
  validate_recovery_snapshot
  discover_recovery_components
  preflight_recovery_components
}

restore_plan() {
  prepare_recovery_plan
  print_recovery_plan
  if [[ "${#RECOVERY_BLOCKERS[@]}" -gt 0 ]]; then
    printf '\nRecovery plan is blocked by %s problem(s).\n' "${#RECOVERY_BLOCKERS[@]}"
    return 1
  fi
  printf '\nRecovery plan is ready. Run recover with the same target options.\n'
}

recovery_session_base() {
  printf '%s\n' "${XDG_STATE_HOME:-${HOME:-/tmp}/.local/state}/backup-home/recovery"
}

validate_session_id() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || die "Invalid recovery session ID: $1"
}

recovery_state_file() {
  printf '%s\n' "$RECOVERY_SESSION_DIR/state.tsv"
}

recovery_state_value() {
  local key="$1"
  awk -F '\t' -v wanted="$key" '$1 == wanted {print $2; exit}' "$(recovery_state_file)"
}

recovery_component_status() {
  local id="$1"
  awk -F '\t' -v wanted="$id" '$1 == "component" && $2 == wanted {status=$3} END {print status}' \
    "$(recovery_state_file)"
}

record_recovery_status() {
  local id="$1"
  local status="$2"
  local message="${3:-}"
  printf 'component\t%s\t%s\t%s\t%s\n' "$id" "$status" "$(iso_now)" \
    "$(manifest_escape "$message")" >>"$(recovery_state_file)"
}

load_recovery_session() {
  local base
  local state
  local recorded_dest
  local mapping

  validate_session_id "$RESUME_SESSION"
  base="$(recovery_session_base)"
  RECOVERY_SESSION_ID="$RESUME_SESSION"
  RECOVERY_SESSION_DIR="$base/$RECOVERY_SESSION_ID"
  state="$(recovery_state_file)"
  [[ -s "$state" ]] || die "Recovery session not found: $RECOVERY_SESSION_ID"
  [[ "$(recovery_state_value schema_version)" == "1" ]] || die "Unsupported recovery session schema"

  recorded_dest="$(recovery_state_value destination)"
  if [[ -n "$DEST_ROOT" ]]; then
    [[ "$(canonicalize_path "$DEST_ROOT")" == "$recorded_dest" ]] \
      || die "--dest does not match the recovery session destination"
  else
    DEST_ROOT="$recorded_dest"
  fi
  SNAPSHOT_NAME="$(recovery_state_value snapshot)"
  TARGET_USER="$(recovery_state_value target_user)"
  TARGET_HOME="$(recovery_state_value target_home)"
  STAGING_DIR="$(recovery_state_value staging_dir)"
  mapfile -t SELECTED_COMPONENTS < <(awk -F '\t' '$1 == "selected" {print $2}' "$state")
  PATH_MAPPINGS=()
  while IFS= read -r mapping; do [[ -n "$mapping" ]] && PATH_MAPPINGS+=("$mapping"); done \
    < <(awk -F '\t' '$1 == "mapping" {print $2}' "$state")
}

create_recovery_session() {
  local base
  local mapping
  local id

  base="$(recovery_session_base)"
  mkdir -p -- "$base"
  chmod 700 -- "$base"
  RECOVERY_SESSION_DIR="$base/$RECOVERY_SESSION_ID"
  [[ ! -e "$RECOVERY_SESSION_DIR" ]] || die "Recovery session already exists: $RECOVERY_SESSION_ID"
  mkdir -p -- "$RECOVERY_SESSION_DIR/logs" "$RECOVERY_SESSION_DIR/commands"
  chmod 700 -- "$RECOVERY_SESSION_DIR" "$RECOVERY_SESSION_DIR/logs" "$RECOVERY_SESSION_DIR/commands"
  {
    printf 'schema_version\t1\n'
    printf 'session\t%s\n' "$RECOVERY_SESSION_ID"
    printf 'created_at\t%s\n' "$(iso_now)"
    printf 'destination\t%s\n' "$DEST_ROOT_REAL"
    printf 'snapshot\t%s\n' "$SNAPSHOT_NAME"
    printf 'target_user\t%s\n' "$TARGET_USER"
    printf 'target_home\t%s\n' "$TARGET_HOME"
    printf 'staging_dir\t%s\n' "$STAGING_DIR"
    for mapping in "${PATH_MAPPINGS[@]}"; do printf 'mapping\t%s\n' "$mapping"; done
    for id in "${SELECTED_COMPONENTS[@]}"; do printf 'selected\t%s\n' "$id"; done
  } >"$(recovery_state_file)"
  chmod 600 -- "$(recovery_state_file)"
  : >"$RECOVERY_SESSION_DIR/manual-steps.md"
  chmod 600 -- "$RECOVERY_SESSION_DIR/manual-steps.md"
}

select_recovery_components() {
  local index
  local id
  local reply
  local -a selected=()

  if [[ "${#SELECTED_COMPONENTS[@]}" -gt 0 ]]; then
    for id in "${SELECTED_COMPONENTS[@]}"; do
      [[ -n "${COMPONENT_INDEX[$id]+x}" ]] || die "Unknown recovery component: $id"
      array_contains "$id" "${selected[@]}" || selected+=("$id")
    done
    SELECTED_COMPONENTS=("${selected[@]}")
    return 0
  fi
  if [[ "$RECOVERY_ALL" -eq 1 ]]; then
    SELECTED_COMPONENTS=("${COMPONENT_IDS[@]}")
    return 0
  fi
  [[ -t 0 ]] || die "Non-interactive recovery requires --component or --all"

  printf '\nSelect recovery components:\n'
  for index in "${!COMPONENT_IDS[@]}"; do
    id="${COMPONENT_IDS[$index]}"
    if [[ "${COMPONENT_RECOMMENDED[$index]}" == "recommended" ]]; then
      printf 'Restore %s (%s) [Y/n]: ' "${COMPONENT_LABELS[$index]}" "$id"
      read -r reply
      case "$reply" in n|N|no|NO) ;; *) selected+=("$id") ;; esac
    else
      printf 'Restore %s (%s) [y/N]: ' "${COMPONENT_LABELS[$index]}" "$id"
      read -r reply
      case "$reply" in y|Y|yes|YES) selected+=("$id") ;; esac
    fi
  done
  [[ "${#selected[@]}" -gt 0 ]] || die "No recovery components were selected"
  SELECTED_COMPONENTS=("${selected[@]}")
}

approve_recovery_component() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local risk="${COMPONENT_RISKS[$index]}"
  local reply

  if [[ "$risk" == "destructive" ]]; then
    if array_contains "$id" "${APPROVED_DESTRUCTIVE[@]}"; then return 0; fi
    [[ -t 0 ]] || return 1
    printf 'Destructive recovery for %s may replace existing state. Type the component ID to approve: ' "$id"
    read -r reply
    [[ "$reply" == "$id" ]] || return 1
    APPROVED_DESTRUCTIVE+=("$id")
    return 0
  fi
  [[ "$ASSUME_YES" -eq 0 ]] || return 0
  [[ -t 0 ]] || return 1
  printf 'Apply recovery component %s (%s) [y/N]: ' "${COMPONENT_LABELS[$index]}" "$id"
  read -r reply
  case "$reply" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

approve_existing_target_replace() {
  local id="$1"
  local target="$2"
  local reply
  if array_contains "$id" "${APPROVED_DESTRUCTIVE[@]}"; then return 0; fi
  [[ -t 0 ]] || return 1
  printf 'Target differs: %s. Type the component ID to preserve it and replace from backup: ' "$target"
  read -r reply
  [[ "$reply" == "$id" ]] || return 1
  APPROVED_DESTRUCTIVE+=("$id")
}

print_shell_command() {
  printf '  command:'
  printf ' %q' "$@"
  printf '\n'
}

run_target_command() {
  if [[ -n "$RECOVERY_TARGET_UID" && "$RECOVERY_TARGET_UID" != "$(id -u)" ]]; then
    require_commands sudo
    print_shell_command sudo "$@"
    sudo "$@"
  else
    print_shell_command "$@"
    "$@"
  fi
}

stage_recovery_component() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local source_path="${COMPONENT_SOURCE_PATHS[$index]}"
  local snapshot_source="$RECOVERY_SNAPSHOT_DIR$source_path"
  local stage_payload="$STAGING_DIR/payload"
  local staged_source="$stage_payload$source_path"
  local comparison
  local rc

  [[ -n "$source_path" ]] || return 0
  [[ -e "$snapshot_source" || -L "$snapshot_source" ]] || return 1
  mkdir -p -- "$stage_payload"
  rsync --archive --hard-links --relative "$RECOVERY_SNAPSHOT_DIR/./${source_path#/}" "$stage_payload/"
  if [[ -d "$snapshot_source" && ! -L "$snapshot_source" ]]; then
    if comparison="$(rsync --archive --hard-links --checksum --dry-run --itemize-changes \
      "$snapshot_source/" "$staged_source/")"; then rc=0; else rc=$?; fi
  else
    if comparison="$(rsync --archive --hard-links --checksum --dry-run --itemize-changes \
      "$snapshot_source" "$staged_source")"; then rc=0; else rc=$?; fi
  fi
  [[ "$rc" -eq 0 && -z "$comparison" ]] || return 1
  record_recovery_status "$id" staged "$staged_source"
}

target_differs_from_stage() {
  local staged_source="$1"
  local target="$2"
  local comparison
  local rc
  [[ -e "$target" || -L "$target" ]] || return 1
  if [[ -d "$staged_source" && ! -L "$staged_source" && -d "$target" && ! -L "$target" ]]; then
    if comparison="$(rsync --archive --hard-links --checksum --dry-run --itemize-changes \
      "$staged_source/" "$target/")"; then rc=0; else rc=$?; fi
  else
    if comparison="$(rsync --archive --hard-links --checksum --dry-run --itemize-changes \
      "$staged_source" "$target")"; then rc=0; else rc=$?; fi
  fi
  [[ "$rc" -eq 0 ]] || return 0
  [[ -n "$comparison" ]]
}

preserve_existing_target() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local target="$2"
  local safety_root="$RECOVERY_SESSION_DIR/pre-restore/$id"
  local current_uid
  local current_gid
  current_uid="$(id -u)"
  current_gid="$(id -g)"

  mkdir -p -- "$safety_root"
  if [[ -n "$RECOVERY_TARGET_UID" && "$RECOVERY_TARGET_UID" != "$current_uid" ]]; then
    require_commands sudo
    print_shell_command sudo rsync --archive --hard-links --relative "$target" "$safety_root/"
    sudo rsync --archive --hard-links --relative "$target" "$safety_root/"
    sudo chown -hR -- "$current_uid:$current_gid" "$safety_root"
  else
    rsync --archive --hard-links --relative "$target" "$safety_root/"
  fi
  [[ -e "$safety_root$target" || -L "$safety_root$target" ]] \
    || die "Could not preserve existing target for $id"
}

verify_merged_component() {
  local staged_source="$1"
  local target="$2"
  local comparison
  local rc
  if [[ -d "$staged_source" && ! -L "$staged_source" ]]; then
    if comparison="$(rsync --archive --hard-links --checksum --dry-run --itemize-changes \
      "$staged_source/" "$target/")"; then rc=0; else rc=$?; fi
  else
    if comparison="$(rsync --archive --hard-links --checksum --dry-run --itemize-changes \
      "$staged_source" "$target")"; then rc=0; else rc=$?; fi
  fi
  [[ "$rc" -eq 0 && -z "$comparison" ]]
}

merge_staged_component() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local source_path="${COMPONENT_SOURCE_PATHS[$index]}"
  local staged_source="$STAGING_DIR/payload$source_path"
  local target

  target="$(map_recovery_target_path "$source_path")"
  if [[ -z "$target" ]]; then
    printf 'No final mapping for %s; staged at %s\n' "$source_path" "$staged_source"
    return 20
  fi
  if [[ -e "$target" || -L "$target" ]]; then
    if ! target_differs_from_stage "$staged_source" "$target"; then
      printf 'Target is already identical: %s\n' "$target"
      return 0
    fi
    if ! approve_existing_target_replace "$id" "$target"; then
      printf 'Conflict left for manual review: %s\n' "$target"
      return 20
    fi
    preserve_existing_target "$index" "$target"
  fi

  if [[ -d "$staged_source" && ! -L "$staged_source" ]]; then
    run_target_command mkdir -p -- "$target"
    run_target_command rsync --archive --hard-links "$staged_source/" "$target/"
  else
    run_target_command mkdir -p -- "$(dirname "$target")"
    run_target_command rsync --archive --hard-links "$staged_source" "$target"
  fi
  if [[ -n "$RECOVERY_TARGET_UID" && "$RECOVERY_TARGET_UID" != "$(id -u)" ]]; then
    require_commands sudo
    print_shell_command sudo chown -hR -- "$RECOVERY_TARGET_UID:$RECOVERY_TARGET_GID" "$target"
    sudo chown -hR -- "$RECOVERY_TARGET_UID:$RECOVERY_TARGET_GID" "$target"
  fi
  verify_merged_component "$staged_source" "$target"
}

recover_filesystem_component() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local rc
  if ! approve_recovery_component "$index"; then
    record_recovery_status "$id" skipped "User did not approve the component"
    return 0
  fi
  if ! stage_recovery_component "$index"; then
    record_recovery_status "$id" failed "Staging or staging verification failed"
    return 1
  fi
  if merge_staged_component "$index"; then rc=0; else rc=$?; fi
  case "$rc" in
    0) record_recovery_status "$id" verified "Filesystem merge verified" ;;
    20) record_recovery_status "$id" manual-pending "Staged data requires mapping or conflict resolution" ;;
    *) record_recovery_status "$id" failed "Filesystem merge or verification failed"; return "$rc" ;;
  esac
}

append_handler_guide() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local handler="${COMPONENT_HANDLERS[$index]}"
  local guide
  guide="$(invoke_restore_handler "$handler" guide "$id" || true)"
  [[ -n "$guide" ]] || return 0
  {
    printf '\n## %s\n\n' "${COMPONENT_LABELS[$index]}"
    printf '%s\n' "$guide"
  } >>"$RECOVERY_SESSION_DIR/manual-steps.md"
  printf '%s\n' "$guide"
}

recover_handler_component() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local handler="${COMPONENT_HANDLERS[$index]}"
  local source_path="${COMPONENT_SOURCE_PATHS[$index]}"
  local log_file="$RECOVERY_SESSION_DIR/logs/$id.log"
  local rc

  if ! approve_recovery_component "$index"; then
    append_handler_guide "$index"
    record_recovery_status "$id" manual-pending "Handler execution was not approved"
    return 0
  fi
  if [[ -n "$source_path" ]]; then
    if ! stage_recovery_component "$index"; then
      record_recovery_status "$id" failed "Handler source staging failed"
      return 1
    fi
    if merge_staged_component "$index"; then rc=0; else rc=$?; fi
    if [[ "$rc" -ne 0 ]]; then
      append_handler_guide "$index"
      if [[ "$rc" -eq 20 ]]; then
        record_recovery_status "$id" manual-pending "Handler source needs manual merge"
        return 0
      fi
      record_recovery_status "$id" failed "Handler source merge failed"
      return "$rc"
    fi
  fi

  if invoke_restore_handler "$handler" apply "$id" 2>&1 | tee -a "$log_file"; then
    rc=0
  else
    rc="${PIPESTATUS[0]}"
  fi
  if [[ "$rc" -eq 20 ]]; then
    append_handler_guide "$index"
    record_recovery_status "$id" manual-pending "Handler prepared guided manual steps"
    return 0
  fi
  if [[ "$rc" -ne 0 ]]; then
    append_handler_guide "$index"
    record_recovery_status "$id" failed "Handler apply failed with rc=$rc"
    return "$rc"
  fi

  if invoke_restore_handler "$handler" verify "$id" 2>&1 | tee -a "$log_file"; then
    rc=0
  else
    rc="${PIPESTATUS[0]}"
  fi
  if [[ "$rc" -eq 0 ]]; then
    record_recovery_status "$id" verified "Handler verification succeeded"
  elif [[ "$rc" -eq 20 ]]; then
    append_handler_guide "$index"
    record_recovery_status "$id" manual-pending "Handler verification requires manual work"
  else
    append_handler_guide "$index"
    record_recovery_status "$id" failed "Handler verification failed with rc=$rc"
    return "$rc"
  fi
}

stage_collector_artifacts() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local collector="${COMPONENT_HANDLERS[$index]}"
  local artifact_dir="$RECOVERY_SNAPSHOT_DIR/.backup-home/artifacts/collectors/$collector"
  local target="$STAGING_DIR/artifacts/$collector"
  [[ -d "$artifact_dir" ]] || return 1
  mkdir -p -- "$target"
  rsync --archive --hard-links "$artifact_dir/" "$target/"
  {
    printf '\n## %s\n\n' "${COMPONENT_LABELS[$index]}"
    printf 'Artifacts were staged at %s.\n' "\`$target\`"
    if [[ -s "$target/RESTORE.md" ]]; then
      printf '\n'
      sed -n '1,240p' "$target/RESTORE.md"
      printf '\n'
    fi
  } >>"$RECOVERY_SESSION_DIR/manual-steps.md"
  if [[ -s "$target/RESTORE.md" ]]; then
    sed -n '1,240p' "$target/RESTORE.md"
  fi
  record_recovery_status "$id" manual-pending "Collector artifacts staged for manual recovery"
}

recover_system_inventory() {
  local index="$1"
  local id="${COMPONENT_IDS[$index]}"
  local artifact_dir="$RECOVERY_SNAPSHOT_DIR/.backup-home/artifacts/collectors/system-inventory"
  local target="$STAGING_DIR/artifacts/system-inventory"
  local missing_apt="$RECOVERY_SESSION_DIR/commands/apt-missing.txt"

  if ! approve_recovery_component "$index"; then
    record_recovery_status "$id" skipped "System inventory guidance was not selected"
    return 0
  fi
  [[ -d "$artifact_dir" ]] || { record_recovery_status "$id" failed "System inventory artifacts are missing"; return 1; }
  mkdir -p -- "$target"
  rsync --archive "$artifact_dir/" "$target/"
  if [[ -s "$target/apt-manual.txt" ]] && command -v apt-mark >/dev/null 2>&1; then
    comm -23 <(sort -u "$target/apt-manual.txt") <(apt-mark showmanual 2>/dev/null | sort -u) >"$missing_apt"
  else
    : >"$missing_apt"
  fi
  chmod 600 -- "$missing_apt"
  {
    printf '\n## System inventory\n\n'
    printf 'Inventory artifacts were staged at %s.\n\n' "\`$target\`"
    printf 'Review %s before installing packages. Package installation, dconf import, and crontab import are intentionally not automatic.\n\n' "\`$missing_apt\`"
    printf 'Suggested commands after review:\n\n```bash\n'
    printf 'xargs -r sudo apt install -- < %q\n' "$missing_apt"
    [[ -s "$target/dconf.ini" ]] && printf 'dconf dump / > current-dconf.ini\ndconf load / < %q\n' "$target/dconf.ini"
    [[ -s "$target/crontab.txt" ]] && printf 'crontab -l > current-crontab.txt\ncrontab %q\n' "$target/crontab.txt"
    printf '```\n'
  } >>"$RECOVERY_SESSION_DIR/manual-steps.md"
  record_recovery_status "$id" manual-pending "System rebuild commands require review"
}

component_dependencies_ready() {
  local index="$1"
  local dependencies="${COMPONENT_DEPENDENCIES[$index]}"
  local dependency
  local status
  local -a dependency_list=()
  [[ -n "$dependencies" ]] || return 0
  IFS=',' read -ra dependency_list <<<"$dependencies"
  for dependency in "${dependency_list[@]}"; do
    status="$(recovery_component_status "$dependency")"
    [[ "$status" == "verified" ]] || return 1
  done
}

print_recovery_session_summary() {
  local id
  local status
  printf '\nRecovery session summary (%s):\n' "$RECOVERY_SESSION_ID"
  for id in "${SELECTED_COMPONENTS[@]}"; do
    status="$(recovery_component_status "$id")"
    printf '  - %s: %s\n' "$id" "${status:-not-started}"
  done
  print_label_value "Session state:" "$(recovery_state_file)"
  print_label_value "Manual steps:" "$RECOVERY_SESSION_DIR/manual-steps.md"
  print_label_value "Staging directory:" "$STAGING_DIR"
}

execute_recovery_component() {
  local kind="$1"
  local index="$2"
  case "$kind" in
    filesystem) recover_filesystem_component "$index" ;;
    handler) recover_handler_component "$index" ;;
    system-inventory) recover_system_inventory "$index" ;;
    fallback) stage_collector_artifacts "$index" ;;
    *) printf 'Unknown component kind: %s\n' "$kind" >&2; return 1 ;;
  esac
}

recover_snapshot() {
  local id
  local index
  local kind
  local status
  local rc=0

  if [[ "$DRY_RUN" -eq 1 ]]; then
    restore_plan
    return
  fi
  if [[ -n "$RESUME_SESSION" ]]; then
    [[ "$RECOVERY_ALL" -eq 0 && "${#SELECTED_COMPONENTS[@]}" -eq 0 ]] \
      || die "--resume cannot be combined with --all or --component"
    load_recovery_session
    ensure_safe_destination
    prepare_recovery_plan
  else
    RECOVERY_SESSION_ID=""
    prepare_recovery_plan
    if [[ "${#RECOVERY_BLOCKERS[@]}" -gt 0 ]]; then
      print_recovery_plan
      die "Recovery is blocked by ${#RECOVERY_BLOCKERS[@]} problem(s)"
    fi
    RECOVERY_SESSION_ID="$SNAPSHOT_NAME-$(timestamp_now)-$$"
    STAGING_DIR="${STAGING_DIR/plan-$SNAPSHOT_NAME/$RECOVERY_SESSION_ID}"
    select_recovery_components
    create_recovery_session
    print_recovery_plan | tee "$RECOVERY_SESSION_DIR/plan.txt"
    chmod 600 -- "$RECOVERY_SESSION_DIR/plan.txt"
  fi

  if [[ "${#RECOVERY_BLOCKERS[@]}" -gt 0 ]]; then
    print_recovery_plan
    die "Recovery is blocked by ${#RECOVERY_BLOCKERS[@]} problem(s)"
  fi
  mkdir -p -- "$STAGING_DIR"
  chmod 700 -- "$STAGING_DIR"

  for id in "${SELECTED_COMPONENTS[@]}"; do
    index="${COMPONENT_INDEX[$id]:-}"
    [[ -n "$index" ]] || die "Session references an unknown component: $id"
    status="$(recovery_component_status "$id")"
    case "$status" in verified|skipped) continue ;; esac
    if ! component_dependencies_ready "$index"; then
      record_recovery_status "$id" manual-pending "A declared dependency is not verified"
      continue
    fi
    kind="${COMPONENT_KINDS[$index]}"
    printf '\nRecovery component: %s (%s)\n' "${COMPONENT_LABELS[$index]}" "$id"
    if execute_recovery_component "$kind" "$index"; then rc=0; else rc=$?; fi
    if [[ "$rc" -ne 0 ]]; then
      print_recovery_session_summary
      die_with_code "$rc" "Recovery stopped at component $id; resume after resolving the failure"
    fi
  done
  print_recovery_session_summary
  printf 'Recovery session finished. Keep staging until every manual-pending component is completed.\n'
}

read_keep_last() {
  local line
  local key
  local value
  local keep_last=""
  if [[ -n "$KEEP_LAST_OVERRIDE" ]]; then
    keep_last="$KEEP_LAST_OVERRIDE"
  else
    [[ -f "$RETENTION_FILE" ]] || die "Retention file not found: $RETENTION_FILE"
    while IFS= read -r line || [[ -n "$line" ]]; do
      line="$(normalize_config_line "$line")"
      [[ -n "$line" ]] || continue
      [[ "$line" == *=* ]] || die "Invalid retention entry: $line"
      key="$(trim_whitespace "${line%%=*}")"
      value="$(trim_whitespace "${line#*=}")"
      [[ "$key" == "keep_last" ]] || die "Unknown retention key: $key"
      keep_last="$value"
    done <"$RETENTION_FILE"
  fi
  [[ "$keep_last" =~ ^[0-9]+$ && "$keep_last" -ge 1 ]] || die "keep_last must be an integer greater than or equal to 1"
  printf '%s\n' "$keep_last"
}

collect_prune_candidates() {
  local keep_last="$1"
  local -a names=()
  local candidate_count
  local index
  mapfile -t names < <(list_snapshot_names)
  candidate_count=$((${#names[@]} - keep_last))
  [[ "$candidate_count" -gt 0 ]] || return 0
  for ((index = 0; index < candidate_count; index++)); do
    printf '%s\n' "${names[$index]}"
  done
}

prune_snapshots() {
  local keep_last
  local lock_mode="shared"
  local -a candidates=()
  local name
  local path
  local canonical
  local errors=0
  local prune_log=""

  require_commands find readlink sort awk flock hostname rm date mkdir
  ensure_dest_access "check"
  keep_last="$(read_keep_last)"
  if [[ "$ASSUME_YES" -eq 1 && "$DRY_RUN" -eq 0 ]]; then
    lock_mode="exclusive"
  fi
  acquire_lock "$lock_mode"
  mapfile -t candidates < <(collect_prune_candidates "$keep_last")
  print_label_value "Retention keep-last:" "$keep_last"
  print_heading "Prune candidates:"
  if [[ "${#candidates[@]}" -eq 0 ]]; then
    printf '  - none\n'
    return 0
  fi
  printf '  - %s\n' "${candidates[@]}"
  if [[ "$ASSUME_YES" -eq 0 || "$DRY_RUN" -eq 1 ]]; then
    printf 'Preview only; add --yes without --dry-run to delete these snapshots.\n'
    return 0
  fi

  mkdir -p -- "$(logs_root_dir)"
  prune_log="$(logs_root_dir)/backup-home-prune-$(timestamp_now).log"
  for name in "${candidates[@]}"; do
    validate_snapshot_name "$name"
    path="$(snapshot_path_for "$name")"
    canonical="$(canonicalize_path "$path")"
    if [[ "$canonical" != "$(snapshot_root_dir)/$name" || ! -d "$path" || -L "$path" ]]; then
      warn "Refusing invalid prune candidate: $path"
      errors=$((errors + 1))
      continue
    fi
    printf 'delete\t%s\n' "$path" >>"$prune_log"
    if ! rm -rf --one-file-system -- "$path"; then
      warn "Could not delete snapshot: $path"
      errors=$((errors + 1))
    else
      printf 'Deleted snapshot: %s\n' "$name"
    fi
  done
  [[ "$errors" -eq 0 ]] || die "Prune completed with $errors deletion error(s)"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      plan|manual|run|list|verify|restore|restore-plan|recover|prune|drill|help)
        if [[ -z "$COMMAND" ]]; then COMMAND="$1"; else POSITIONAL_ARGS+=("$1"); fi
        shift
        ;;
      --dest) [[ $# -ge 2 ]] || die "--dest requires a value"; DEST_ROOT="$2"; shift 2 ;;
      --config-file) [[ $# -ge 2 ]] || die "--config-file requires a value"; PROFILE_FILE="$2"; shift 2 ;;
      --manual-file) [[ $# -ge 2 ]] || die "--manual-file requires a value"; MANUAL_FILE="$2"; shift 2 ;;
      --collectors-file) [[ $# -ge 2 ]] || die "--collectors-file requires a value"; COLLECTORS_FILE="$2"; shift 2 ;;
      --retention-file) [[ $# -ge 2 ]] || die "--retention-file requires a value"; RETENTION_FILE="$2"; shift 2 ;;
      --handlers-file) [[ $# -ge 2 ]] || die "--handlers-file requires a value"; HANDLERS_FILE="$2"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --verbose) VERBOSE=1; shift ;;
      --yes) ASSUME_YES=1; shift ;;
      --ignore-errors) IGNORE_ERRORS=1; shift ;;
      --deep) DEEP_VERIFY=1; shift ;;
      --log-file) [[ $# -ge 2 ]] || die "--log-file requires a value"; LOG_FILE="$2"; shift 2 ;;
      --snapshot) [[ $# -ge 2 ]] || die "--snapshot requires a value"; SNAPSHOT_NAME="$2"; shift 2 ;;
      --path) [[ $# -ge 2 ]] || die "--path requires a value"; RESTORE_PATH="$2"; shift 2 ;;
      --restore-to) [[ $# -ge 2 ]] || die "--restore-to requires a value"; RESTORE_DEST="$2"; shift 2 ;;
      --keep-last) [[ $# -ge 2 ]] || die "--keep-last requires a value"; KEEP_LAST_OVERRIDE="$2"; shift 2 ;;
      --target-user) [[ $# -ge 2 ]] || die "--target-user requires a value"; TARGET_USER="$2"; shift 2 ;;
      --target-home) [[ $# -ge 2 ]] || die "--target-home requires a value"; TARGET_HOME="$2"; shift 2 ;;
      --staging-dir) [[ $# -ge 2 ]] || die "--staging-dir requires a value"; STAGING_DIR="$2"; shift 2 ;;
      --map-path) [[ $# -ge 2 ]] || die "--map-path requires a value"; PATH_MAPPINGS+=("$2"); shift 2 ;;
      --component) [[ $# -ge 2 ]] || die "--component requires a value"; SELECTED_COMPONENTS+=("$2"); shift 2 ;;
      --approve-destructive) [[ $# -ge 2 ]] || die "--approve-destructive requires a value"; APPROVED_DESTRUCTIVE+=("$2"); shift 2 ;;
      --resume) [[ $# -ge 2 ]] || die "--resume requires a value"; RESUME_SESSION="$2"; shift 2 ;;
      --all) RECOVERY_ALL=1; shift ;;
      --skip-deep-verify) SKIP_DEEP_VERIFY=1; shift ;;
      --allow-legacy) ALLOW_LEGACY=1; shift ;;
      -h|--help) COMMAND="help"; shift ;;
      -*) die "Unknown option: $1" ;;
      *) POSITIONAL_ARGS+=("$1"); shift ;;
    esac
  done
}

apply_positional_defaults() {
  case "$COMMAND" in
    verify|restore|restore-plan|recover|drill)
      if [[ -z "$SNAPSHOT_NAME" && "${#POSITIONAL_ARGS[@]}" -gt 0 ]]; then
        SNAPSHOT_NAME="${POSITIONAL_ARGS[0]}"
        POSITIONAL_ARGS=("${POSITIONAL_ARGS[@]:1}")
      fi
      ;;
  esac
  [[ "${#POSITIONAL_ARGS[@]}" -eq 0 ]] || die "Unexpected positional argument: ${POSITIONAL_ARGS[0]}"
}

main() {
  parse_args "$@"
  [[ -n "$COMMAND" ]] || COMMAND="help"
  apply_positional_defaults
  case "$COMMAND" in
    help) usage ;;
    plan) show_plan ;;
    manual) show_manual ;;
    run) run_backup ;;
    list) list_backups ;;
    verify) verify_snapshot ;;
    restore) restore_snapshot ;;
    restore-plan) restore_plan ;;
    recover) recover_snapshot ;;
    prune) prune_snapshots ;;
    drill) drill_snapshot ;;
    *) die "Unknown command: $COMMAND" ;;
  esac
}

main "$@"

#!/usr/bin/env bash

# shellcheck disable=SC2034 # The caller uses the initialized globals.

collector_fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

collector_require_command() {
  command -v "$1" >/dev/null 2>&1 \
    || collector_fail "Required command is unavailable: $1"
}

collector_validate_relative_path() {
  local value="$1"
  [[ -n "$value" && "$value" != /* && "$value" != *$'\t'* && "$value" != *$'\n'* ]] \
    || collector_fail "Unsafe relative path in collector configuration: $value"
  [[ ! "$value" =~ (^|/)\.\.?(/|$) ]] \
    || collector_fail "Dot path segments are not allowed: $value"
}

collector_validate_name() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] \
    || collector_fail "Unsafe collector name: $1"
}

collector_init() {
  COLLECTOR_STAGE_DIR="${BACKUP_HOME_STAGE_DIR:-}"
  COLLECTOR_SOURCE_HOME="${BACKUP_HOME_SOURCE_HOME:-${HOME:-}}"
  [[ -n "$COLLECTOR_STAGE_DIR" && "$COLLECTOR_STAGE_DIR" == /* ]] \
    || collector_fail "BACKUP_HOME_STAGE_DIR must be an absolute path"
  [[ -n "$COLLECTOR_SOURCE_HOME" && "$COLLECTOR_SOURCE_HOME" == /* ]] \
    || collector_fail "BACKUP_HOME_SOURCE_HOME must be an absolute path"
  mkdir -p -- "$COLLECTOR_STAGE_DIR"
  chmod 700 -- "$COLLECTOR_STAGE_DIR"
  COLLECTOR_WARNINGS_FILE="$COLLECTOR_STAGE_DIR/warnings.txt"
  COLLECTOR_INDEX_FILE="$COLLECTOR_STAGE_DIR/index.tsv"
  printf 'kind\tsource\tartifact\tstatus\tdetail\n' >"$COLLECTOR_INDEX_FILE"
}

collector_warn() {
  printf 'Warning: %s\n' "$*" >&2
  printf '%s\n' "$*" >>"$COLLECTOR_WARNINGS_FILE"
}

collector_index() {
  local value
  for value in "$@"; do
    [[ "$value" != *$'\t'* && "$value" != *$'\n'* ]] \
      || collector_fail "Collector index values must not contain tabs or newlines"
  done
  printf '%s\t%s\t%s\t%s\t%s\n' "$1" "$2" "$3" "$4" "$5" \
    >>"$COLLECTOR_INDEX_FILE"
}

collector_copy_stable_file() {
  local source="$1"
  local target="$2"
  local before
  local after
  local attempt

  mkdir -p -- "$(dirname -- "$target")"
  for attempt in 1 2 3; do
    before="$(stat -c '%s:%Y' -- "$source" 2>/dev/null || true)"
    [[ -n "$before" ]] || return 1
    cp --preserve=mode,timestamps -- "$source" "$target"
    after="$(stat -c '%s:%Y' -- "$source" 2>/dev/null || true)"
    [[ "$before" == "$after" ]] && return 0
  done
  rm -f -- "$target"
  return 1
}

collector_finalize() {
  [[ -s "$COLLECTOR_WARNINGS_FILE" ]] || rm -f -- "$COLLECTOR_WARNINGS_FILE"
  (
    cd -- "$COLLECTOR_STAGE_DIR" || exit 1
    find . -type f ! -name checksums.sha256 -print0 \
      | sort -z \
      | xargs -0 -r sha256sum
  ) >"$COLLECTOR_STAGE_DIR/checksums.sha256"
  chmod -R go-rwx -- "$COLLECTOR_STAGE_DIR"
}

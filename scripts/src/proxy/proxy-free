#!/usr/bin/env bash

PROXY_FREE_VARS=(
    http_proxy
    https_proxy
    all_proxy
    ftp_proxy
    rsync_proxy
    HTTP_PROXY
    HTTPS_PROXY
    ALL_PROXY
    FTP_PROXY
    RSYNC_PROXY
    no_proxy
    NO_PROXY
    npm_config_proxy
    npm_config_https_proxy
    npm_config_noproxy
    yarn_proxy
    yarn_https_proxy
)

is_sourced() {
    if [ -n "${ZSH_EVAL_CONTEXT:-}" ]; then
        case "$ZSH_EVAL_CONTEXT" in
            *:file:*) return 0 ;;
            *:file) return 0 ;;
        esac
    fi

    if [ -n "${BASH_VERSION:-}" ] && [ "${BASH_SOURCE[0]}" != "$0" ]; then
        return 0
    fi

    return 1
}

finish() {
    if is_sourced; then
        return "$1"
    fi

    exit "$1"
}

print_unset_commands() {
    printf 'unset'
    for name in "${PROXY_FREE_VARS[@]}"; do
        printf ' %s' "$name"
    done
    printf '\n'
}

run_without_proxy() {
    exec env \
        -u http_proxy \
        -u https_proxy \
        -u all_proxy \
        -u ftp_proxy \
        -u rsync_proxy \
        -u HTTP_PROXY \
        -u HTTPS_PROXY \
        -u ALL_PROXY \
        -u FTP_PROXY \
        -u RSYNC_PROXY \
        -u no_proxy \
        -u NO_PROXY \
        -u npm_config_proxy \
        -u npm_config_https_proxy \
        -u npm_config_noproxy \
        -u yarn_proxy \
        -u yarn_https_proxy \
        "$@"
}

show_help() {
    cat <<'EOF'
Usage:
  source proxy-free
  eval "$(proxy-free --print)"
  proxy-free -- command [args...]

Clear common proxy environment variables such as http_proxy, https_proxy,
ALL_PROXY, NO_PROXY, npm_config_proxy, and yarn proxy variables.

Options:
  --print     Print unset commands for eval.
  -h, --help  Show this help text.

Notes:
  Running proxy-free as a normal command cannot change the parent shell.
  Source it to clear variables in your current shell.
EOF
}

case "${1:-}" in
    -h|--help)
        show_help
        finish 0
        ;;
    --print)
        print_unset_commands
        finish 0
        ;;
    --)
        shift
        if [ "$#" -eq 0 ]; then
            printf 'proxy-free: -- requires a command.\n' >&2
            finish 1
        fi
        run_without_proxy "$@"
        ;;
esac

if [ "$#" -gt 0 ]; then
    run_without_proxy "$@"
fi

for name in "${PROXY_FREE_VARS[@]}"; do
    unset "$name"
done

if ! is_sourced; then
    printf 'Proxy variables were cleared only for this process.\n' >&2
    printf 'To clear your current shell, run: source proxy-free\n' >&2
fi

finish 0

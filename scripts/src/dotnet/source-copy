COMMON_ROOT_FILES = [
    "Directory.Build.props",
    "Directory.Build.targets",
    "Directory.Packages.props",
    "global.json",
    "NuGet.config",
    ".editorconfig",
    ".gitattributes",
    ".gitignore",
]

def copy_tree_merge(
    input_root: Path,
    src_dir: Path,
    output_root: Path,
    rules: List[IgnoreRule],
    dry_run: bool = False,
) -> None:
    """
    Copy src_dir into output_root preserving relative path from input_root.
    Merges overlapping trees.
    """
    for dirpath, dirnames, filenames in os.walk(src_dir):
        cur = Path(dirpath)
        rel_cur = cur.resolve().relative_to(input_root.resolve())
        rel_cur_posix = rel_cur.as_posix()

        # Filter directories in-place
        kept_dirs = []
        for d in dirnames:
            child_dir = (cur / d).resolve()
            if is_relative_to_path(output_root, child_dir):
                continue
            d_rel = (Path(rel_cur_posix) / d).as_posix()
            if should_ignore(d_rel, is_dir=True, rules=rules):
                continue
            kept_dirs.append(d)
        dirnames[:] = kept_dirs

        # Ensure destination directory exists
        dst_cur = output_root / rel_cur
        if not dry_run:
            dst_cur.mkdir(parents=True, exist_ok=True)

        for f in filenames:
            src_file = cur / f
            rel_file = (rel_cur / f).as_posix()
            if should_ignore(rel_file, is_dir=False, rules=rules):
                continue
            dst_file = output_root / rel_cur / f
            if dry_run:
                print(f"[DRY] copy {src_file} -> {dst_file}")
            else:
                dst_file.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(src_file, dst_file)


# ----------------------------
# PowerShell build script generation
# ----------------------------

def generate_powershell(
    output_root: Path,
    selected_root_projects: List[Path],
    input_root: Path,
) -> Path:
    """
    Write build_release.ps1 into output_root.
    Projects are referenced by their copied relative paths within output_root.
    """
    # Convert paths to relative paths inside output_root
    rel_paths: List[str] = []
    for p in selected_root_projects:
        rel = p.resolve().relative_to(input_root.resolve()).as_posix()
        rel_paths.append(rel)

    # De-dup preserve order
    seen = set()
    rel_paths = [x for x in rel_paths if not (x in seen or seen.add(x))]

    ps1 = output_root / "build_release.ps1"
    content = textwrap.dedent(f"""\
    [CmdletBinding()]
    param(
      [switch]$Publish,
      [switch]$Pack
    )

    $ErrorActionPreference = "Stop"
    $root = (Resolve-Path (Split-Path -Parent $MyInvocation.MyCommand.Path)).Path
    Set-Location $root

    # Publish by default so each selected project gets a Release output folder.
    if (-not $PSBoundParameters.ContainsKey("Publish")) {{
      $Publish = $true
    }}

    # Projects selected for release build (relative to output folder):
    $projects = @(
    {os.linesep.join([f'  "{rp}"' for rp in rel_paths])}
    )

    # Publish outputs always go to ./output beside this script.
    $outputRoot = Join-Path $root "output"
    New-Item -ItemType Directory -Force -Path $outputRoot | Out-Null

    Write-Host "Building (Release)..." -ForegroundColor Cyan
    foreach ($p in $projects) {{
      Write-Host "dotnet build $p -c Release"
      dotnet build $p -c Release
      if ($LASTEXITCODE -ne 0) {{
        throw "dotnet build failed for $p (exit code $LASTEXITCODE)."
      }}
    }}

    if ($Publish) {{
      Write-Host "Publishing (Release)..." -ForegroundColor Cyan
      foreach ($p in $projects) {{
        $name = [System.IO.Path]::GetFileNameWithoutExtension($p)
        $outDir = Join-Path $outputRoot $name
        New-Item -ItemType Directory -Force -Path $outDir | Out-Null
        Write-Host "dotnet publish $p -c Release -o $outDir"
        dotnet publish $p -c Release -o $outDir
        if ($LASTEXITCODE -ne 0) {{
          throw "dotnet publish failed for $p (exit code $LASTEXITCODE)."
        }}
        if (-not (Get-ChildItem -Path $outDir -Force | Select-Object -First 1)) {{
          throw "Publish output is empty for $p. Check project publish settings."
        }}
      }}
    }}

    if ($Pack) {{
      $nupkgDir = Join-Path $outputRoot "nuget"
      New-Item -ItemType Directory -Force -Path $nupkgDir | Out-Null

      Write-Host "Packing (Release)..." -ForegroundColor Cyan
      foreach ($p in $projects) {{
        Write-Host "dotnet pack $p -c Release -o $nupkgDir"
        dotnet pack $p -c Release -o $nupkgDir
        if ($LASTEXITCODE -ne 0) {{
          throw "dotnet pack failed for $p (exit code $LASTEXITCODE)."
        }}
      }}
    }}

    Write-Host "Done." -ForegroundColor Green
    """)
    ps1.write_text(content, encoding="utf-8")
    return ps1


# ----------------------------
# Main
# ----------------------------

def main() -> int:
    ap = argparse.ArgumentParser(
        prog="source-copy",
        description="Select C#/.NET projects and copy them with referenced projects to an output folder.",
        formatter_class=argparse.RawTextHelpFormatter,
        epilog=textwrap.dedent("""\
        Examples:
          source-copy --output /tmp/release-source
          source-copy LMS_Backend --output /tmp/lms-source
          source-copy . --output /tmp/source-copy --select all
          source-copy . --output /tmp/source-copy --select 1,3,5-7
          source-copy . --output /tmp/source-copy --select 're:WebApi|Gateway'
          source-copy . --output /tmp/source-copy --list
          source-copy . --output /tmp/source-copy --all-projects --list
          source-copy . --output /tmp/source-copy --select 1 --dry-run
        """),
    )
    ap.add_argument("input", nargs="?", default=None, help="Input directory/repo root (default: current directory)")
    ap.add_argument("--input", "-i", dest="input_option", help="Input directory/repo root (kept for compatibility)")
    ap.add_argument("--output", "-o", required=True, help="Destination directory (required)")
    ap.add_argument("--select", help="Selection: all, indexes/ranges like 1,3,5-7, or re:<regex>. If omitted in a TTY, you'll be prompted.")
    ap.add_argument("--list", action="store_true", help="List discovered projects and exit without copying")
    ap.add_argument("--dry-run", action="store_true", help="Show what would be copied, without copying")
    ap.add_argument("--no-common-root-files", action="store_true", help="Do not copy common root build files")
    ap.add_argument("--all-projects", action="store_true", help="Show all .sln/.csproj entries instead of only presentation/API/UI projects")
    ap.add_argument("--presentation-only", action="store_true", help="Only list csproj likely to be presentation layer (default; kept for compatibility)")
    ap.add_argument("--presentation-regex", help="Regex on relative csproj path; if it matches, treat as presentation.")
    args = ap.parse_args()

    if args.all_projects and args.presentation_only:
        print("[ERROR] Use either --all-projects or --presentation-only, not both.")
        return 2

    if args.input and args.input_option:
        print("[ERROR] Use either positional INPUT or --input, not both.")
        return 2

    input_arg = args.input_option or args.input or "."
    input_root = Path(input_arg).expanduser().resolve()
    output_root = Path(args.output).expanduser().resolve()

    if not input_root.exists() or not input_root.is_dir():
        print(f"[ERROR] Input root not found or not a directory: {input_root}")
        return 2
    if output_root == input_root:
        print("[ERROR] Output must not be the same directory as input.")
        return 2

    presentation_rx: Optional[re.Pattern] = None
    if args.presentation_regex:
        try:
            presentation_rx = re.compile(args.presentation_regex, re.IGNORECASE)
        except re.error as e:
            print(f"[ERROR] Invalid --presentation-regex: {e}")
            return 2

    presentation_only = not args.all_projects

    items = discover_items(
        input_root,
        presentation_only=presentation_only,
        presentation_regex=presentation_rx,
        exclude_roots={output_root} if is_relative_to_path(output_root, input_root) else None,
    )
    if not items:
        if presentation_only:
            print("[INFO] No presentation/API/UI .csproj files found. Use --all-projects to show every .sln/.csproj entry.")
        else:
            print("[INFO] No .sln or .csproj files found.")
        return 0

    print(f"\nInput:  {input_root}")
    print(f"Output: {output_root}")
    if presentation_only:
        print("\nFound presentation/API/UI projects:")
    else:
        print("\nFound all .sln/.csproj entries:")
    for idx, it in enumerate(items, start=1):
        rel = it.path.resolve().relative_to(input_root).as_posix()
        print(f"{idx:3d}) {format_change_time(it.latest_change_time):16}  [{it.kind}] {rel}")

    if args.list:
        print(f"\nFound {len(items)} selectable item(s).")
        return 0

    # Determine selection
    selected_indices: Set[int] = set()

    if args.select:
        sel = args.select.strip()
        if sel.lower().startswith("re:"):
            try:
                rx = re.compile(sel[3:], re.IGNORECASE)
            except re.error as e:
                print(f"[ERROR] Invalid --select regex: {e}")
                return 2
            for idx, it in enumerate(items, start=1):
                rel = it.path.resolve().relative_to(input_root).as_posix()
                if rx.search(rel):
                    selected_indices.add(idx)
        else:
            try:
                selected_indices = parse_index_selection(sel, max_index=len(items))
            except ValueError as e:
                print(f"[ERROR] {e}")
                return 2
    else:
        tui_selected = tui_select_indices(items, input_root)
        if tui_selected:
            selected_indices = tui_selected
        else:
            if not sys.stdin.isatty():
                print("[ERROR] No interactive terminal is available. Pass --select, or use --list to inspect choices.")
                return 2
            if tui_selected == set():
                print("[INFO] No selections in menu. Falling back to text selection.")
            elif not _HAS_PROMPT_TOOLKIT:
                print("[INFO] For a better menu, install prompt_toolkit (pip install prompt_toolkit).")
            while True:
                sel = input("\nSelect items (e.g. 1,3,5-7 or 'all'): ").strip()
                try:
                    selected_indices = parse_index_selection(sel, max_index=len(items))
                    if not selected_indices:
                        print("No valid selections. Try again.")
                        continue
                    break
                except ValueError as e:
                    print(f"Invalid selection: {e}")

    if not selected_indices:
        print("[ERROR] Selection matched no projects.")
        return 2

    selected_items = [items[i - 1] for i in sorted(selected_indices)]
    print("\nSelected:")
    for it in selected_items:
        rel = it.path.resolve().relative_to(input_root).as_posix()
        print(f" - [{it.kind}] {rel}")

    # Expand selection to root csproj list
    selected_root_csprojs: List[Path] = []
    for it in selected_items:
        if it.kind == "csproj":
            selected_root_csprojs.append(it.path.resolve())
        else:
            # sln
            csps = sln_to_csprojs(it.path.resolve())
            if not csps:
                print(f"[WARN] No .csproj parsed from solution: {it.path}")
            selected_root_csprojs.extend(csps)

    # De-dup preserve order
    seen = set()
    selected_root_csprojs = [p for p in selected_root_csprojs if not (p in seen or seen.add(p))]

    if not selected_root_csprojs:
        print("[ERROR] Selection produced no .csproj projects.")
        return 2

    # Dependency closure
    all_csprojs, warnings = dependency_closure(selected_root_csprojs, input_root=input_root)

    # Collect project directories to copy
    project_dirs: Set[Path] = set()
    for cp in all_csprojs:
        project_dirs.add(cp.parent.resolve())

    # Show plan
    print("\nProjects to include (root selections):")
    for p in selected_root_csprojs:
        try:
            rel = p.relative_to(input_root).as_posix()
        except ValueError:
            rel = str(p)
        print(f" - {rel}")

    print("\nAll projects to copy (including referenced):")
    for p in sorted(all_csprojs, key=lambda x: x.as_posix().lower()):
        rel = p.relative_to(input_root).as_posix()
        print(f" - {rel}")

    if warnings:
        print("\nWarnings:")
        for w in warnings:
            print(f" - {w}")

    # Prepare output directory
    if not args.dry_run:
        output_root.mkdir(parents=True, exist_ok=True)

    # Load ignore rules
    rules = load_root_gitignore(input_root)

    # Copy common root files
    if not args.no_common_root_files:
        for fn in COMMON_ROOT_FILES:
            src = input_root / fn
            if src.exists() and src.is_file():
                dst = output_root / fn
                if args.dry_run:
                    print(f"[DRY] copy {src} -> {dst}")
                else:
                    shutil.copy2(src, dst)

    # Copy each project directory (merge)
    print("\nCopying project directories...")
    for d in sorted(project_dirs, key=lambda x: x.as_posix().lower()):
        rel = d.relative_to(input_root).as_posix()
        print(f" - {rel}")
        copy_tree_merge(
            input_root=input_root,
            src_dir=d,
            output_root=output_root,
            rules=rules,
            dry_run=args.dry_run,
        )

    # Generate PowerShell build script (based on root selections)
    if not args.dry_run:
        ps1 = generate_powershell(
            output_root=output_root,
            selected_root_projects=selected_root_csprojs,
            input_root=input_root,
        )
        print("\nGenerated:")
        print(f" - {ps1}")

        cmd = f'powershell -ExecutionPolicy Bypass -File "{ps1}"'
        print("\nRun this to build and publish Release for each selected project:")
        print(cmd)
        print("\nOptional flags:")
        print(f'powershell -ExecutionPolicy Bypass -File "{ps1}" -Publish:$false')
        print(f'powershell -ExecutionPolicy Bypass -File "{ps1}" -Pack')
        print(f'powershell -ExecutionPolicy Bypass -File "{ps1}" -Publish -Pack')

    print("\nDone.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

#!/usr/bin/env python3
"""
source-copy

Features:
- Discover .sln and .csproj under an input directory
- Optional presentation-only filter (best-effort heuristics)
- Interactive multi-select (TUI if prompt_toolkit is installed)
- Expand .sln => its .csproj entries
- Build dependency closure via <ProjectReference Include="...">
- Copy selected projects + dependencies to output, honoring root .gitignore (best-effort)
- Generate build_release.ps1 to build/publish/pack in Release

Notes:
- .gitignore parsing is best-effort and reads ONLY the root .gitignore (input/.gitignore).
  It also ALWAYS ignores common build folders (bin, obj, .git, .vs, etc.)
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
import textwrap
import time
import xml.etree.ElementTree as ET
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path, PurePosixPath
from typing import Dict, Iterable, List, Optional, Set, Tuple

try:
    from prompt_toolkit.shortcuts import checkboxlist_dialog
    _HAS_PROMPT_TOOLKIT = True
except Exception:
    _HAS_PROMPT_TOOLKIT = False



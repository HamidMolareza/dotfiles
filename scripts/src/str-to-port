#!/usr/bin/env python3

import sys

MIN_PORT = 1024
MAX_PORT = 49151

HELP_MSG = """
str-to-port: Deterministically map a string to a safe TCP port.

Usage:
  ./str-to-port [OPTIONS] <your-string>

Options:
  -v, --verbose    Show a detailed breakdown of computation.
  -h, --help       Show this help message and exit.

Examples:
  ./str-to-port MyApp123
  ./str-to-port -v "Hello World"
"""

def string_to_port(s: str, min_port=MIN_PORT, max_port=MAX_PORT, verbose=False):
    ascii_values = [ord(c) for c in s]
    total = sum(ascii_values)
    port_range = max_port - min_port + 1
    mapped_port = min_port + (total % port_range)
    if verbose:
        print(f"Input string: {s}")
        print(f"ASCII values: {ascii_values}")
        print(f"ASCII sum: {total}")
        print(f"Port range: [{min_port}, {max_port}] (Size: {port_range})")
        print(f"Mapped port: {mapped_port}")
    else:
        print(mapped_port)

def main():
    args = sys.argv[1:]
    verbose = False

    if not args or '-h' in args or '--help' in args:
        print(HELP_MSG)
        sys.exit(0)

    if '-v' in args:
        verbose = True
        args.remove('-v')
    if '--verbose' in args:
        verbose = True
        args.remove('--verbose')

    if not args:
        print("Error: Missing string to map.\n")
        print(HELP_MSG)
        sys.exit(1)

    input_str = " ".join(args)
    try:
        if not input_str.strip():
            raise ValueError("Input string cannot be empty.")
        string_to_port(input_str, MIN_PORT, MAX_PORT, verbose)
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()

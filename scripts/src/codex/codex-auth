def format_auth_file_list(auth_files: Sequence[AuthFile]) -> str:
    lines = [
        "Auth files found:",
        f"      {menu_header()}",
        f"      {menu_separator()}",
    ]
    for index, auth_file in enumerate(auth_files, start=1):

        return None
    if not isinstance(value, str):
        raise ValueError("metadata purchase date must be a string")
    return date.fromisoformat(value)


def parse_metadata_validity_days(value: object) -> int | None:
    if value is None:
        return None
    if isinstance(value, bool) or not isinstance(value, int) or value <= 0:
        raise ValueError("metadata validity days must be a positive integer")
    return value


def parse_account_metadata_payload(payload: object) -> AccountMetadata:
    if not isinstance(payload, dict):
        raise ValueError("metadata payload must be an object")
    try:
        return AccountMetadata(
            seller=parse_metadata_text(payload.get("seller")),
            purchased_on=parse_metadata_purchase_date(payload.get("purchased_on")),
            valid_for_days=parse_metadata_validity_days(payload.get("valid_for_days")),
            note=parse_metadata_text(payload.get("note")),
        )
    except (TypeError, ValueError):
        raise ValueError("metadata payload contains invalid values") from None


def load_legacy_account_metadata(auth_path: Path) -> AccountMetadata:
    sidecar_path = legacy_metadata_path(auth_path)
    try:
        payload = json.loads(sidecar_path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return AccountMetadata()
    except (OSError, json.JSONDecodeError):
        return AccountMetadata(error="metadata error")

    if not isinstance(payload, dict) or payload.get("version") != METADATA_VERSION:
        return AccountMetadata(error="metadata error")

    try:
        return parse_account_metadata_payload(payload)
    except ValueError:
        return AccountMetadata(error="metadata error")


def account_metadata_payload(metadata: AccountMetadata) -> dict[str, object]:
    payload: dict[str, object] = {}
    if metadata.seller:
        payload["seller"] = metadata.seller
    if metadata.purchased_on is not None:
        payload["purchased_on"] = metadata.purchased_on.isoformat()
    if metadata.valid_for_days is not None:
        payload["valid_for_days"] = metadata.valid_for_days
    if metadata.note:
        payload["note"] = metadata.note
    return payload


def load_account_metadata_store(directory: Path) -> dict[str, AccountMetadata] | None:
    store_path = metadata_store_path(directory)
    try:
        payload = json.loads(store_path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return {}
    except (OSError, json.JSONDecodeError):
        return None

    if not isinstance(payload, dict) or payload.get("version") != METADATA_VERSION:
        return None

    accounts = payload.get("accounts")
    if not isinstance(accounts, dict):
        return None

    metadata_by_email: dict[str, AccountMetadata] = {}
    for email, account_payload in accounts.items():
        if not isinstance(email, str):
            continue
        key = metadata_key(email)
        if not key:
            continue
        try:
            metadata_by_email[key] = parse_account_metadata_payload(account_payload)
        except ValueError:
            metadata_by_email[key] = AccountMetadata(error="metadata error")
    return metadata_by_email


def write_account_metadata_store(directory: Path, metadata_by_email: dict[str, AccountMetadata]) -> None:
    store_path = metadata_store_path(directory)
    accounts = {
        email: account_metadata_payload(metadata)
        for email, metadata in sorted(metadata_by_email.items())
        if metadata.has_values() and not metadata.error
    }

    if not accounts:
        try:
            store_path.unlink()
        except FileNotFoundError:
            return
        fsync_directory(store_path.parent)
        return

    temp_path = store_path.with_name(f"{store_path.name}.tmp-{secrets.token_hex(4)}")
    payload = {"version": METADATA_VERSION, "accounts": accounts}
    try:
        temp_path.write_text(
            json.dumps(payload, indent=2, sort_keys=True) + "\n",
            encoding="utf-8",
        )
        os.replace(temp_path, store_path)
        fsync_directory(store_path.parent)
    finally:
        try:
            temp_path.unlink()
        except FileNotFoundError:
            pass


def load_account_metadata(
    auth_path: Path,
    email: str,
    metadata_by_email: dict[str, AccountMetadata] | None,
) -> AccountMetadata:
    if not email:
        return AccountMetadata()

    if metadata_by_email is None:
        return AccountMetadata(error="metadata error")

    key = metadata_key(email)
    if key in metadata_by_email:
        return metadata_by_email[key]

    return load_legacy_account_metadata(auth_path)


def save_account_metadata(auth_file: AuthFile, metadata: AccountMetadata) -> None:
    key = metadata_key(auth_file.email)
    if not key:
        raise ValueError(f"No email found for {auth_file.name}; account info cannot be saved.")

    metadata_by_email = load_account_metadata_store(auth_file.path.parent)
    if metadata_by_email is None:
        raise ValueError(f"Invalid metadata store: {metadata_store_path(auth_file.path.parent)}")

    if metadata.has_values():
        metadata_by_email[key] = metadata
    else:
        metadata_by_email.pop(key, None)
    write_account_metadata_store(auth_file.path.parent, metadata_by_email)


def migrate_legacy_account_metadata(
    auth_path: Path,
    email: str,
    metadata: AccountMetadata,
    metadata_by_email: dict[str, AccountMetadata] | None,
) -> bool:
    if metadata_by_email is None or not email or metadata.error or not metadata.has_values():
        return False
    key = metadata_key(email)
    if key in metadata_by_email:
        return False
    metadata_by_email[key] = metadata
    debug_log("migrated legacy account metadata", auth_file=auth_path.name, email=email)
    return True


def account_expiration_date(metadata: AccountMetadata) -> date | None:
    if metadata.purchased_on is None or metadata.valid_for_days is None:
        return None
    return metadata.purchased_on + timedelta(days=metadata.valid_for_days)


def is_account_expired(metadata: AccountMetadata, *, today: date | None = None) -> bool:
    expires_on = account_expiration_date(metadata)
    if expires_on is None:
        return False
    current_date = today or datetime.now().astimezone().date()
    return expires_on < current_date


def is_auth_file_expired(auth_file: AuthFile, *, today: date | None = None) -> bool:
    return is_account_expired(auth_file.metadata, today=today) and not auth_file.quota_server_confirmed


def account_validity_text(metadata: AccountMetadata, *, today: date | None = None) -> str:
    if metadata.purchased_on is None and metadata.valid_for_days is None:
        return EMPTY_CELL
    if metadata.purchased_on is None:
        return f"{metadata.valid_for_days}d validity"
    expires_on = account_expiration_date(metadata)
    if expires_on is None:
        return EMPTY_CELL
    current_date = today or datetime.now().astimezone().date()
    remaining_days = (expires_on - current_date).days
    if remaining_days > 0:
        return f"{remaining_days}d left"
    if remaining_days == 0:
        return "expires today"
    return f"expired {-remaining_days}d"


def format_account_info(metadata: AccountMetadata) -> str:
    if metadata.error:
        return metadata.error

    parts = []
    if metadata.seller:
        parts.append(metadata.seller)
    if metadata.purchased_on is not None:
        parts.append(f"bought {metadata.purchased_on.isoformat()}")
    validity = account_validity_text(metadata)
    if validity:
        parts.append(validity)
    if metadata.note:
        parts.append(metadata.note)
    return " | ".join(parts)


def menu_header() -> str:
    return (
        f"{'Status':<{STATUS_WIDTH}} "
        f"{'File':<{NAME_WIDTH}} "
        f"{'5h left':<{PRIMARY_LEFT_WIDTH}} "
        f"{'5h in':<{PRIMARY_RESET_WIDTH}} "

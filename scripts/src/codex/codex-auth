def prompt_metadata_update(label: str, current: str, tty_input, tty_output) -> tuple[str, str]:
    display = current or "empty"
    tty_output.write(f"{label} [{display}] (Enter keeps, {METADATA_CLEAR_TOKEN} clears): ")
    tty_output.flush()
    value = tty_input.readline()
    if value == "":
        fail("Account info editor was interrupted.", exit_code=130)

    value = value.strip()
    if not value:
        return ("keep", EMPTY_CELL)
    if value == METADATA_CLEAR_TOKEN:
        return ("clear", EMPTY_CELL)
    return ("set", value)


def prompt_metadata_text(label: str, current: str, tty_input, tty_output) -> str:
    action, value = prompt_metadata_update(label, current, tty_input, tty_output)
    if action == "keep":
        return current
    if action == "clear":
        return EMPTY_CELL
    return value


def prompt_metadata_purchase_date(current: date | None, tty_input, tty_output) -> date | None:
    current_text = current.isoformat() if current is not None else EMPTY_CELL
    while True:
        action, value = prompt_metadata_update("Purchased on YYYY-MM-DD", current_text, tty_input, tty_output)
        if action == "keep":
            return current
        if action == "clear":
            return None
        try:
            return date.fromisoformat(value)
        except ValueError:
            tty_output.write("Purchase date must use YYYY-MM-DD.\n")
            tty_output.flush()


def prompt_metadata_validity_days(current: int | None, tty_input, tty_output) -> int | None:
    current_text = str(current) if current is not None else EMPTY_CELL
    while True:
        action, value = prompt_metadata_update("Validity days", current_text, tty_input, tty_output)
        if action == "keep":
            return current
        if action == "clear":
            return None
        if value.isdigit() and int(value) > 0:
            return int(value)

        tty_output.write("Validity days must be a positive integer.\n")
        tty_output.flush()


def prompt_account_metadata(auth_file: AuthFile, tty_input, tty_output) -> AccountMetadata:

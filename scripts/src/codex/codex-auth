def env_flag_enabled(name: str) -> bool:
    value = os.environ.get(name, "")
    return value.strip().lower() in {"1", "true", "yes", "on", "debug"}


def configure_debug_logging(enabled: bool, log_path: Path | None) -> None:
    global DEBUG_STREAM
    global DEBUG_STREAM_OWNED

    if DEBUG_STREAM_OWNED and DEBUG_STREAM is not None:
        DEBUG_STREAM.close()

    DEBUG_STREAM = None
    DEBUG_STREAM_OWNED = False

    if not enabled:
        return

    if log_path is None:
        DEBUG_STREAM = sys.stderr
        return

    log_path.parent.mkdir(parents=True, exist_ok=True)
    DEBUG_STREAM = log_path.open("a", encoding="utf-8")
    DEBUG_STREAM_OWNED = True


def close_debug_logging() -> None:
    global DEBUG_STREAM
    global DEBUG_STREAM_OWNED

    if DEBUG_STREAM_OWNED and DEBUG_STREAM is not None:
        DEBUG_STREAM.close()
    DEBUG_STREAM = None
    DEBUG_STREAM_OWNED = False


def debug_enabled() -> bool:
    return DEBUG_STREAM is not None


def summarize_debug_value(value: object) -> str:
    if isinstance(value, Path):
        return str(value)
    if isinstance(value, BaseException):
        return f"{type(value).__name__}({value})"
    if isinstance(value, str):
        text = value.replace("\n", "\\n")
    else:
        try:
            text = json.dumps(value, sort_keys=True, default=str)
        except TypeError:
            text = repr(value)
    if len(text) > DEBUG_BODY_PREVIEW_LIMIT:
        return f"{text[:DEBUG_BODY_PREVIEW_LIMIT]}..."
    return text


def debug_log(message: str, **fields: object) -> None:
    stream = DEBUG_STREAM
    if stream is None:
        return

    timestamp = datetime.now().astimezone().strftime("%Y-%m-%d %H:%M:%S")
    suffix = ""
    if fields:
        parts = [f"{key}={summarize_debug_value(value)}" for key, value in sorted(fields.items())]
        suffix = " | " + " ".join(parts)
    print(f"[codex-auth debug] {timestamp} | {message}{suffix}", file=stream, flush=True)


def debug_exception(message: str, error: BaseException, **fields: object) -> None:
    debug_log(message, error=error, **fields)
    if not debug_enabled():
        return
    for line in traceback.format_exception(type(error), error, error.__traceback__):
        DEBUG_STREAM.write(line)
    DEBUG_STREAM.flush()


def error_body_preview(error: urllib_error.HTTPError) -> str:
    try:
        body = error.read()
    except OSError:
        return EMPTY_CELL
    if not body:
        return EMPTY_CELL
    try:
        return body.decode("utf-8", errors="replace")
    except Exception:
        return repr(body[:DEBUG_BODY_PREVIEW_LIMIT])


def normalize_proxy_value(value: str | None) -> str | None:
    if value is None:
        return DEFAULT_USAGE_PROXY_URL

    normalized = value.strip()
    if not normalized:
        return DEFAULT_USAGE_PROXY_URL

    lowered = normalized.lower()
    if lowered in {"direct", "none", "off", "disable", "disabled"}:
        return None

    if re.fullmatch(r"\d+", normalized):
        return f"http://127.0.0.1:{normalized}"

    if "://" not in normalized:
        return f"http://{normalized}"

    return normalized


def usage_proxy_from_value(value: str) -> UsageProxyConfig:
    normalized = normalize_proxy_value(value)
    if normalized is None:
        return UsageProxyConfig(display="direct")
    return UsageProxyConfig(proxy_url=normalized, display=normalized)


def default_usage_proxy_config() -> UsageProxyConfig:
    return UsageProxyConfig(use_environment=True, display=DEFAULT_USAGE_PROXY_DISPLAY)


def show_help() -> None:
    print(
        f"""Usage: codex-auth [OPTIONS]

Switch the active Codex auth file inside {AUTH_DIR}.

Rules:
  - {ACTIVE_NAME} is the active file
  - auth.json<number> files are inactive candidates
  - at most one active file exists at a time
  - the menu shows cached or live remaining quota and reset countdowns for each auth file
  - the menu shows each auth file's user email from the local id_token or cache when available
  - Edit Account Info stores seller, purchase date, validity days, and a note in {METADATA_STORE_NAME}
  - account info is keyed by email, so it follows auth files when codex-auth switches or archives them
  - quota probes use a read-only HTTPS request with the current auth token
  - quota probes never trigger token refresh or modify your real auth files
  - transient probe failures keep stale cached quota when available and mark it with *
  - sorting prioritizes server-confirmed expired accounts, then nearest account expiry,
    then 7d reset, 5h reset, and lower remaining percentages
  - live probe failures can surface as statuses such as token expired, timeout, bad auth, or network error
  - after a successful switch, the newly active file timestamp is updated
  - New Account archives the active auth.json into the next auth.json<number> slot

Options:
  -d, --dir PATH   Override the auth directory (default: {AUTH_DIR})
  --proxy VALUE    Proxy for usage probes. Accepts URL, host:port, port, or 'direct'.
                   Default: {DEFAULT_USAGE_PROXY_DISPLAY}
  --debug          Enable probe debug logging
  --debug-log PATH Write debug logs to PATH instead of stderr
  -h, --help       Show this help text
"""
    )


def parse_args(argv: Sequence[str]) -> CliOptions:
    directory = AUTH_DIR
    debug = env_flag_enabled(DEBUG_ENV_VAR)
    debug_log_value = os.environ.get(DEBUG_LOG_ENV_VAR, "").strip()
    debug_log_path = Path(debug_log_value).expanduser() if debug_log_value else None
    proxy_url = os.environ.get(PROXY_ENV_VAR, "").strip() or None
    index = 0

    while index < len(argv):
        arg = argv[index]
        if arg in {"-h", "--help"}:
            show_help()
            raise SystemExit(0)
        if arg in {"-d", "--dir"}:
            index += 1
            if index >= len(argv):
                fail("--dir requires a path value.")
            directory = Path(argv[index]).expanduser()
        elif arg == "--debug":
            debug = True
        elif arg == "--debug-log":
            index += 1
            if index >= len(argv):
                fail("--debug-log requires a path value.")
            debug = True
            debug_log_path = Path(argv[index]).expanduser()
        elif arg == "--proxy":
            index += 1
            if index >= len(argv):
                fail("--proxy requires a value.")
            proxy_url = argv[index].strip()
        else:
            fail(f"Unknown argument: {arg}")
        index += 1

    return CliOptions(directory=directory, debug=debug, debug_log_path=debug_log_path, proxy_url=proxy_url)


def is_help_invocation(argv: Sequence[str]) -> bool:
    return any(arg in {"-h", "--help"} for arg in argv)


def script_invocation_command() -> str:
    invocation = sys.argv[0] or "codex-auth"
    if "/" in invocation:
        return str(Path(invocation).resolve())
    return invocation


def ensure_network_guard(argv: Sequence[str]) -> None:
    if os.environ.get(NETWORK_GUARD_ACTIVE_ENV_VAR) == "1" or is_help_invocation(argv):
        return

    command = [NETWORK_GUARD_COMMAND, "exec", "--", script_invocation_command(), *argv]
    try:
        os.execvp(command[0], command)
    except OSError as error:
        fail(f"Could not start {NETWORK_GUARD_COMMAND}: {error}")



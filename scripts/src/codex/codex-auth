    return "\n".join(lines)


def active_auth_file(auth_files: Sequence[AuthFile]) -> AuthFile | None:
    return next((auth_file for auth_file in auth_files if auth_file.is_active), None)


def auth_menu_choices(auth_files: Sequence[AuthFile]) -> list[AuthChoice]:

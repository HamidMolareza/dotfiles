def format_open_codex_summary(groups: Sequence[CodexProcessGroup]) -> str:
    if not groups:
        return EMPTY_CELL
    in_progress_count = sum(1 for group in groups if group.state == CODEX_STATE_IN_PROGRESS)
    return f"Codex running: {len(groups)}, in progress: {in_progress_count}"


def picker_title(process_summary: str = EMPTY_CELL) -> str:
    message = f"{MENU_TITLE}\n"
    if process_summary:
        message += f"{process_summary}\n"
    return f"{message}\n"


def picker_message(auth_files: Sequence[AuthFile], process_summary: str = EMPTY_CELL) -> str:
    message = picker_title(process_summary)
    if active_auth_file(auth_files) is None:
        message += f"No active {ACTIVE_NAME} file found. Select a file to make it active.\n\n"
    message += f"{menu_header()}\n{menu_separator()}"
    return message


def list_auth_files(directory: Path) -> list[AuthFile]:
    if not directory.exists():
        fail(f"Directory does not exist: {directory}")
    if not directory.is_dir():
        fail(f"Not a directory: {directory}")

    matched_paths = [
        path
        for path in directory.iterdir()
        if path.is_file() and AUTH_PATTERN.fullmatch(path.name) is not None
    ]

    metadata_by_email = load_account_metadata_store(directory)
    migrated_legacy_metadata = False
    auth_files = []
    for path in sorted(matched_paths, key=lambda item: auth_sort_key(item.name)):
        suffix = path.name.removeprefix(ACTIVE_NAME)
        stat_result = path.stat()
        email = extract_auth_email(path)
        metadata = load_account_metadata(path, email, metadata_by_email)
        migrated_legacy_metadata = (
            migrate_legacy_account_metadata(path, email, metadata, metadata_by_email) or migrated_legacy_metadata
        )
        auth_files.append(
            AuthFile(
                path=path,
                suffix=suffix,
                is_active=path.name == ACTIVE_NAME,
                last_used_at=stat_result.st_mtime,
                size_bytes=stat_result.st_size,
                mtime_ns=stat_result.st_mtime_ns,
                email=email,
                metadata=metadata,
            )
        )

    if migrated_legacy_metadata and metadata_by_email is not None:
        try:
            write_account_metadata_store(directory, metadata_by_email)
        except OSError as error:
            debug_exception("failed to save migrated legacy account metadata", error, directory=directory)

    if not auth_files:
        fail(f"No auth files matching auth.json or auth.json<number> found in {directory}.")

    active_count = sum(1 for auth_file in auth_files if auth_file.is_active)
    if active_count > 1:
        fail(
            "\n".join(
                (
                    f"Expected at most one active {ACTIVE_NAME} file in {directory}, found {active_count}.",
                    "",
                    format_auth_file_list(auth_files),
                )
            )
        )

    return auth_files


def load_quota_cache() -> dict[str, dict[str, Any]]:
    try:
        payload = json.loads(CACHE_FILE.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return {}
    except (OSError, json.JSONDecodeError):
        return {}

    if payload.get("version") != CACHE_VERSION:
        return {}

    entries = payload.get("entries")
    if not isinstance(entries, dict):
        return {}

    valid_entries: dict[str, dict[str, Any]] = {}
    for key, value in entries.items():
        if isinstance(key, str) and isinstance(value, dict):
            valid_entries[key] = value
    return valid_entries


def save_quota_cache(entries: dict[str, dict[str, Any]]) -> None:
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    temp_path = CACHE_FILE.with_name(f"{CACHE_FILE.name}.tmp-{secrets.token_hex(4)}")
    payload = {"version": CACHE_VERSION, "entries": entries}
    temp_path.write_text(json.dumps(payload, separators=(",", ":")), encoding="utf-8")
    os.replace(temp_path, CACHE_FILE)


def cache_key(auth_file: AuthFile) -> str:
    return str(auth_file.path.resolve())


def cache_entry_matches_auth_file(entry: object, auth_file: AuthFile) -> bool:
    return (
        isinstance(entry, dict)
        and entry.get("mtime_ns") == auth_file.mtime_ns
        and entry.get("size_bytes") == auth_file.size_bytes
    )


def cached_email(cache: dict[str, dict[str, Any]], auth_file: AuthFile) -> str:
    entry = cache.get(cache_key(auth_file))
    if not cache_entry_matches_auth_file(entry, auth_file):
        return EMPTY_CELL

    email = entry.get("email")
    return email if isinstance(email, str) else EMPTY_CELL


def cached_quota_view(
    cache: dict[str, dict[str, Any]],
    auth_file: AuthFile,
    now: float,
    *,
    allow_stale: bool,
) -> QuotaView | None:
    entry = cache.get(cache_key(auth_file))
    if not cache_entry_matches_auth_file(entry, auth_file):
        return None

    quota = QuotaView.from_cache_value(entry.get("quota"))
    fetched_at = entry.get("fetched_at")
    if quota is None or not isinstance(fetched_at, (int, float)):
        return None

    if not quota.is_data_view() and not is_cacheable_status(quota.primary_left):
        return None

    if not allow_stale and now - float(fetched_at) > CACHE_TTL_SECONDS:
        return None

    return quota


def update_cached_email(cache: dict[str, dict[str, Any]], auth_file: AuthFile) -> bool:
    if not auth_file.email:
        return False

    key = cache_key(auth_file)
    existing = cache.get(key)
    if cache_entry_matches_auth_file(existing, auth_file):
        entry = dict(existing)
    else:
        entry = {
            "mtime_ns": auth_file.mtime_ns,
            "size_bytes": auth_file.size_bytes,
        }

    if entry.get("email") == auth_file.email:
        return False

    entry["email"] = auth_file.email
    cache[key] = entry
    return True


def update_quota_cache_entry(
    cache: dict[str, dict[str, Any]], auth_file: AuthFile, quota: QuotaView, fetched_at: float
) -> None:
    key = cache_key(auth_file)
    existing = cache.get(key)
    entry = dict(existing) if cache_entry_matches_auth_file(existing, auth_file) else {}
    entry.update(
        {
            "mtime_ns": auth_file.mtime_ns,
            "size_bytes": auth_file.size_bytes,
            "quota": quota.to_cache_value(),
            "fetched_at": fetched_at,
        }
    )
    if auth_file.email:
        entry["email"] = auth_file.email
    cache[key] = entry


def load_chatgpt_base_url(directory: Path) -> str:
    config_file = directory / "config.toml"
    if not config_file.exists():
        debug_log("using default ChatGPT base URL", config_file=config_file, base_url=DEFAULT_CHATGPT_BASE_URL)
        return DEFAULT_CHATGPT_BASE_URL

    try:
        config = tomllib.loads(config_file.read_text(encoding="utf-8"))
    except (OSError, tomllib.TOMLDecodeError):
        debug_log("failed to read config.toml, using default base URL", config_file=config_file)
        return DEFAULT_CHATGPT_BASE_URL

    base_url = config.get("chatgpt_base_url")
    if not isinstance(base_url, str) or not base_url.strip():
        debug_log("config.toml missing chatgpt_base_url, using default base URL", config_file=config_file)
        return DEFAULT_CHATGPT_BASE_URL

    normalized = base_url.rstrip("/")
    if (
        normalized.startswith("https://chatgpt.com")
        or normalized.startswith("https://chat.openai.com")
    ) and "/backend-api" not in normalized:
        normalized = f"{normalized}/backend-api"

    debug_log("loaded ChatGPT base URL", config_file=config_file, base_url=normalized)
    return normalized


def load_usage_proxy_config(directory: Path, override: str | None) -> UsageProxyConfig:
    if override is not None:
        proxy_config = usage_proxy_from_value(override)
        debug_log("using proxy override", proxy=proxy_config.display)
        return proxy_config

    config_file = directory / "config.toml"
    if not config_file.exists():
        debug_log(
            "using default usage proxy",
            config_file=config_file,
            proxy=DEFAULT_USAGE_PROXY_DISPLAY,
        )
        return default_usage_proxy_config()

    try:
        config = tomllib.loads(config_file.read_text(encoding="utf-8"))
    except (OSError, tomllib.TOMLDecodeError):
        debug_log(
            "failed to read config.toml, using default usage proxy",
            config_file=config_file,
            proxy=DEFAULT_USAGE_PROXY_DISPLAY,
        )
        return default_usage_proxy_config()

    proxy_value = config.get("chatgpt_proxy")
    if proxy_value is None:
        proxy_value = config.get("chatgpt_proxy_url")

    if proxy_value is None:
        debug_log(
            "config.toml missing chatgpt_proxy, using default usage proxy",
            config_file=config_file,
            proxy=DEFAULT_USAGE_PROXY_DISPLAY,
        )
        return default_usage_proxy_config()

    if not isinstance(proxy_value, str):
        debug_log(
            "config.toml chatgpt_proxy was not a string, using default usage proxy",
            config_file=config_file,
            proxy=DEFAULT_USAGE_PROXY_DISPLAY,
        )
        return default_usage_proxy_config()

    proxy_config = usage_proxy_from_value(proxy_value)
    debug_log("loaded usage proxy from config", config_file=config_file, proxy=proxy_config.display)
    return proxy_config


def usage_endpoint_for_base_url(base_url: str) -> str:
    if "/backend-api" in base_url:
        return f"{base_url}/wham/usage"
    return f"{base_url}/api/codex/usage"


def decode_jwt_payload(jwt: str) -> dict[str, Any] | None:
    parts = jwt.split(".")
    if len(parts) != 3:
        return None

    payload = parts[1]
    padding = "=" * (-len(payload) % 4)
    try:
        decoded = base64.urlsafe_b64decode(f"{payload}{padding}")
        parsed = json.loads(decoded.decode("utf-8"))
    except (ValueError, json.JSONDecodeError, UnicodeDecodeError):
        return None

    return parsed if isinstance(parsed, dict) else None


def is_access_token_expired(access_token: str) -> bool:
    payload = decode_jwt_payload(access_token)
    if payload is None:
        return False

    exp = payload.get("exp")
    return isinstance(exp, (int, float)) and float(exp) <= time.time()


def extract_auth_email(auth_file: Path) -> str:
    try:
        payload = load_auth_payload(auth_file)
    except QuotaProbeError:
        return EMPTY_CELL

    tokens = payload.get("tokens")
    if not isinstance(tokens, dict):
        return EMPTY_CELL

    id_token = tokens.get("id_token")
    if not isinstance(id_token, str) or not id_token:
        return EMPTY_CELL

    claims = decode_jwt_payload(id_token)
    if claims is None:
        return EMPTY_CELL

    for key in ("email", "preferred_username", "upn"):
        value = claims.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip()

    return EMPTY_CELL


def format_window_left(window: object) -> str | None:
    if not isinstance(window, dict):
        return None

    used_percent = window.get("used_percent", window.get("usedPercent"))
    if not isinstance(used_percent, (int, float)):
        return None

    remaining_percent = max(0, 100 - int(round(float(used_percent))))
    return f"{remaining_percent}%"


def extract_window_reset_timestamp(window: object) -> float | None:
    if not isinstance(window, dict):
        return None

    reset_at = window.get("reset_at", window.get("resetAt", window.get("resets_at", window.get("resetsAt"))))
    if isinstance(reset_at, (int, float)) and float(reset_at) > 0:
        return float(reset_at)

    reset_after = window.get("reset_after_seconds", window.get("resetAfterSeconds"))
    if isinstance(reset_after, (int, float)) and float(reset_after) > 0:
        return time.time() + float(reset_after)

    return None


def format_window_reset(window: object) -> str:
    timestamp = extract_window_reset_timestamp(window)
    if timestamp is None:
        return EMPTY_CELL
    return format_reset_timestamp(timestamp)


def select_rate_limit_snapshot(payload: dict[str, Any]) -> dict[str, Any]:
    rate_limit = payload.get("rate_limit")
    if isinstance(rate_limit, dict):
        return {
            "primary": rate_limit.get("primary_window"),
            "secondary": rate_limit.get("secondary_window"),
            "credits": payload.get("credits"),
        }

    debug_log("usage payload missing rate_limit object", payload_keys=sorted(payload.keys()))
    raise QuotaProbeError(BAD_RESPONSE, transient=True)


def format_quota_view(payload: dict[str, Any]) -> QuotaView:
    snapshot = select_rate_limit_snapshot(payload)

    primary_left = format_window_left(snapshot.get("primary"))
    secondary_left = format_window_left(snapshot.get("secondary"))
    primary_reset_at = extract_window_reset_timestamp(snapshot.get("primary"))
    secondary_reset_at = extract_window_reset_timestamp(snapshot.get("secondary"))
    if primary_left or secondary_left:
        debug_log(
            "formatted quota windows",
            primary_left=primary_left or EMPTY_CELL,
            primary_reset_at=primary_reset_at,
            secondary_left=secondary_left or EMPTY_CELL,
            secondary_reset_at=secondary_reset_at,
        )
        return QuotaView(
            primary_left=primary_left or EMPTY_CELL,
            primary_reset=format_reset_timestamp(primary_reset_at) if primary_left and primary_reset_at is not None else EMPTY_CELL,
            secondary_left=secondary_left or EMPTY_CELL,
            secondary_reset=(
                format_reset_timestamp(secondary_reset_at) if secondary_left and secondary_reset_at is not None else EMPTY_CELL
            ),
            primary_left_percent=parse_remaining_percent(primary_left),
            primary_reset_at=primary_reset_at if primary_left else None,
            secondary_left_percent=parse_remaining_percent(secondary_left),
            secondary_reset_at=secondary_reset_at if secondary_left else None,
        )

    credits = snapshot.get("credits")
    if isinstance(credits, dict):
        if credits.get("unlimited") is True:
            debug_log("usage payload reported unlimited credits")
            return QuotaView.status("unlimited")

        balance = credits.get("balance")
        if isinstance(balance, str) and balance.strip() and balance.strip() not in {"0", "0.0"}:
            debug_log("usage payload reported credits balance", balance=balance.strip())
            return QuotaView.status(f"credits {balance.strip()}")

    debug_log("usage payload had no usable quota windows or credits", snapshot=snapshot)
    return QuotaView.status(QUOTA_UNKNOWN)


def load_auth_payload(auth_file: Path) -> dict[str, Any]:
    try:
        payload = json.loads(auth_file.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        raise QuotaProbeError(INVALID_AUTH) from error
    if not isinstance(payload, dict):
        raise QuotaProbeError(INVALID_AUTH)
    return payload


def auth_mode_from_payload(payload: dict[str, Any]) -> str:
    mode = payload.get("auth_mode")
    if isinstance(mode, str) and mode:
        return mode
    if payload.get("OPENAI_API_KEY"):
        return "api_key"
    return "chatgpt"


def usage_request_headers(access_token: str, account_id: str | None) -> dict[str, str]:
    headers = {
        "Authorization": f"Bearer {access_token}",
        "User-Agent": "codex-cli",
    }
    if account_id:
        headers["ChatGPT-Account-Id"] = account_id
    return headers


def retry_delay_seconds(attempt_index: int) -> float:
    return HTTP_RETRY_BASE_DELAY_SECONDS * (2**attempt_index)


def should_retry_http_status(status_code: int) -> bool:
    return status_code in {408, 425, 429, 502, 503, 504} or status_code >= 500


def is_timeout_reason(reason: object) -> bool:
    return isinstance(reason, TimeoutError | socket.timeout)


def is_network_reason(reason: object) -> bool:
    return isinstance(
        reason,
        (
            ConnectionError,
            ConnectionResetError,
            ConnectionAbortedError,
            ConnectionRefusedError,
            socket.gaierror,
            ssl.SSLError,
            OSError,
        ),
    )


def build_usage_opener(proxy_config: UsageProxyConfig):
    if proxy_config.use_environment:
        return urllib_request.build_opener(urllib_request.ProxyHandler())
    proxies = {} if proxy_config.proxy_url is None else {"http": proxy_config.proxy_url, "https": proxy_config.proxy_url}
    return urllib_request.build_opener(urllib_request.ProxyHandler(proxies))


def fetch_usage_payload(url: str, headers: dict[str, str], proxy_config: UsageProxyConfig) -> dict[str, Any]:
    last_error: Exception | None = None

    for attempt_index in range(HTTP_RETRY_ATTEMPTS):
        request = urllib_request.Request(url, headers=headers)
        opener = build_usage_opener(proxy_config)
        debug_log(
            "usage request attempt",
            attempt=attempt_index + 1,
            max_attempts=HTTP_RETRY_ATTEMPTS,
            proxy=proxy_config.display,
            timeout_seconds=HTTP_TIMEOUT_SECONDS,
            url=url,
        )
        try:
            with opener.open(request, timeout=HTTP_TIMEOUT_SECONDS) as response:
                body = response.read().decode("utf-8")
                debug_log(
                    "usage request succeeded",
                    attempt=attempt_index + 1,
                    payload_preview=body,
                    status=getattr(response, "status", EMPTY_CELL),
                )
            payload = json.loads(body)
            if isinstance(payload, dict):
                debug_log("usage payload parsed", attempt=attempt_index + 1, payload_keys=sorted(payload.keys()))
                return payload
            debug_log("usage payload was not a JSON object", payload_type=type(payload).__name__)
            raise QuotaProbeError(BAD_RESPONSE, transient=True)
        except urllib_error.HTTPError as error:
            last_error = error
            debug_log(
                "usage request HTTP error",
                attempt=attempt_index + 1,
                body_preview=error_body_preview(error),
                retryable=should_retry_http_status(error.code),
                status=error.code,
                url=url,
            )
            if error.code == 401:
                raise QuotaProbeError(UNAUTHORIZED) from error
            if error.code == 403:
                raise QuotaProbeError(QUOTA_UNKNOWN, transient=True) from error
            if error.code == 429:
                if attempt_index < HTTP_RETRY_ATTEMPTS - 1:
                    time.sleep(retry_delay_seconds(attempt_index))
                    continue
                raise QuotaProbeError(RATE_LIMITED, transient=True) from error
            if should_retry_http_status(error.code) and attempt_index < HTTP_RETRY_ATTEMPTS - 1:
                time.sleep(retry_delay_seconds(attempt_index))
                continue
            raise QuotaProbeError(f"http {error.code}", transient=should_retry_http_status(error.code)) from error
        except urllib_error.URLError as error:
            last_error = error
            reason = error.reason
            debug_log(
                "usage request URL error",
                attempt=attempt_index + 1,
                reason=reason,
                retryable=is_timeout_reason(reason) or is_network_reason(reason),
                timeout=is_timeout_reason(reason),
                url=url,
            )
            if is_timeout_reason(reason):
                if attempt_index < HTTP_RETRY_ATTEMPTS - 1:
                    time.sleep(retry_delay_seconds(attempt_index))
                    continue
                raise QuotaProbeError(TIMEOUT, transient=True) from error
            if is_network_reason(reason):
                if attempt_index < HTTP_RETRY_ATTEMPTS - 1:
                    time.sleep(retry_delay_seconds(attempt_index))
                    continue
                raise QuotaProbeError(NETWORK_ERROR, transient=True) from error
            raise QuotaProbeError(NETWORK_ERROR, transient=True) from error
        except (TimeoutError, socket.timeout) as error:
            last_error = error
            debug_log("usage request timeout", attempt=attempt_index + 1, error=error, url=url)
            if attempt_index < HTTP_RETRY_ATTEMPTS - 1:
                time.sleep(retry_delay_seconds(attempt_index))
                continue
            raise QuotaProbeError(TIMEOUT, transient=True) from error
        except (UnicodeDecodeError, json.JSONDecodeError) as error:
            last_error = error
            debug_log("usage response decode failure", attempt=attempt_index + 1, error=error, url=url)
            if attempt_index < HTTP_RETRY_ATTEMPTS - 1:
                time.sleep(retry_delay_seconds(attempt_index))
                continue
            raise QuotaProbeError(BAD_RESPONSE, transient=True) from error

    if last_error is not None:
        raise QuotaProbeError(NETWORK_ERROR, transient=True) from last_error
    raise QuotaProbeError(NETWORK_ERROR, transient=True)


def probe_quota_view(auth_file: AuthFile, directory: Path, proxy_config: UsageProxyConfig) -> ProbeOutcome:
    access_token = ""
    try:
        auth_payload = load_auth_payload(auth_file.path)
        auth_mode = auth_mode_from_payload(auth_payload)
        debug_log("probing auth file", auth_file=auth_file.name, auth_mode=auth_mode, directory=directory)
        if auth_mode == "api_key":
            return ProbeOutcome.status(API_KEY_AUTH)

        tokens = auth_payload.get("tokens")
        if not isinstance(tokens, dict):
            return ProbeOutcome.status(MISSING_TOKEN)

        access_token = tokens.get("access_token")
        if not isinstance(access_token, str) or not access_token:
            return ProbeOutcome.status(MISSING_TOKEN)

        if is_access_token_expired(access_token):
            return ProbeOutcome.status(TOKEN_EXPIRED)

        base_url = load_chatgpt_base_url(directory)
        endpoint = usage_endpoint_for_base_url(base_url)
        account_id = tokens.get("account_id")
        account_id = account_id if isinstance(account_id, str) and account_id else None
        debug_log(
            "prepared usage probe",
            auth_file=auth_file.name,
            endpoint=endpoint,
            has_account_id=account_id is not None,
            proxy=proxy_config.display,
        )

        payload = fetch_usage_payload(endpoint, usage_request_headers(access_token, account_id), proxy_config)
        quota = format_quota_view(payload)
        debug_log("probe completed", auth_file=auth_file.name, status=quota.primary_left)
        return ProbeOutcome(quota, server_confirmed=True)
    except QuotaProbeError as error:
        status = error.status
        if status == UNAUTHORIZED and is_access_token_expired(access_token):
            status = TOKEN_EXPIRED
        debug_log(
            "probe failed with quota probe error",
            auth_file=auth_file.name,
            status=status,
            transient=error.transient,
        )
        return ProbeOutcome.status(status, cacheable=not error.transient)
    except Exception as error:
        debug_exception("probe failed with unexpected exception", error, auth_file=auth_file.name)
        return ProbeOutcome.status(PROBE_ERROR, cacheable=False)


def enrich_auth_files_with_quota(
    auth_files: Sequence[AuthFile], directory: Path, proxy_config: UsageProxyConfig
) -> list[AuthFile]:
    cache = load_quota_cache()
    now = time.time()
    updated_cache = dict(cache)
    cache_changed = False

    enriched_auth_files: list[AuthFile] = []
    files_to_probe: list[AuthFile] = []
    stale_fallbacks: dict[Path, QuotaView] = {}
    metadata_by_email: dict[str, AccountMetadata] | None = None
    metadata_store_loaded = False
    metadata_store_changed = False

    for auth_file in auth_files:
        fallback_email = cached_email(cache, auth_file)
        if not auth_file.email and fallback_email:
            auth_file = replace(auth_file, email=fallback_email)
        if auth_file.email and not auth_file.metadata.has_values() and not auth_file.metadata.error:
            if not metadata_store_loaded:
                metadata_by_email = load_account_metadata_store(directory)
                metadata_store_loaded = True
            metadata = load_account_metadata(auth_file.path, auth_file.email, metadata_by_email)
            metadata_store_changed = (
                migrate_legacy_account_metadata(auth_file.path, auth_file.email, metadata, metadata_by_email)
                or metadata_store_changed
            )
            auth_file = replace(auth_file, metadata=metadata)
        if update_cached_email(updated_cache, auth_file):
            cache_changed = True

        cached_quota = cached_quota_view(cache, auth_file, now, allow_stale=False)
        if cached_quota is not None:
            debug_log("using fresh cached quota", auth_file=auth_file.name, status=cached_quota.primary_left)
            enriched_auth_files.append(
                replace(auth_file, quota=cached_quota, quota_server_confirmed=is_server_confirmed_quota(cached_quota))
            )
            continue

        stale_quota = cached_quota_view(cache, auth_file, now, allow_stale=True)
        if stale_quota is not None:
            debug_log("using stale quota as fallback candidate", auth_file=auth_file.name, status=stale_quota.primary_left)
            stale_fallbacks[auth_file.path] = stale_quota

        files_to_probe.append(auth_file)

    probed_outcomes: dict[Path, ProbeOutcome] = {}
    if files_to_probe:
        max_workers = min(MAX_CONCURRENT_PROBES, len(files_to_probe))
        with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as executor:
            future_to_auth = {
                executor.submit(probe_quota_view, auth_file, directory, proxy_config): auth_file
                for auth_file in files_to_probe
            }
            for future in concurrent.futures.as_completed(future_to_auth):
                auth_file = future_to_auth[future]
                try:
                    outcome = future.result()
                except Exception:
                    outcome = ProbeOutcome.status(PROBE_ERROR, cacheable=False)

                probed_outcomes[auth_file.path] = outcome
                if outcome.cacheable:
                    update_quota_cache_entry(updated_cache, auth_file, outcome.quota, time.time())
                    cache_changed = True

    if cache_changed:
        try:
            save_quota_cache(updated_cache)
        except OSError:
            pass

    if metadata_store_changed and metadata_by_email is not None:
        try:
            write_account_metadata_store(directory, metadata_by_email)
        except OSError as error:
            debug_exception("failed to save migrated legacy account metadata", error, directory=directory)

    enriched_by_path = {auth_file.path: auth_file for auth_file in enriched_auth_files}
    for auth_file in files_to_probe:
        outcome = probed_outcomes.get(auth_file.path)
        stale_quota = stale_fallbacks.get(auth_file.path)
        if outcome is None:
            quota = stale_quota.with_stale_marker() if stale_quota is not None else QuotaView.status(PROBE_ERROR)
            debug_log("probe outcome missing, using fallback", auth_file=auth_file.name, status=quota.primary_left)
        elif not outcome.cacheable and stale_quota is not None:
            quota = stale_quota.with_stale_marker()
            debug_log(
                "probe returned transient failure, using stale fallback",
                auth_file=auth_file.name,
                fallback_status=quota.primary_left,
                live_status=outcome.quota.primary_left,
            )
        else:
            quota = outcome.quota
            debug_log("using live probe quota", auth_file=auth_file.name, status=quota.primary_left)
        enriched_by_path[auth_file.path] = replace(
            auth_file,
            quota=quota,
            quota_server_confirmed=outcome.server_confirmed if outcome is not None else False,
        )

    final_auth_files = [enriched_by_path[auth_file.path] for auth_file in auth_files]
    return sorted(final_auth_files, key=auth_priority_key)


def is_server_confirmed_quota(quota: QuotaView) -> bool:
    return quota.is_data_view() or quota.primary_left == "unlimited" or quota.primary_left.startswith("credits ")


def quota_priority_key(auth_file: AuthFile) -> tuple[int | float, ...]:
    quota = auth_file.quota
    return (
        0 if quota.secondary_reset_at is not None else 1,
        quota.secondary_reset_at if quota.secondary_reset_at is not None else float("inf"),
        0 if quota.primary_reset_at is not None else 1,
        quota.primary_reset_at if quota.primary_reset_at is not None else float("inf"),
        quota.secondary_left_percent if quota.secondary_left_percent is not None else 101,
        quota.primary_left_percent if quota.primary_left_percent is not None else 101,
        *auth_sort_key(auth_file.name),
    )


def auth_priority_key(auth_file: AuthFile) -> tuple[int | float, ...]:
    expires_on = account_expiration_date(auth_file.metadata)
    today = datetime.now().astimezone().date()
    if expires_on is None:
        return (2, 0, *quota_priority_key(auth_file))
    if expires_on < today:
        if auth_file.quota_server_confirmed:
            return (0, 0, *quota_priority_key(auth_file))
        return (3, 0, *quota_priority_key(auth_file))
    return (1, expires_on.toordinal(), *quota_priority_key(auth_file))


def fallback_choice(
    auth_files: Sequence[AuthFile],
    tty_input,
    tty_output,
    process_summary: str = EMPTY_CELL,
) -> AuthChoice:
    active_auth = active_auth_file(auth_files)
    choices = auth_menu_choices(auth_files)
    tty_output.write(picker_title(process_summary))
    if active_auth is None:
        tty_output.write(f"No active {ACTIVE_NAME} file found. Select a file to make it active.\n\n")
    tty_output.write(f"      {menu_header()}\n")
    tty_output.write(f"      {menu_separator()}\n")
    for index, choice in enumerate(choices, start=1):
        tty_output.write(f"  {index:>2}. {choice.fallback_label()}\n")
    tty_output.write("\n")
    tty_output.write("      * stale cache, reset columns show time remaining\n\n")
    tty_output.flush()

    while True:
        if active_auth is None:
            prompt = f"Select an option [1-{len(choices)}] (Ctrl-C cancels): "
        else:
            prompt = f"Select an option [1-{len(choices)}] (Enter keeps current, Ctrl-C cancels): "
        tty_output.write(prompt)
        tty_output.flush()
        selection = tty_input.readline()
        if selection == "":
            fail("Interactive auth picker was interrupted.", exit_code=130)

        selection = selection.strip()
        if not selection:
            if active_auth is not None:
                return active_auth

        if selection.isdigit():
            selected_index = int(selection)
            if 1 <= selected_index <= len(choices):
                return choices[selected_index - 1]

        tty_output.write("Invalid selection. Please enter one of the listed numbers.\n")
        tty_output.flush()


def prompt_toolkit_choice(
    auth_files: Sequence[AuthFile],
    tty_input,
    tty_output,
    process_summary: str = EMPTY_CELL,
) -> AuthChoice:
    from prompt_toolkit.application.current import create_app_session
    from prompt_toolkit.input.defaults import create_input
    from prompt_toolkit.output.defaults import create_output
    from prompt_toolkit.shortcuts import choice
    from prompt_toolkit.styles import Style

    style = Style.from_dict(
        {
            "frame.border": "#334155",
            "frame.label": "bold #93c5fd",
            "text-area": "bg:#111827 #e5e7eb",
            "text-area.prompt": "bold #fbbf24",
            "selected-option": "bg:#22c55e #052e16 bold",
            "line": "#94a3b8",
            "bottom-toolbar": "bg:#0f172a #cbd5e1",
        }
    )

    tty_ui_input = create_input(stdin=tty_input, always_prefer_tty=True)
    tty_ui_output = create_output(stdout=tty_output, always_prefer_tty=True)
    choices = auth_menu_choices(auth_files)

    try:
        with create_app_session(input=tty_ui_input, output=tty_ui_output):
            result = choice(
                message=picker_message(auth_files, process_summary),
                options=[(item, item.prompt_toolkit_label()) for item in choices],
                default=active_auth_file(auth_files) or choices[0],
                style=style,
                symbol=">",
                show_frame=True,
                bottom_toolbar="Enter selects  Ctrl-C cancels  * stale cache  Reset columns show time remaining",
            )
    except KeyboardInterrupt:
        fail("Interactive auth picker was cancelled.", exit_code=130)
    finally:
        tty_ui_input.close()

    if result is None:
        fail("Interactive auth picker was cancelled.", exit_code=130)

    return result


def choose_auth_file(auth_files: Sequence[AuthFile], process_summary: str = EMPTY_CELL) -> AuthChoice:
    try:
        tty_input = open("/dev/tty", "r", encoding="utf-8")
        tty_output = open("/dev/tty", "w", encoding="utf-8")
    except OSError:
        fail("Interactive auth picker requires a terminal.")


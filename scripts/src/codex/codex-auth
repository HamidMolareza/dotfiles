def format_timestamp(timestamp: float) -> str:
    return datetime.fromtimestamp(timestamp).astimezone().strftime("%Y-%m-%d %H:%M")


def format_reset_timestamp(timestamp: float) -> str:
    remaining_seconds = max(0, int(round(timestamp - time.time())))
    if remaining_seconds < 60:
        return "now"

    total_minutes, _ = divmod(remaining_seconds, 60)
    total_hours, minutes = divmod(total_minutes, 60)
    days, hours = divmod(total_hours, 24)

    if days > 0:
        return f"{days}d {hours}h"
    if total_hours > 0:
        return f"{total_hours}h {minutes}m"
    return f"{total_minutes}m"


def parse_reset_timestamp_value(value: object) -> float | None:
    if isinstance(value, (int, float)) and float(value) > 0:
        return float(value)
    return None


def parse_remaining_percent(value: object) -> int | None:
    if isinstance(value, (int, float)):
        percent = int(round(float(value)))
        return max(0, min(100, percent))
    if not isinstance(value, str):
        return None

    match = re.fullmatch(r"\s*(\d{1,3})%\*?\s*", value)
    if match is None:
        return None

    percent = int(match.group(1))
    return max(0, min(100, percent))


def parse_reset_display(value: str) -> float | None:
    stripped = value.strip()
    if not stripped:
        return None
    if stripped == "now":
        return time.time()

    total_seconds = 0
    for amount, unit in re.findall(r"(\d+)\s*([dhm])", stripped):
        factor = {"d": 86400, "h": 3600, "m": 60}[unit]
        total_seconds += int(amount) * factor

    if total_seconds <= 0:
        return None

    return time.time() + total_seconds


def truncate_text(value: str, width: int) -> str:
    if len(value) <= width:
        return value
    if width <= 3:
        return value[:width]
    return f"{value[: width - 3]}..."


def color_style_for_percent(percent: int | None) -> str:
    if percent is None:
        return ""
    if percent <= 33:
        return "red"
    if percent <= 66:
        return "yellow"
    return "green"


def ansi_code_for_style(style_name: str) -> str:
    return {
        "red": ANSI_RED,
        "yellow": ANSI_YELLOW,
        "green": ANSI_GREEN,
    }.get(style_name, "")


def format_plain_cell(value: str, width: int) -> str:
    return f"{truncate_text(value, width):<{width}}"


def format_ansi_percent_cell(value: str, percent: int | None, width: int) -> str:
    text = truncate_text(value, width)
    padded = f"{text:<{width}}"
    color_name = color_style_for_percent(percent)
    ansi_code = ansi_code_for_style(color_name)
    if not ansi_code:
        return padded
    return f"{ansi_code}{padded}{ANSI_RESET}"


def format_prompt_fragments(value: str, width: int, style: str = "") -> list[tuple[str, str]]:
    return [(style, format_plain_cell(value, width))]


def format_prompt_percent_fragments(
    value: str, percent: int | None, width: int, *, override_style: str = ""
) -> list[tuple[str, str]]:
    color_name = color_style_for_percent(percent)
    style = override_style or (f"fg:{color_name}" if color_name else "")
    return format_prompt_fragments(value, width, style=style)



@dataclass(frozen=True)
class QuotaView:
    primary_left: str = EMPTY_CELL
    primary_reset: str = EMPTY_CELL
    secondary_left: str = EMPTY_CELL
    secondary_reset: str = EMPTY_CELL
    primary_left_percent: int | None = None
    primary_reset_at: float | None = None
    secondary_left_percent: int | None = None
    secondary_reset_at: float | None = None

    @classmethod
    def status(cls, value: str) -> "QuotaView":
        return cls(primary_left=value)

    @classmethod
    def from_cache_value(cls, value: object) -> "QuotaView | None":
        if not isinstance(value, dict):
            return None
        primary_left = value.get("primary_left", EMPTY_CELL)
        primary_reset = value.get("primary_reset", EMPTY_CELL)
        secondary_left = value.get("secondary_left", EMPTY_CELL)
        secondary_reset = value.get("secondary_reset", EMPTY_CELL)
        if not all(isinstance(item, str) for item in (primary_left, primary_reset, secondary_left, secondary_reset)):
            return None
        primary_left_percent = parse_remaining_percent(value.get("primary_left_percent", primary_left))
        primary_reset_at = parse_reset_timestamp_value(value.get("primary_reset_at"))
        secondary_left_percent = parse_remaining_percent(value.get("secondary_left_percent", secondary_left))
        secondary_reset_at = parse_reset_timestamp_value(value.get("secondary_reset_at"))

        if primary_reset_at is None:
            primary_reset_at = parse_reset_display(primary_reset)
        if secondary_reset_at is None:
            secondary_reset_at = parse_reset_display(secondary_reset)

        return cls(
            primary_left=primary_left,
            primary_reset=format_reset_timestamp(primary_reset_at) if primary_reset_at is not None else primary_reset,
            secondary_left=secondary_left,
            secondary_reset=(
                format_reset_timestamp(secondary_reset_at) if secondary_reset_at is not None else secondary_reset
            ),
            primary_left_percent=primary_left_percent,
            primary_reset_at=primary_reset_at,
            secondary_left_percent=secondary_left_percent,
            secondary_reset_at=secondary_reset_at,
        )

    def to_cache_value(self) -> dict[str, str | int | float]:
        value: dict[str, str | int | float] = {
            "primary_left": self.primary_left,
            "primary_reset": self.primary_reset,
            "secondary_left": self.secondary_left,
            "secondary_reset": self.secondary_reset,
        }
        if self.primary_left_percent is not None:
            value["primary_left_percent"] = self.primary_left_percent
        if self.primary_reset_at is not None:
            value["primary_reset_at"] = self.primary_reset_at
        if self.secondary_left_percent is not None:
            value["secondary_left_percent"] = self.secondary_left_percent
        if self.secondary_reset_at is not None:
            value["secondary_reset_at"] = self.secondary_reset_at
        return value

    def with_stale_marker(self) -> "QuotaView":
        def mark(value: str) -> str:
            if not value or value.endswith("*"):
                return value
            return f"{value}*"

        return replace(
            self,
            primary_left=mark(self.primary_left),
            secondary_left=mark(self.secondary_left),
        )

    def is_data_view(self) -> bool:
        return any(
            value
            for value in (
                self.primary_reset,
                self.secondary_left,
                self.secondary_reset,
            )
        )


@dataclass(frozen=True)
class ProbeOutcome:
    quota: QuotaView
    cacheable: bool = True

    @classmethod
    def status(cls, value: str, *, cacheable: bool = True) -> "ProbeOutcome":
        return cls(quota=QuotaView.status(value), cacheable=cacheable and is_cacheable_status(value))


@dataclass(frozen=True)
class AuthFile:
    path: Path
    suffix: str
    is_active: bool
    last_used_at: float
    size_bytes: int
    mtime_ns: int
    quota: QuotaView = field(default_factory=QuotaView)

    @property
    def name(self) -> str:
        return self.path.name

    @property
    def label(self) -> str:
        status = "[active]" if self.is_active else f"[slot {self.suffix}]"
        last_used = format_timestamp(self.last_used_at)
        quota = self.quota
        return (
            f"{status:<{STATUS_WIDTH}} "
            f"{self.name:<{NAME_WIDTH}} "
            f"{last_used:<{TIME_WIDTH}} "
            f"{truncate_text(quota.primary_left, PRIMARY_LEFT_WIDTH):<{PRIMARY_LEFT_WIDTH}} "
            f"{truncate_text(quota.primary_reset, PRIMARY_RESET_WIDTH):<{PRIMARY_RESET_WIDTH}} "
            f"{truncate_text(quota.secondary_left, SECONDARY_LEFT_WIDTH):<{SECONDARY_LEFT_WIDTH}} "
            f"{truncate_text(quota.secondary_reset, SECONDARY_RESET_WIDTH):<{SECONDARY_RESET_WIDTH}}"
        )


class SwapError(RuntimeError):
    pass


class QuotaProbeError(RuntimeError):
    def __init__(self, status: str, *, transient: bool = False):
        super().__init__(status)
        self.status = status
        self.transient = transient


def is_cacheable_status(status: str) -> bool:
    return status in {
        API_KEY_AUTH,
        MISSING_TOKEN,
        INVALID_AUTH,
        TOKEN_EXPIRED,
    }


def fail(message: str, exit_code: int = 1) -> None:
    print(message, file=sys.stderr)
    raise SystemExit(exit_code)


def show_help() -> None:
    print(
        f"""Usage: codex-auth [OPTIONS]

Switch the active Codex auth file inside {AUTH_DIR}.

Rules:
  - {ACTIVE_NAME} is the active file
  - auth.json<number> files are inactive candidates
  - only one active file exists at a time
  - the menu shows each file's last active time from its modified timestamp
  - the menu shows cached or live remaining quota and reset countdowns for each auth file
  - quota probes use a direct read-only HTTPS request with the current auth token
  - quota probes never trigger token refresh or modify your real auth files
  - transient probe failures keep stale cached quota when available and mark it with *
  - live probe failures can surface as statuses such as token expired, timeout, bad auth, or network error
  - after a successful switch, the newly active file timestamp is updated

Options:
  -d, --dir PATH   Override the auth directory (default: {AUTH_DIR})
  -h, --help       Show this help text
"""
    )


def parse_args(argv: Sequence[str]) -> Path:
    directory = AUTH_DIR
    index = 0

    while index < len(argv):
        arg = argv[index]
        if arg in {"-h", "--help"}:
            show_help()
            raise SystemExit(0)
        if arg in {"-d", "--dir"}:
            index += 1
            if index >= len(argv):
                fail("--dir requires a path value.")
            directory = Path(argv[index]).expanduser()
        else:
            fail(f"Unknown argument: {arg}")
        index += 1

    return directory


def auth_sort_key(name: str) -> tuple[int, int]:
    if name == ACTIVE_NAME:
        return (0, 0)

    suffix = name.removeprefix(ACTIVE_NAME)
    return (1, int(suffix))


def format_timestamp(timestamp: float) -> str:
    return datetime.fromtimestamp(timestamp).astimezone().strftime("%Y-%m-%d %H:%M")


def format_reset_timestamp(timestamp: float) -> str:
    remaining_seconds = max(0, int(round(timestamp - time.time())))
    if remaining_seconds < 60:
        return "now"

    total_minutes, _ = divmod(remaining_seconds, 60)
    total_hours, minutes = divmod(total_minutes, 60)
    days, hours = divmod(total_hours, 24)

    if days > 0:
        return f"{days}d {hours}h"
    if total_hours > 0:
        return f"{total_hours}h {minutes}m"
    return f"{total_minutes}m"


def parse_reset_timestamp_value(value: object) -> float | None:
    if isinstance(value, (int, float)) and float(value) > 0:
        return float(value)
    return None


def parse_remaining_percent(value: object) -> int | None:
    if isinstance(value, (int, float)):
        percent = int(round(float(value)))
        return max(0, min(100, percent))
    if not isinstance(value, str):
        return None

    match = re.fullmatch(r"\s*(\d{1,3})%\*?\s*", value)
    if match is None:
        return None

    percent = int(match.group(1))
    return max(0, min(100, percent))


def parse_reset_display(value: str) -> float | None:
    stripped = value.strip()
    if not stripped:
        return None
    if stripped == "now":
        return time.time()

    total_seconds = 0
    for amount, unit in re.findall(r"(\d+)\s*([dhm])", stripped):
        factor = {"d": 86400, "h": 3600, "m": 60}[unit]
        total_seconds += int(amount) * factor

    if total_seconds <= 0:
        return None

    return time.time() + total_seconds


def truncate_text(value: str, width: int) -> str:
    if len(value) <= width:
        return value
    if width <= 3:
        return value[:width]
    return f"{value[: width - 3]}..."



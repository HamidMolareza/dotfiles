@dataclass(frozen=True)
class AuthFile:
    path: Path
    suffix: str
    is_active: bool
    last_used_at: float
    size_bytes: int
    mtime_ns: int
    email: str = EMPTY_CELL
    metadata: AccountMetadata = field(default_factory=AccountMetadata)
    quota: QuotaView = field(default_factory=QuotaView)
    quota_server_confirmed: bool = False

    @property
    def name(self) -> str:
        return self.path.name

    @property
    def label(self) -> str:
        status = "[active]" if self.is_active else f"[slot {self.suffix}]"
        quota = self.quota
        return (
            f"{status:<{STATUS_WIDTH}} "
            f"{self.name:<{NAME_WIDTH}} "
            f"{truncate_text(quota.primary_left, PRIMARY_LEFT_WIDTH):<{PRIMARY_LEFT_WIDTH}} "
            f"{truncate_text(quota.primary_reset, PRIMARY_RESET_WIDTH):<{PRIMARY_RESET_WIDTH}} "
            f"{truncate_text(quota.secondary_left, SECONDARY_LEFT_WIDTH):<{SECONDARY_LEFT_WIDTH}} "
            f"{truncate_text(quota.secondary_reset, SECONDARY_RESET_WIDTH):<{SECONDARY_RESET_WIDTH}} "
            f"{truncate_text(self.email, EMAIL_WIDTH):<{EMAIL_WIDTH}} "
            f"{truncate_text(format_account_info(self.metadata), ACCOUNT_INFO_WIDTH):<{ACCOUNT_INFO_WIDTH}}"
        )

    def fallback_label(self) -> str:
        status = "[active]" if self.is_active else f"[slot {self.suffix}]"
        quota = self.quota
        is_expired = is_auth_file_expired(self)
        label = "".join(
            (
                format_plain_cell(status, STATUS_WIDTH),
                " ",
                format_plain_cell(self.name, NAME_WIDTH),
                " ",
                (
                    format_plain_cell(quota.primary_left, PRIMARY_LEFT_WIDTH)
                    if is_expired
                    else format_ansi_percent_cell(quota.primary_left, quota.primary_left_percent, PRIMARY_LEFT_WIDTH)
                ),
                " ",
                format_plain_cell(quota.primary_reset, PRIMARY_RESET_WIDTH),
                " ",
                (
                    format_plain_cell(quota.secondary_left, SECONDARY_LEFT_WIDTH)
                    if is_expired
                    else format_ansi_percent_cell(quota.secondary_left, quota.secondary_left_percent, SECONDARY_LEFT_WIDTH)
                ),
                " ",
                format_plain_cell(quota.secondary_reset, SECONDARY_RESET_WIDTH),
                " ",
                format_plain_cell(self.email, EMAIL_WIDTH),
                " ",
                format_plain_cell(format_account_info(self.metadata), ACCOUNT_INFO_WIDTH),
            )
        )
        if is_expired:
            return f"{ANSI_GRAY}{label}{ANSI_RESET}"
        return label

    def prompt_toolkit_label(self) -> list[tuple[str, str]]:
        status = "[active]" if self.is_active else f"[slot {self.suffix}]"
        quota = self.quota
        expired_style = "fg:#64748b" if is_auth_file_expired(self) else ""
        fragments: list[tuple[str, str]] = []
        fragments.extend(format_prompt_fragments(status, STATUS_WIDTH, expired_style))
        fragments.append(("", " "))
        fragments.extend(format_prompt_fragments(self.name, NAME_WIDTH, expired_style))
        fragments.append(("", " "))
        fragments.extend(
            format_prompt_percent_fragments(
                quota.primary_left,
                quota.primary_left_percent,
                PRIMARY_LEFT_WIDTH,
                override_style=expired_style,
            )
        )
        fragments.append(("", " "))
        fragments.extend(format_prompt_fragments(quota.primary_reset, PRIMARY_RESET_WIDTH, expired_style))
        fragments.append(("", " "))
        fragments.extend(
            format_prompt_percent_fragments(
                quota.secondary_left,
                quota.secondary_left_percent,
                SECONDARY_LEFT_WIDTH,
                override_style=expired_style,
            )
        )
        fragments.append(("", " "))
        fragments.extend(format_prompt_fragments(quota.secondary_reset, SECONDARY_RESET_WIDTH, expired_style))
        fragments.append(("", " "))
        fragments.extend(format_prompt_fragments(self.email, EMAIL_WIDTH, expired_style))
        fragments.append(("", " "))
        fragments.extend(format_prompt_fragments(format_account_info(self.metadata), ACCOUNT_INFO_WIDTH, expired_style))
        return fragments



#!/usr/bin/env bash

set -Eeuo pipefail

ADAPTER_BASE_URL="${GAPGPT_ADAPTER_BASE_URL:-http://127.0.0.1:8085}"
MODELS_ENDPOINT="${GAPGPT_ADAPTER_MODELS_URL:-${ADAPTER_BASE_URL%/}/v1/models}"

show_help() {
  cat <<'EOF'
Usage: gapchat [OPTIONS] [PROMPT]

Special behavior:
  Without --model, the model picker opens by default
  --model, -m    Fetch models from the GapGPT adapter and open an interactive picker

Examples:
  gapchat
  gapchat --model
  gapchat -m
  gapchat --model claude-sonnet-4-6

Environment:
  GAPGPT_ADAPTER_API_KEY    Required for fetching models when no explicit model is passed
  GAPGPT_ADAPTER_BASE_URL   Optional, defaults to http://127.0.0.1:8085
  GAPGPT_ADAPTER_MODELS_URL Optional full override for the models endpoint
EOF
}

pick_model() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 is required for the interactive model picker." >&2
    exit 1
  fi

  python3 /dev/fd/3 "$MODELS_ENDPOINT" "${GAPGPT_ADAPTER_API_KEY:-}" 3<<'PY'
import json
import os
import socket
import sys
import urllib.error
import urllib.request
from typing import List


def fail(message: str, exit_code: int = 1) -> None:
    print(message, file=sys.stderr)
    raise SystemExit(exit_code)


def fetch_models(endpoint: str, api_key: str) -> List[str]:
    if not api_key:
        fail(
            "GAPGPT_ADAPTER_API_KEY is not set. Export it before using gapchat without an explicit --model value."
        )

    timeout = float(os.environ.get("GAPGPT_ADAPTER_TIMEOUT", "5"))
    request = urllib.request.Request(
        endpoint,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Accept": "application/json",
        },
        method="GET",
    )

    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            payload = response.read().decode("utf-8")
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace").strip()
        detail = f" Response: {body[:200]}" if body else ""
        fail(
            f"Failed to fetch models from {endpoint}: HTTP {exc.code} {exc.reason}.{detail}"
        )
    except urllib.error.URLError as exc:
        reason = exc.reason
        if isinstance(reason, ConnectionRefusedError):
            fail(
                f"Could not reach the GapGPT adapter at {endpoint}. Is the local adapter running?"
            )
        if isinstance(reason, socket.timeout) or "timed out" in str(reason).lower():
            fail(f"Timed out while fetching models from {endpoint}.")
        fail(f"Failed to fetch models from {endpoint}: {reason}")
    except TimeoutError:
        fail(f"Timed out while fetching models from {endpoint}.")

    try:
        data = json.loads(payload)
    except json.JSONDecodeError as exc:
        fail(f"Adapter returned invalid JSON from {endpoint}: {exc}")

    entries = data.get("data")
    if not isinstance(entries, list):
        fail(f"Adapter response from {endpoint} is missing a valid data list.")

    models: List[str] = []
    seen = set()
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        model_id = entry.get("id")
        if isinstance(model_id, str):
            model_id = model_id.strip()
            if model_id and model_id not in seen:
                models.append(model_id)
                seen.add(model_id)

    if not models:
        fail(f"No model ids were returned from {endpoint}.")

    return models


def fallback_choice(models: List[str], tty_input, tty_output) -> str:
    print(
        "prompt_toolkit is not installed; falling back to a numbered model picker.",
        file=sys.stderr,
    )
    tty_output.write("GapCodex model picker\n")
    for index, model in enumerate(models, start=1):
        tty_output.write(f"  {index}. {model}\n")
    tty_output.flush()

    while True:
        tty_output.write(f"Select a model [1-{len(models)}] (Ctrl-C cancels): ")
        tty_output.flush()
        selection = tty_input.readline()
        if selection == "":
            fail("Interactive model picker was interrupted.", exit_code=130)
        selection = selection.strip()
        if not selection:
            continue
        if selection.isdigit():
            selected_index = int(selection)
            if 1 <= selected_index <= len(models):
                return models[selected_index - 1]
        tty_output.write("Invalid selection. Please enter one of the listed numbers.\n")
        tty_output.flush()


def prompt_toolkit_choice(models: List[str], tty_input, tty_output) -> str:
    from prompt_toolkit.application.current import create_app_session
    from prompt_toolkit.input.defaults import create_input
    from prompt_toolkit.output.defaults import create_output
    from prompt_toolkit.shortcuts import choice
    from prompt_toolkit.styles import Style

    style = Style.from_dict(
        {
            "frame.border": "#334155",
            "frame.label": "bold #93c5fd",
            "text-area": "bg:#111827 #e5e7eb",
            "text-area.prompt": "bold #fbbf24",
            "selected-option": "bg:#22c55e #052e16 bold",
            "line": "#94a3b8",
            "bottom-toolbar": "bg:#0f172a #cbd5e1",
        }
    )

    tty_ui_input = create_input(stdin=tty_input, always_prefer_tty=True)
    tty_ui_output = create_output(stdout=tty_output, always_prefer_tty=True)

    try:
        with create_app_session(input=tty_ui_input, output=tty_ui_output):
            result = choice(
                message="GapCodex model picker",
                options=[(model, model) for model in models],
                default=models[0],
                style=style,
                symbol=">",
                show_frame=True,
                bottom_toolbar="Enter selects  Ctrl-C cancels",
            )
    except KeyboardInterrupt:
        fail("Interactive model picker was cancelled.", exit_code=130)
    finally:
        tty_ui_input.close()

    if result is None:
        fail("Interactive model picker was cancelled.", exit_code=130)

    return result


def main() -> None:
    endpoint = sys.argv[1]
    api_key = sys.argv[2]
    models = fetch_models(endpoint, api_key)

    try:
        tty_input = open("/dev/tty", "r", encoding="utf-8")
        tty_output = open("/dev/tty", "w", encoding="utf-8")
    except OSError:
        fail(
            "Interactive model picker requires a terminal. Run gapchat from an interactive shell or pass an explicit --model value."
        )

    try:
        try:
            selected_model = prompt_toolkit_choice(models, tty_input, tty_output)
        except ImportError:
            selected_model = fallback_choice(models, tty_input, tty_output)
    finally:
        tty_input.close()
        tty_output.close()

    print(selected_model)


main()
PY
}

args=()
pick_requested=false
model_provided=false
model_value=""

while (($# > 0)); do
  case "$1" in
    --model=*|-m=*)
      args+=("$1")
      model_provided=true
      shift
      ;;
    --model|-m)
      if [[ -n "${2:-}" && "${2:-}" != -* ]]; then
        args+=("$1" "$2")
        model_provided=true
        shift 2
        continue
      fi
      pick_requested=true
      shift
      ;;
    --help|-h)
      show_help
      echo
      exec env \
        codex --profile gapchat "$@"
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ "$model_provided" == false && "$pick_requested" == false ]]; then
  pick_requested=true
fi

if [[ "$pick_requested" == true ]]; then
  model_value="$(pick_model)"
  args=(--model "$model_value" "${args[@]}")
fi

exec env \
  codex --profile gapchat "${args[@]}"

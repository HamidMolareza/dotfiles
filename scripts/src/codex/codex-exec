#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   ./run_codex_agents.sh            # uses codex1
#   ./run_codex_agents.sh codex3     # uses codex3
#   CODEX_BIN=codex2 ./run_codex_agents.sh

CODEX_BIN="${CODEX_BIN:-${1:-codex1}}"

if ! command -v "$CODEX_BIN" >/dev/null 2>&1; then
  echo "Error: '$CODEX_BIN' not found in PATH."
  echo "Tip: pass the codex name like: $0 codex3"
  exit 127
fi

"$CODEX_BIN" exec \
  --cd . \
  --model gpt-5.2-codex \
  --config model_reasoning_effort="xhigh" \
  --sandbox workspace-write \
  'Do base the AGENTS.md file'

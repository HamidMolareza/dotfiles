#!/usr/bin/env bash
set -Eeuo pipefail

PACKAGE='@openai/codex'
NETWORK_MODE='current'
QUARANTINE_ROOT=''

run_npm_direct() {
  env \
    -u ALL_PROXY \
    -u all_proxy \
    -u HTTP_PROXY \
    -u http_proxy \
    -u HTTPS_PROXY \
    -u https_proxy \
    -u FTP_PROXY \
    -u ftp_proxy \
    -u NO_PROXY \
    -u no_proxy \
    -u npm_config_proxy \
    -u npm_config_https_proxy \
    -u npm_config_noproxy \
    npm \
    --proxy=null \
    --https-proxy=null \
    --noproxy='' \
    "$@"
}

run_npm_proxy() {
  env \
    -u FTP_PROXY \
    -u ftp_proxy \
    npm "$@"
}

run_npm_current() {
  npm "$@"
}

run_npm() {
  case "$NETWORK_MODE" in
    current)
      run_npm_current "$@"
      ;;
    direct)
      run_npm_direct "$@"
      ;;
    proxy)
      run_npm_proxy "$@"
      ;;
    *)
      printf 'Unknown network mode: %s\n' "$NETWORK_MODE" >&2
      exit 1
      ;;
  esac
}

ensure_quarantine_root() {
  if [[ -z "$QUARANTINE_ROOT" ]]; then
    QUARANTINE_ROOT="$GLOBAL_ROOT/.codex-update-quarantine/$(date +%Y%m%dT%H%M%S)-$$"
  fi

  mkdir -p "$QUARANTINE_ROOT"
}

quarantine_stale_codex_stage_entries() {
  local reason search_dir candidate relative_path destination destination_dir
  reason="$1"
  shift

  for search_dir in "$@"; do
    [[ -d "$search_dir" ]] || continue

    for candidate in "$search_dir"/.codex-*; do
      [[ -e "$candidate" || -L "$candidate" ]] || continue

      ensure_quarantine_root
      relative_path="${candidate#/}"
      destination="$QUARANTINE_ROOT/$relative_path"
      destination_dir="${destination%/*}"

      mkdir -p "$destination_dir"

      if [[ -e "$destination" || -L "$destination" ]]; then
        destination="$destination.$(date +%s).$$"
      fi

      printf 'Quarantining stale npm Codex staging entry (%s): %s -> %s\n' \
        "$reason" "$candidate" "$destination" >&2
      mv -- "$candidate" "$destination"
    done
  done
}

is_codex_stale_stage_error() {
  local output_file
  output_file="$1"

  grep -q 'ENOTEMPTY' "$output_file" \
    && grep -q 'rename' "$output_file" \
    && grep -Eq '(/@openai/\.codex-|/bin/\.codex-)' "$output_file"
}

npm_with_stale_stage_retry() {
  local description output_file
  local -a stage_dirs npm_args

  description="$1"
  shift

  stage_dirs=()
  while [[ $# -gt 0 && "$1" != '--' ]]; do
    stage_dirs+=("$1")
    shift
  done

  if [[ $# -eq 0 ]]; then
    printf 'Internal error: missing npm argument separator for %s.\n' "$description" >&2
    exit 1
  fi
  shift

  npm_args=("$@")
  output_file="$(mktemp -t codex-update-npm.XXXXXX)"

  if run_npm "${npm_args[@]}" 2>&1 | tee "$output_file"; then
    rm -f "$output_file"
    return 0
  fi

  if is_codex_stale_stage_error "$output_file"; then
    printf 'npm hit a stale Codex staging directory while %s; quarantining leftovers and retrying once.\n' \
      "$description" >&2
    quarantine_stale_codex_stage_entries 'npm ENOTEMPTY retry' "${stage_dirs[@]}"

    if run_npm "${npm_args[@]}"; then
      rm -f "$output_file"
      return 0
    fi
  fi

  rm -f "$output_file"
  return 1
}

append_registry() {
  local registry existing
  registry="$1"

  [[ -n "$registry" ]] || return 0

  for existing in "${REGISTRIES[@]}"; do
    [[ "$existing" != "$registry" ]] || return 0
  done

  REGISTRIES+=("$registry")
}

build_registries() {
  local configured_registry

  REGISTRIES=()

  if [[ -n "${CODEX_NPM_REGISTRY:-}" ]]; then
    append_registry "$CODEX_NPM_REGISTRY"
  else
    configured_registry="$(run_npm config get registry 2>/dev/null || true)"
    [[ "$configured_registry" != 'undefined' ]] || configured_registry=''
    append_registry "$configured_registry"
  fi

  append_registry 'https://package-mirror.liara.ir/repository/npm/'
  append_registry 'https://registry.npmjs.org/'
  append_registry 'https://registry.npmmirror.com/'
}

resolve_latest_version() {
  local registry version

  for registry in "${REGISTRIES[@]}"; do
    printf 'Resolving latest %s version from %s...\n' "$PACKAGE" "$registry" >&2
    if version="$(run_npm view "$PACKAGE" version --registry="$registry" 2>/dev/null | tr -d '[:space:]')" && [[ -n "$version" ]]; then
      printf '%s\n' "$version"
      return 0
    fi
  done

  return 1
}

install_codex_package() {
  local registry

  for registry in "${REGISTRIES[@]}"; do
    printf 'Installing %s@%s from %s...\n' "$PACKAGE" "$TARGET_VERSION" "$registry"
    if npm_with_stale_stage_retry \
      "installing $PACKAGE@$TARGET_VERSION from $registry" \
      "$GLOBAL_ROOT/@openai" \
      "$GLOBAL_PREFIX/bin" \
      -- \
      install -g "$PACKAGE@$TARGET_VERSION" --include=optional --registry="$registry"; then
      return 0
    fi
  done

  return 1
}

install_platform_package() {
  local codex_package_dir registry
  codex_package_dir="$1"

  for registry in "${REGISTRIES[@]}"; do
    printf 'Installing missing platform package %s from %s...\n' "$PLATFORM_PACKAGE" "$registry"
    if npm_with_stale_stage_retry \
      "installing $PLATFORM_PACKAGE for $PACKAGE@$TARGET_VERSION from $registry" \
      "$codex_package_dir/node_modules/@openai" \
      "$codex_package_dir/node_modules/.bin" \
      -- \
      install \
      --prefix "$codex_package_dir" \
      --no-save \
      --package-lock=false \
      "${PLATFORM_PACKAGE}@npm:${PACKAGE}@${TARGET_VERSION}-${PLATFORM_SUFFIX}" \
      --include=optional \
      --registry="$registry"; then
      return 0
    fi
  done

  return 1
}

platform_package() {
  case "$(platform_id)" in
    linux:x64)
      printf '%s\n' '@openai/codex-linux-x64'
      ;;
    linux:arm64)
      printf '%s\n' '@openai/codex-linux-arm64'
      ;;
    darwin:x64)
      printf '%s\n' '@openai/codex-darwin-x64'
      ;;
    darwin:arm64)
      printf '%s\n' '@openai/codex-darwin-arm64'
      ;;
    win32:x64)
      printf '%s\n' '@openai/codex-win32-x64'
      ;;
    win32:arm64)
      printf '%s\n' '@openai/codex-win32-arm64'
      ;;
    *)
      printf 'Unsupported platform for Codex: %s\n' "$(platform_id)" >&2
      exit 1
      ;;
  esac
}

platform_suffix() {
  case "$(platform_id)" in
    linux:x64) printf '%s\n' 'linux-x64' ;;
    linux:arm64) printf '%s\n' 'linux-arm64' ;;
    darwin:x64) printf '%s\n' 'darwin-x64' ;;
    darwin:arm64) printf '%s\n' 'darwin-arm64' ;;
    win32:x64) printf '%s\n' 'win32-x64' ;;
    win32:arm64) printf '%s\n' 'win32-arm64' ;;
    *)
      printf 'Unsupported platform for Codex: %s\n' "$(platform_id)" >&2
      exit 1
      ;;
  esac
}

platform_id() {
  node -p '`${process.platform}:${process.arch}`'
}

codex_bin_path() {
  local global_root
  global_root="$1"
  printf '%s\n' "$global_root/@openai/codex/bin/codex.js"
}

verify_platform_package_resolves() {
  local global_root package_name bin_path
  global_root="$1"
  package_name="$(platform_package)"
  bin_path="$(codex_bin_path "$global_root")"

  [[ -f "$bin_path" ]] || return 1

  node --input-type=module - "$bin_path" "$package_name" <<'NODE'
import { createRequire } from 'node:module';

const [binPath, packageName] = process.argv.slice(2);

try {
  const require = createRequire(binPath);
  require.resolve(`${packageName}/package.json`);
} catch {
  process.exit(1);
}
NODE
}

usage() {
  cat <<'EOF'
Usage: codex-update [options] [version]

Update Codex CLI from npm.

Options:
  --direct     Bypass proxy environment and npm proxy config.
               This can help when proxy environment variables are set.
  --proxy      Use the current shell/npm proxy settings.
               FTP proxy variables are still ignored because they can
               interfere with npm registry requests.
  --current    Use npm with the current environment unchanged. This is the
               default mode.
  -h, --help   Show this help text.

Arguments:
  version    Optional explicit version to install, for example 0.122.0.
             When omitted, the script resolves the current latest version
             first and then installs that exact version.

Environment:
  CODEX_NPM_REGISTRY  Optional registry to try before the built-in fallbacks.
EOF
}

TARGET_VERSION=''
while [[ $# -gt 0 ]]; do
  case "$1" in
    --direct)
      NETWORK_MODE='direct'
      shift
      ;;
    --proxy)
      NETWORK_MODE='proxy'
      shift
      ;;
    --current)
      NETWORK_MODE='current'
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf 'Unknown option: %s\n\n' "$1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$TARGET_VERSION" ]]; then
        printf 'Only one version argument is supported.\n\n' >&2
        usage >&2
        exit 1
      fi
      TARGET_VERSION="$1"
      shift
      ;;
  esac
done

if [[ $# -gt 0 ]]; then
  printf 'Unexpected extra arguments: %s\n\n' "$*" >&2
  usage >&2
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  printf 'npm is required but was not found on PATH.\n' >&2
  exit 1
fi

if ! command -v node >/dev/null 2>&1; then
  printf 'node is required but was not found on PATH.\n' >&2
  exit 1
fi

build_registries

if [[ -z "$TARGET_VERSION" ]]; then
  if ! TARGET_VERSION="$(resolve_latest_version)"; then
    TARGET_VERSION=''
  fi
fi

if [[ -z "$TARGET_VERSION" ]]; then
  printf 'Could not resolve a target version for %s.\n' "$PACKAGE" >&2
  exit 1
fi

PLATFORM_PACKAGE="$(platform_package)"
PLATFORM_SUFFIX="$(platform_suffix)"
GLOBAL_ROOT="$(run_npm root -g)"
GLOBAL_PREFIX="$(run_npm prefix -g)"
CODEX_PACKAGE_DIR="$GLOBAL_ROOT/@openai/codex"

quarantine_stale_codex_stage_entries 'preflight' \
  "$GLOBAL_ROOT/@openai" \
  "$GLOBAL_PREFIX/bin"

if ! install_codex_package; then
  printf 'Could not install %s@%s from any configured registry.\n' "$PACKAGE" "$TARGET_VERSION" >&2
  exit 1
fi

if ! verify_platform_package_resolves "$GLOBAL_ROOT"; then
  quarantine_stale_codex_stage_entries 'platform package preflight' \
    "$CODEX_PACKAGE_DIR/node_modules/@openai" \
    "$CODEX_PACKAGE_DIR/node_modules/.bin"

  if ! install_platform_package "$CODEX_PACKAGE_DIR"; then
    printf 'Could not install %s for %s@%s from any configured registry.\n' \
      "$PLATFORM_PACKAGE" "$PACKAGE" "$TARGET_VERSION" >&2
    exit 1
  fi
fi

if ! verify_platform_package_resolves "$GLOBAL_ROOT"; then
  printf 'Expected %s to resolve from %s, but it is still missing.\n' \
    "$PLATFORM_PACKAGE" "$(codex_bin_path "$GLOBAL_ROOT")" >&2
  exit 1
fi

INSTALLED_VERSION="$(
  node -e "const path = require('node:path'); const pkg = require(path.join(process.argv[1], '@openai', 'codex', 'package.json')); process.stdout.write(pkg.version);" \
    "$GLOBAL_ROOT"
)"

if [[ "$INSTALLED_VERSION" != "$TARGET_VERSION" ]]; then
  printf 'Expected %s version %s, but npm installed %s under %s.\n' \
    "$PACKAGE" "$TARGET_VERSION" "$INSTALLED_VERSION" "$GLOBAL_ROOT" >&2
  exit 1
fi

printf 'Verified package version: %s\n' "$INSTALLED_VERSION"
printf 'CLI reports: '
codex --version

def format_chart_timestamp_label(timestamp: str) -> str:
    try:
        return datetime.fromisoformat(timestamp).strftime("%H:%M:%S")
    except ValueError:
        return timestamp


def build_usage_chart_points(snapshot, limit: int = 12):
    recent_requests = snapshot.get("recent_requests", [])
    if not recent_requests:
        return []

    points = []
    for request in reversed(recent_requests[:limit]):
        points.append(
            {
                "label": format_chart_timestamp_label(request["timestamp"]),
                "uploaded_bytes": int(request["uploaded_bytes"]),
                "downloaded_bytes": int(request["downloaded_bytes"]),
                "total_bytes": int(request["total_bytes"]),
            }
        )
    return points


def render_usage_chart(snapshot) -> str:
    points = build_usage_chart_points(snapshot)
    if not points:
        return "<div class='empty'>No recent traffic yet.</div>"

    svg_width = 720
    svg_height = 220
    padding_top = 14
    padding_right = 12
    padding_bottom = 40
    padding_left = 12
    inner_width = svg_width - padding_left - padding_right
    inner_height = svg_height - padding_top - padding_bottom
    slot_width = inner_width / len(points)
    bar_width = min(max(slot_width * 0.58, 10), 34)
    max_total = max(point["total_bytes"] for point in points) or 1
    tick_every = max(1, (len(points) + 2) // 4)

    bars = []
    labels = []
    for index, point in enumerate(points):
        x = padding_left + (slot_width * index) + ((slot_width - bar_width) / 2)
        download_height = (point["downloaded_bytes"] / max_total) * inner_height
        upload_height = (point["uploaded_bytes"] / max_total) * inner_height
        y_base = padding_top + inner_height
        download_y = y_base - download_height
        upload_y = download_y - upload_height

        bars.append(
            f"<rect class='chart-download' x='{x:.2f}' y='{download_y:.2f}' "
            f"width='{bar_width:.2f}' height='{download_height:.2f}' rx='5' ry='5'>"
            f"<title>{html.escape(point['label'])} download {format_mb(point['downloaded_bytes'])}</title>"
            "</rect>"
        )
        if upload_height > 0:
            bars.append(
                f"<rect class='chart-upload' x='{x:.2f}' y='{upload_y:.2f}' "
                f"width='{bar_width:.2f}' height='{upload_height:.2f}' rx='5' ry='5'>"
                f"<title>{html.escape(point['label'])} upload {format_mb(point['uploaded_bytes'])}</title>"
                "</rect>"
            )

        if index % tick_every == 0 or index == len(points) - 1:
            labels.append(
                f"<text class='chart-label' x='{x + (bar_width / 2):.2f}' y='{svg_height - 14}' "
                f"text-anchor='middle'>{html.escape(point['label'])}</text>"
            )

    return (
        "<div class='chart-shell'>"
        "<div class='chart-legend'>"
        "<span><i class='legend-swatch legend-upload'></i>Upload</span>"
        "<span><i class='legend-swatch legend-download'></i>Download</span>"
        "</div>"
        f"<svg class='usage-chart-svg' viewBox='0 0 {svg_width} {svg_height}' "
        "role='img' aria-label='Recent traffic by request'>"
        f"<line class='chart-axis' x1='{padding_left}' y1='{padding_top + inner_height}' "
        f"x2='{svg_width - padding_right}' y2='{padding_top + inner_height}'></line>"
        f"{''.join(bars)}"
        f"{''.join(labels)}"
        "</svg>"
        "</div>"
    )



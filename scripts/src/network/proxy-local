    const totalsTableElement = document.getElementById("totals-table");
    const recentRequestsElement = document.getElementById("recent-requests");
    const statusElement = document.getElementById("dashboard-status");
    const INITIAL_HISTORY_SNAPSHOT = {json.dumps(history_snapshot, sort_keys=True)};

    function escapeHtml(value) {{
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }}

    function formatMb(byteCount) {{
      return `${{(byteCount / bytesInMb).toFixed(2)}} MB`;
    }}

    function emptyUsageSummary() {{
      return {{
        count: 0,
        uploaded_bytes: 0,
        downloaded_bytes: 0,
        total_bytes: 0,
      }};
    }}

    function formatChartTimestampLabel(timestamp) {{
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) {{
        return String(timestamp);
      }}
      return date.toLocaleTimeString([], {{
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
      }});
    }}

    function buildUsageChartPoints(snapshot, limit = 12) {{
      const recentRequests = snapshot.recent_requests || [];
      return recentRequests
        .slice(0, limit)
        .reverse()
        .map((request) => ({{
          label: formatChartTimestampLabel(request.timestamp),
          uploaded_bytes: Number(request.uploaded_bytes) || 0,
          downloaded_bytes: Number(request.downloaded_bytes) || 0,
          total_bytes: Number(request.total_bytes) || 0,
        }}));
    }}

    function renderSummaryCards(snapshot) {{
      const overall = snapshot.overall;
      const activeTotal = Object.values(snapshot.active_by_proxy).reduce((sum, count) => sum + count, 0);
      const cards = [
        ["Started", snapshot.started_at],
        ["Active connections", String(activeTotal)],
        ["Requests handled", String(overall.count)],
        ["Uploaded", formatMb(overall.uploaded_bytes)],
        ["Downloaded", formatMb(overall.downloaded_bytes)],
        ["Total traffic", formatMb(overall.total_bytes)],
      ];
      summaryCardsElement.innerHTML = cards.map(([label, value]) => `
        <div class="card">
          <div class="card-label">${{escapeHtml(label)}}</div>
          <div class="card-value">${{escapeHtml(value)}}</div>
        </div>
      `).join("");
    }}

    function renderHistorySummary(history) {{
      const summary = history.summary || emptyUsageSummary();
      const cards = [
        ["Range", history.range_title || "History"],
        ["Matched requests", String(summary.count || 0)],
        ["Total traffic", formatMb(summary.total_bytes || 0)],
        ["Upload", formatMb(summary.uploaded_bytes || 0)],
        ["Download", formatMb(summary.downloaded_bytes || 0)],
      ];
      historySummaryElement.innerHTML = cards.map(([label, value]) => `
        <div class="card">
          <div class="card-label">${{escapeHtml(label)}}</div>
          <div class="card-value">${{escapeHtml(value)}}</div>
        </div>
      `).join("");
    }}

    function syncHistoryProxyOptions(history) {{
      const proxies = history.available_proxy_types || [];
      const previousValue = historyProxyTypeElement.value || "all";
      historyProxyTypeElement.innerHTML = `
        <option value="all">All proxies</option>
        ${{proxies.map((proxyType) => `
          <option value="${{escapeHtml(proxyType)}}">${{escapeHtml(proxyType)}}</option>
        `).join("")}}
      `;
      historyProxyTypeElement.value = proxies.includes(previousValue) || previousValue === "all"
        ? previousValue
        : "all";
    }}

    function renderHistoryNote(history) {{
      const notes = [];
      if (history.time_range && history.time_range.from && history.time_range.to) {{
        notes.push(`${{history.time_range.from}} -> ${{history.time_range.to}}`);
      }}
      if (history.invalid_lines) {{
        notes.push(`Skipped invalid log lines: ${{history.invalid_lines}}`);
      }}
      historyNoteElement.textContent = notes.join(" · ") || "Built from the append-only usage log.";
    }}

    function renderBucketChart(targetElement, series, emptyMessage) {{
      if (!series.length) {{
        targetElement.innerHTML = `<div class="empty">${{escapeHtml(emptyMessage)}}</div>`;
        return;
      }}

      const svgWidth = 720;
      const svgHeight = 220;
      const paddingTop = 14;
      const paddingRight = 12;
      const paddingBottom = 40;
      const paddingLeft = 12;
      const innerWidth = svgWidth - paddingLeft - paddingRight;
      const innerHeight = svgHeight - paddingTop - paddingBottom;
      const slotWidth = innerWidth / series.length;
      const barWidth = Math.min(Math.max(slotWidth * 0.58, 10), 34);
      const maxTotal = Math.max(...series.map((point) => Number(point.total_bytes) || 0), 1);
      const tickEvery = Math.max(1, Math.floor((series.length + 2) / 4));

      const bars = [];
      const labels = [];

      series.forEach((point, index) => {{
        const uploadedBytes = Number(point.uploaded_bytes) || 0;
        const downloadedBytes = Number(point.downloaded_bytes) || 0;
        const x = paddingLeft + (slotWidth * index) + ((slotWidth - barWidth) / 2);
        const downloadHeight = (downloadedBytes / maxTotal) * innerHeight;
        const uploadHeight = (uploadedBytes / maxTotal) * innerHeight;
        const yBase = paddingTop + innerHeight;
        const downloadY = yBase - downloadHeight;
        const uploadY = downloadY - uploadHeight;

        bars.push(`
          <rect class="chart-download" x="${{x.toFixed(2)}}" y="${{downloadY.toFixed(2)}}"
                width="${{barWidth.toFixed(2)}}" height="${{downloadHeight.toFixed(2)}}" rx="5" ry="5">
            <title>${{escapeHtml(point.label)}} download ${{escapeHtml(formatMb(downloadedBytes))}}</title>
          </rect>
        `);

        if (uploadHeight > 0) {{
          bars.push(`
            <rect class="chart-upload" x="${{x.toFixed(2)}}" y="${{uploadY.toFixed(2)}}"
                  width="${{barWidth.toFixed(2)}}" height="${{uploadHeight.toFixed(2)}}" rx="5" ry="5">
              <title>${{escapeHtml(point.label)}} upload ${{escapeHtml(formatMb(uploadedBytes))}}</title>
            </rect>
          `);
        }}

        if (index % tickEvery === 0 || index === series.length - 1) {{
          labels.push(`
            <text class="chart-label" x="${{(x + (barWidth / 2)).toFixed(2)}}" y="${{svgHeight - 14}}" text-anchor="middle">
              ${{escapeHtml(point.label)}}
            </text>
          `);
        }}
      }});

      targetElement.innerHTML = `
        <div class="chart-shell">
          <div class="chart-legend">
            <span><i class="legend-swatch legend-upload"></i>Upload</span>
            <span><i class="legend-swatch legend-download"></i>Download</span>
          </div>
          <svg class="usage-chart-svg" viewBox="0 0 ${{svgWidth}} ${{svgHeight}}" role="img" aria-label="Traffic over time">
            <line class="chart-axis" x1="${{paddingLeft}}" y1="${{paddingTop + innerHeight}}" x2="${{svgWidth - paddingRight}}" y2="${{paddingTop + innerHeight}}"></line>
            ${{bars.join("")}}
            ${{labels.join("")}}
          </svg>
        </div>
      `;
    }}

    function renderHistoryChart(history) {{
      renderBucketChart(historyChartElement, history.series || [], "No historical traffic matched this filter.");
    }}

    function renderHistoryDestinations(history) {{
      const destinations = history.top_destinations || [];
      if (!destinations.length) {{
        historyDestinationsElement.innerHTML = "<div class='empty'>No destinations matched this filter.</div>";
        return;
      }}

      historyDestinationsElement.innerHTML = `
        <table>
          <thead>
            <tr><th>Destination</th><th>Requests</th><th>Total</th></tr>
          </thead>
          <tbody>
            ${{destinations.map((item) => `
              <tr>
                <td class="destination">${{escapeHtml(item.destination)}}</td>
                <td>${{item.count}}</td>
                <td>${{escapeHtml(formatMb(item.total_bytes))}}</td>
              </tr>
            `).join("")}}
          </tbody>
        </table>
      `;
    }}

    function renderUsageChart(snapshot) {{
      const points = buildUsageChartPoints(snapshot);
      renderBucketChart(usageChartElement, points, "No recent traffic yet.");
    }}

    function renderLatestRequest(snapshot) {{
      const latest = snapshot.latest_request;
      if (!latest) {{
        latestRequestElement.innerHTML = "<div class='empty'>No completed requests yet.</div>";
        return;
      }}

      const fields = [
        ["Time", latest.timestamp],
        ["Proxy", latest.proxy_type],
        ["Method", latest.method],
        ["Client", latest.client],
        ["Destination", latest.destination],
        ["Upload", formatMb(latest.uploaded_bytes)],
        ["Download", formatMb(latest.downloaded_bytes)],
        ["Total", formatMb(latest.total_bytes)],
      ];
      latestRequestElement.innerHTML = fields.map(([label, value]) => `
        <div class="detail-row">
          <span class="detail-label">${{escapeHtml(label)}}</span>
          <span class="detail-value">${{escapeHtml(value)}}</span>
        </div>
      `).join("");
    }}

    function renderActiveClients(snapshot) {{
      const clients = Object.entries(snapshot.active_by_client);
      if (!clients.length) {{
        activeClientsElement.innerHTML = "<div class='empty'>No active clients right now.</div>";
        return;
      }}

      activeClientsElement.innerHTML = `
        <table>
          <thead><tr><th>Client</th><th>Active connections</th></tr></thead>
          <tbody>
            ${{clients.map(([client, count]) => `
              <tr><td>${{escapeHtml(client)}}</td><td>${{count}}</td></tr>
            `).join("")}}
          </tbody>
        </table>
      `;
    }}

    function renderTotalsTable(snapshot) {{
      totalsTableElement.innerHTML = PROXY_TYPES.map((proxyType) => {{
        const summary = snapshot.totals_by_proxy[proxyType] || emptyUsageSummary();
        const activeCount = snapshot.active_by_proxy[proxyType] || 0;
        return `
          <tr>
            <td>${{escapeHtml(proxyType)}}</td>
            <td>${{summary.count}}</td>
            <td>${{activeCount}}</td>
            <td>${{escapeHtml(formatMb(summary.uploaded_bytes))}}</td>
            <td>${{escapeHtml(formatMb(summary.downloaded_bytes))}}</td>
            <td>${{escapeHtml(formatMb(summary.total_bytes))}}</td>
          </tr>
        `;
      }}).join("");
    }}

    function renderRecentRequests(snapshot) {{
      const requests = snapshot.recent_requests || [];
      if (!requests.length) {{
        recentRequestsElement.innerHTML = "<div class='empty'>No recent requests yet.</div>";
        return;
      }}

      recentRequestsElement.innerHTML = `
        <table>
          <thead>
            <tr><th>Time</th><th>Proxy</th><th>Method</th><th>Client</th><th>Destination</th><th>Total</th></tr>
          </thead>
          <tbody>
            ${{requests.map((request) => `
              <tr>
                <td>${{escapeHtml(request.timestamp)}}</td>
                <td>${{escapeHtml(request.proxy_type)}}</td>
                <td>${{escapeHtml(request.method)}}</td>
                <td>${{escapeHtml(request.client)}}</td>
                <td class="destination">${{escapeHtml(request.destination)}}</td>
                <td>${{escapeHtml(formatMb(request.total_bytes))}}</td>
              </tr>
            `).join("")}}
          </tbody>
        </table>
      `;
    }}

    function renderDashboard(snapshot) {{
      renderSummaryCards(snapshot);
      renderUsageChart(snapshot);
      renderLatestRequest(snapshot);
      renderActiveClients(snapshot);
      renderTotalsTable(snapshot);
      renderRecentRequests(snapshot);
    }}

    function renderHistory(history) {{
      syncHistoryProxyOptions(history);
      renderHistorySummary(history);
      renderHistoryNote(history);
      renderHistoryChart(history);
      renderHistoryDestinations(history);
    }}

    function setStatus(text, isWarning = false) {{
      statusElement.textContent = text;
      statusElement.classList.toggle("pill-warning", isWarning);
    }}

    function setHistoryError(message) {{
      historyNoteElement.textContent = message;
      historyChartElement.innerHTML = `<div class="empty">${{escapeHtml(message)}}</div>`;
      historyDestinationsElement.innerHTML = "<div class='empty'>History data is unavailable right now.</div>";
    }}

    async function refreshHistory() {{
      const params = new URLSearchParams();
      params.set("range", historyRangeElement.value);
      if (historyProxyTypeElement.value !== "all") {{
        params.set("proxy_type", historyProxyTypeElement.value);
      }}

      const response = await fetch(`/api/history?${{params.toString()}}`, {{
        cache: "no-store",
        headers: {{
          "Accept": "application/json"
        }}
      }});
      if (!response.ok) {{
        throw new Error(`history HTTP ${{response.status}}`);
      }}
      const history = await response.json();
      renderHistory(history);
    }}

    async function refreshDashboard() {{
      try {{
        const response = await fetch("/api/dashboard", {{
          cache: "no-store",
          headers: {{
            "Accept": "application/json"
          }}
        }});
        if (!response.ok) {{
          throw new Error(`HTTP ${{response.status}}`);
        }}
        const snapshot = await response.json();
        renderDashboard(snapshot);
        setStatus(`Live updates every 2 seconds · ${{
          new Date().toLocaleTimeString()
        }}`);
      }} catch (error) {{
        setStatus(`Live updates paused: ${{error.message}}`, true);
      }}

      try {{
        await refreshHistory();
      }} catch (error) {{
        setHistoryError(`History refresh paused: ${{error.message}}`);
      }}
    }}

    renderHistory(INITIAL_HISTORY_SNAPSHOT);
    historyRangeElement.addEventListener("change", () => {{
      refreshHistory().catch((error) => setHistoryError(`History refresh paused: ${{error.message}}`));
    }});
    historyProxyTypeElement.addEventListener("change", () => {{
      refreshHistory().catch((error) => setHistoryError(`History refresh paused: ${{error.message}}`));
    }});
    setStatus("Connecting to live dashboard…");
    window.setTimeout(refreshDashboard, 0);
    window.setInterval(refreshDashboard, 2000);
  </script>
</body>
</html>
"""


def start_dashboard_server(args, usage_log_path: Path | None):
    if args.no_dashboard:
        return None

    server = ThreadedDashboardServer(
        (args.dashboard_bind, args.dashboard_port),
        DashboardRequestHandler,
        usage_log_path=usage_log_path,
    )
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()
    return RunningDashboard(
        bind_ip=args.dashboard_bind,
        port=args.dashboard_port,
        server=server,
        thread=thread,
    )


def build_ssl_context(cert_file: str, key_file: str) -> ssl.SSLContext:
    context = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
    context.load_cert_chain(certfile=cert_file, keyfile=key_file)
    return context


def uses_mixed_listener(selected_types) -> bool:
    return any(proxy_type in {"mixed", "http", "socks5"} for proxy_type in selected_types)


def resolve_mixed_port(args, selected_types):
    if not uses_mixed_listener(selected_types):
        return None

    if args.http_port is not None and args.socks5_port is not None and args.http_port != args.socks5_port:
        raise SystemExit(
            "Error: --http-port and --socks5-port now map to the same mixed listener and must use the same value. "
            "Use --mixed-port for the shared port."
        )

    if args.http_port is not None:
        return args.http_port
    if args.socks5_port is not None:
        return args.socks5_port
    return args.mixed_port


def start_servers(args, allowed_networks):
    selected_types = args.proxy_types or ["mixed"]
    servers = []

    mixed_port = resolve_mixed_port(args, selected_types)

    if mixed_port is not None:
        server = ThreadedMixedProxyServer(
            (args.bind, mixed_port),
            allowed_networks=allowed_networks,
            timeout_seconds=args.timeout,
            verbose=args.verbose,
            debug=args.debug,
        )
        servers.append(
            RunningServer(
                proxy_type="mixed",
                bind_ip=args.bind,
                port=mixed_port,
                compatibility="Works with phone Wi-Fi HTTP proxy settings and SOCKS5 clients on the same port.",
                server=server,
                thread=threading.Thread(target=server.serve_forever, daemon=True),
            )
        )

    if "https" in selected_types:
        if not args.cert_file or not args.key_file:
            raise SystemExit("Error: --type https requires both --cert-file and --key-file.")

        ssl_context = build_ssl_context(args.cert_file, args.key_file)
        server = ThreadedTLSHTTPProxyServer(
            (args.bind, args.https_port),
            ProxyRequestHandler,
            ssl_context=ssl_context,
            allowed_networks=allowed_networks,
            timeout_seconds=args.timeout,
            verbose=args.verbose,
            debug=args.debug,
            proxy_label="https",
        )
        servers.append(
            RunningServer(
                proxy_type="https",
                bind_ip=args.bind,
                port=args.https_port,
                compatibility="Only for clients that support an HTTPS proxy with your certificate.",
                server=server,
                thread=threading.Thread(target=server.serve_forever, daemon=True),
            )
        )

    if "socks5" in selected_types:
        server = ThreadedSocks5Server(
            (args.bind, args.socks5_port),
            Socks5RequestHandler,
            allowed_networks=allowed_networks,
            timeout_seconds=args.timeout,
            verbose=args.verbose,
            debug=args.debug,
        )
        servers.append(
            RunningServer(
                proxy_type="socks5",
                bind_ip=args.bind,
                port=args.socks5_port,
                compatibility="Use only in apps or tools that support SOCKS5.",
                server=server,
                thread=threading.Thread(target=server.serve_forever, daemon=True),
            )
        )

    for item in servers:
        item.thread.start()

    return servers


def print_startup_instructions(
    servers,
    allowed_networks,
    client_ips,
    debug_log_path: Path | None,
    usage_log_path: Path | None,
    dashboard: RunningDashboard | None,
):
    print_section("Proxy listeners")
    for item in servers:
        listener = f"{item.bind_ip}:{item.port}"
        print(f"  {style_proxy_label(item.proxy_type, sys.stdout)}  {colorize(listener, COLOR_BOLD, stream=sys.stdout)}")
        print(f"     {colorize(item.compatibility, COLOR_BLUE, stream=sys.stdout)}")

    if allowed_networks:
        allowed_text = ", ".join(str(network) for network in allowed_networks)
        print_success(f"Allowed clients: {allowed_text}")
    else:
        print_warning("Allowed clients: any device that can reach this address")
        print_warning("Security note: on shared Wi-Fi, prefer --allow-client PHONE_IP")

    mixed_server = next((item for item in servers if item.proxy_type == "mixed"), None)
    if mixed_server:
        print()
        print_section("Phone Wi-Fi setup")
        print(f"  Proxy type: {colorize('Manual / HTTP', COLOR_BOLD, COLOR_CYAN, stream=sys.stdout)}")
        if client_ips:
            print(f"  Host: {colorize(client_ips[0], COLOR_BOLD, COLOR_GREEN, stream=sys.stdout)}")
        else:
            print_warning("  Host: <use this computer's Wi-Fi IPv4 address>")
        print(f"  Port: {colorize(str(mixed_server.port), COLOR_BOLD, COLOR_GREEN, stream=sys.stdout)}")
        if len(client_ips) > 1:
            print_info(f"  Other detected IPv4 addresses: {', '.join(client_ips[1:])}")
        print_info("  The same port also accepts SOCKS5 for apps that support it.")

    if client_ips:
        print()
        print_info(f"Detected IPv4 addresses for clients: {', '.join(client_ips)}")
    elif any(item.bind_ip == "0.0.0.0" for item in servers):
        print()
        print_warning("Detected IPv4 addresses for clients: none found automatically")
        print_warning("Use your computer's Wi-Fi IPv4 address as the phone proxy host.")

    if any(item.bind_ip == "127.0.0.1" for item in servers):
        print()
        print_warning("Warning: 127.0.0.1 is only reachable from this machine.")
        print_warning("Use --bind 0.0.0.0 or your LAN IP for phone access.")

    print()
    if RUNTIME_LOG_ENABLED:
        print_info("Connection logs are printed automatically when devices connect or disconnect.")
    else:
        print_info("Runtime console connection logs are disabled.")
    if dashboard is not None:
        print_info(f"Dashboard: http://{dashboard.bind_ip}:{dashboard.port}")
        if RUNTIME_LOG_ENABLED:
            print_info("Use --quiet if you want to watch the dashboard without runtime console logs.")
    if usage_log_path is not None:
        print_info(f"Usage log file: {usage_log_path}")
        print_info(f"Analyze totals later with: {Path(sys.argv[0]).name} usage-analyze {usage_log_path}")
    if debug_log_path is not None:
        print_info(f"Debug log file: {debug_log_path}")
    print_success("Press Ctrl+C to stop.")


def shutdown_servers(servers, dashboard: RunningDashboard | None):
    for item in servers:
        try:
            item.server.shutdown()
        finally:
            item.server.server_close()

    if dashboard is not None:
        try:
            dashboard.server.shutdown()
        finally:
            dashboard.server.server_close()


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "usage-analyze":
        run_usage_analyze(sys.argv[2:])
        return

    parser = build_proxy_parser()
    args = parser.parse_args()

    if args.debug_log_file:
        args.debug = True
    if args.debug:
        args.verbose = True
    configure_runtime_logging(not args.quiet)

    try:
        ipaddress.ip_address(args.bind)
    except ValueError as exc:
        raise SystemExit(f"Error: invalid --bind address '{args.bind}': {exc}") from exc

    ensure_valid_port(args.mixed_port, "--mixed-port")
    ensure_valid_port(args.https_port, "--https-port")
    if args.http_port is not None:
        ensure_valid_port(args.http_port, "--http-port")
    if args.socks5_port is not None:
        ensure_valid_port(args.socks5_port, "--socks5-port")
    if not args.no_dashboard:
        try:
            ipaddress.ip_address(args.dashboard_bind)
        except ValueError as exc:
            raise SystemExit(f"Error: invalid --dashboard-bind address '{args.dashboard_bind}': {exc}") from exc
        ensure_valid_port(args.dashboard_port, "--dashboard-port")

    if args.timeout <= 0:
        raise SystemExit("Error: --timeout must be greater than 0.")

    debug_log_path = resolve_debug_log_path(args.debug_log_file) if args.debug else None
    usage_log_path = resolve_usage_log_path(args.usage_log_file)
    try:
        configure_debug_logger(args.debug, debug_log_path)
    except OSError as exc:
        raise SystemExit(f"Error: could not open debug log file '{debug_log_path}': {exc}") from exc

    try:
        configure_usage_logger(usage_log_path)
    except OSError as exc:
        DEBUG_LOGGER.close()
        raise SystemExit(f"Error: could not open usage log file '{usage_log_path}': {exc}") from exc

    debug_log("system", f"argv={sys.argv!r}", level="INFO")
    debug_log(
        "system",
        "configuration "
        f"bind={args.bind} mixed_port={args.mixed_port} http_port={args.http_port} https_port={args.https_port} "
        f"socks5_port={args.socks5_port} timeout={args.timeout}s verbose={args.verbose} debug={args.debug} "
        f"usage_log={usage_log_path} dashboard={args.dashboard_bind}:{args.dashboard_port} "
        f"dashboard_enabled={not args.no_dashboard} quiet={args.quiet}",
        level="INFO",
    )

    allowed_networks = parse_allowed_networks(args.allow_client)
    client_ips = detect_candidate_client_ips()
    debug_log(
        "system",
        f"allowed_networks={[str(network) for network in allowed_networks]} detected_client_ips={client_ips}",
        level="INFO",
    )
    servers = start_servers(args, allowed_networks)
    dashboard = None
    if not args.no_dashboard:
        try:
            dashboard = start_dashboard_server(args, usage_log_path)
        except OSError as exc:
            print_warning(
                f"Dashboard could not start on {args.dashboard_bind}:{args.dashboard_port}: {exc}"
            )
            debug_exception("dashboard", "failed to start dashboard", exc)
    print_startup_instructions(
        servers,
        allowed_networks,
        client_ips,
        debug_log_path,
        usage_log_path,
        dashboard,
    )

    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        print("\nStopped.")
    finally:
        shutdown_servers(servers, dashboard)
        DEBUG_LOGGER.close()
        USAGE_LOGGER.close()


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""Summarize local Git repositories that need commit, push, or pull work."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
from dataclasses import asdict, dataclass
from pathlib import Path
from typing import Iterable


DEFAULT_MAX_DEPTH = 4

ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")

COLORS = {
    "reset": "\033[0m",
    "bold": "\033[1m",
    "dim": "\033[2m",
    "red": "\033[31m",
    "red_bold": "\033[1;31m",
    "green": "\033[32m",
    "yellow": "\033[33m",
    "yellow_bold": "\033[1;33m",
    "blue": "\033[34m",
    "blue_bold": "\033[1;34m",
    "magenta": "\033[35m",
    "magenta_bold": "\033[1;35m",
    "cyan": "\033[36m",
    "cyan_bold": "\033[1;36m",
}

SKIP_DIRS = {
    ".cache",
    ".git",
    ".idea",
    ".local",
    ".npm",
    ".nuget",
    ".vscode",
    "__pycache__",
    "bin",
    "build",
    "dist",
    "node_modules",
    "obj",
    "out",
    "packages",
    "vendor",
}


@dataclass
class StatusCounts:
    total: int = 0
    staged: int = 0
    unstaged: int = 0
    untracked: int = 0
    conflicts: int = 0


@dataclass
class RepoSummary:
    path: str
    branch: str
    commit_files: int
    staged_files: int
    unstaged_files: int
    untracked_files: int
    conflict_files: int
    remotes: list[str]
    upstream: str | None
    remote_state: str
    ahead_commits: int | None
    behind_commits: int | None
    commits_not_on_any_remote: int | None
    stash_count: int
    latest_commit_date: str | None
    latest_commit_sha: str | None
    latest_commit_subject: str | None
    fetch_error: str | None
    error: str | None

    @property
    def needs_action(self) -> bool:
        return any(
            [
                self.error,
                self.fetch_error,
                self.commit_files > 0,
                self.conflict_files > 0,
                self.remote_state in {"no_remote", "no_upstream"},
                (self.ahead_commits or 0) > 0,
                (self.behind_commits or 0) > 0,
                self.stash_count > 0,
            ]
        )


def parse_args() -> argparse.Namespace:

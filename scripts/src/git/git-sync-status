        formatter_class=argparse.RawTextHelpFormatter,
        epilog=f"""Examples:
  {Path(sys.argv[0]).name} ~/my-files/projects
  {Path(sys.argv[0]).name} . --fetch
  {Path(sys.argv[0]).name} ~/my-files --only-needs-action --max-depth 3
  {Path(sys.argv[0]).name} ~/my-files/projects --json
  {Path(sys.argv[0]).name} ~/my-files/projects --view full
  {Path(sys.argv[0]).name} ~/my-files/projects --limit 20

Notes:
  Remote ahead/behind counts use local remote-tracking refs.
  Add --fetch to refresh remotes before summarizing.
  Symlinked project directories are scanned with loop protection.
""",
    )
    parser.add_argument(
        "path",
        nargs="?",
        default=".",
        help="Repository path or parent directory to scan. Defaults to current directory.",
    )
    parser.add_argument(
        "--max-depth",
        type=int,
        default=DEFAULT_MAX_DEPTH,
        help=(
            "Maximum scan depth when PATH is not already inside a Git repo. "
            "Use -1 for unlimited. Default: %(default)s."
        ),
    )
    parser.add_argument(
        "--fetch",
        action="store_true",
        help="Run 'git fetch --all --prune --quiet' in each repo before summarizing.",
    )
    parser.add_argument(
        "--include-hidden",
        action="store_true",
        help="Include hidden child directories while discovering repositories.",
    )
    parser.add_argument(
        "--include-nested",
        action="store_true",
        help="Continue scanning inside discovered repositories.",
    )
    parser.add_argument(
        "--only-needs-action",
        action="store_true",
        help="Only show repositories that need commit, push, pull, remote setup, or stash review.",
    )
    parser.add_argument(
        "--absolute",

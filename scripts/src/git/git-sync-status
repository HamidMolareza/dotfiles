        default="action",
        help="Sort rows by action need, path, or latest commit date. Default: %(default)s.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Print machine-readable JSON instead of a table.",
    )
    parser.add_argument(
        "--view",
        choices=["compact", "full"],

def run_git(
    repo: Path,
    args: list[str],
    *,
    text: bool = True,
    check: bool = False,
) -> subprocess.CompletedProcess[str] | subprocess.CompletedProcess[bytes]:
    return subprocess.run(
        ["git", "-C", str(repo), *args],
        check=check,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=text,
    )


def is_inside_git_repo(path: Path) -> bool:
    result = run_git(path, ["rev-parse", "--is-inside-work-tree"])
    return result.returncode == 0 and result.stdout.strip() == "true"


def git_top_level(path: Path) -> Path | None:
    result = run_git(path, ["rev-parse", "--show-toplevel"])
    if result.returncode != 0:
        return None
    return Path(result.stdout.strip()).resolve()


def discover_repositories(
    start_path: Path,
    *,
    max_depth: int,
    include_hidden: bool,
    include_nested: bool,
) -> list[Path]:
    start_path = start_path.expanduser().resolve()
    scan_root = start_path.parent if start_path.is_file() else start_path

    if is_inside_git_repo(scan_root):
        top_level = git_top_level(scan_root)
        return [top_level] if top_level else []

    repositories: list[Path] = []
    seen: set[Path] = set()
    visited_dirs: set[Path] = {scan_root.resolve()}
    scan_nested = include_nested or max_depth < 0

    for root, dirs, _files in os.walk(scan_root, followlinks=True):
        root_path = Path(root)
        depth = len(root_path.relative_to(scan_root).parts)

        if max_depth >= 0 and depth > max_depth:
            dirs[:] = []
            continue

        git_marker = root_path / ".git"
        if git_marker.exists():
            repo_path = repository_path_for_root(root_path)
            if repo_path is not None:
                resolved = repo_path.resolve()
                if resolved not in seen:
                    repositories.append(repo_path)
                    seen.add(resolved)
                if not scan_nested:
                    dirs[:] = []
                    continue

        for name in dirs:
            candidate = root_path / name
            if not candidate.is_symlink():
                continue

            repo_path = repository_path_for_symlink(candidate)
            if repo_path is None:
                continue

            resolved = repo_path.resolve()
            if resolved not in seen:
                repositories.append(repo_path)
                seen.add(resolved)

        dirs[:] = filter_descendable_dirs(
            root_path,
            dirs,
            include_hidden=include_hidden,
            visited_dirs=visited_dirs,
        )

    return repositories


def filter_descendable_dirs(
    root_path: Path,
    dir_names: list[str],
    *,
    include_hidden: bool,
    visited_dirs: set[Path],
) -> list[str]:
    filtered: list[str] = []
    sorted_names = sorted(dir_names, key=lambda name: ((root_path / name).is_symlink(), name))

    for name in sorted_names:
        if not should_descend(name, include_hidden=include_hidden):
            continue

        child = root_path / name
        try:
            if not child.is_dir():
                continue
            resolved = child.resolve(strict=True)
        except OSError:
            continue

        if resolved in visited_dirs:
            continue

        visited_dirs.add(resolved)
        filtered.append(name)

    return filtered


def repository_path_for_root(path: Path) -> Path | None:
    top_level = git_top_level(path)
    if top_level is None:
        return None
    if path.resolve() == top_level.resolve():
        return path
    return top_level.resolve()


def repository_path_for_symlink(path: Path) -> Path | None:
    if not (path / ".git").exists():
        return None

    top_level = git_top_level(path)
    if top_level is None:
        return None

    if path.resolve() != top_level.resolve():
        return None

    return path


def should_descend(name: str, *, include_hidden: bool) -> bool:
    if name in SKIP_DIRS:
        return False
    if not include_hidden and name.startswith("."):
        return False
    return True


def parse_status_counts(output: bytes) -> StatusCounts:
    records = output.split(b"\0")
    counts = StatusCounts()
    index = 0

    while index < len(records):
        record = records[index]
        index += 1

        if not record:
            continue
        if len(record) < 4:
            continue

        status = record[:2].decode("ascii", errors="replace")
        if status == "??":
            counts.untracked += 1
        else:
            if status[0] != " ":
                counts.staged += 1
            if status[1] != " ":
                counts.unstaged += 1
            if is_conflict_status(status):
                counts.conflicts += 1

        counts.total += 1

        if "R" in status or "C" in status:
            index += 1

    return counts


def is_conflict_status(status: str) -> bool:
    return status in {"DD", "AU", "UD", "UA", "DU", "AA", "UU"} or "U" in status


def get_status_counts(repo: Path) -> StatusCounts:
    result = run_git(
        repo,
        ["status", "--porcelain=v1", "-z", "--untracked-files=all"],
        text=False,
    )
    if result.returncode != 0:
        raise RuntimeError(clean_error(result.stderr))
    return parse_status_counts(result.stdout)


def get_branch(repo: Path) -> str:
    result = run_git(repo, ["branch", "--show-current"])
    if result.returncode == 0 and result.stdout.strip():
        return result.stdout.strip()

    short_head = run_git(repo, ["rev-parse", "--short", "HEAD"])
    if short_head.returncode == 0 and short_head.stdout.strip():
        return f"DETACHED@{short_head.stdout.strip()}"

    symbolic_head = run_git(repo, ["symbolic-ref", "--short", "HEAD"])
    if symbolic_head.returncode == 0 and symbolic_head.stdout.strip():
        return symbolic_head.stdout.strip()

    return "unknown"


def get_remotes(repo: Path) -> list[str]:
    result = run_git(repo, ["remote"])
    if result.returncode != 0:
        return []
    return [line.strip() for line in result.stdout.splitlines() if line.strip()]


def get_upstream(repo: Path) -> str | None:
    result = run_git(repo, ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}"])
    if result.returncode != 0:
        return None
    return result.stdout.strip() or None


def get_ahead_behind(repo: Path, upstream: str) -> tuple[int | None, int | None]:
    result = run_git(repo, ["rev-list", "--left-right", "--count", f"{upstream}...HEAD"])
    if result.returncode != 0:
        return None, None

    parts = result.stdout.split()
    if len(parts) != 2:
        return None, None

    behind, ahead = int(parts[0]), int(parts[1])
    return ahead, behind


def count_commits_not_on_any_remote(repo: Path) -> int | None:
    result = run_git(repo, ["rev-list", "--count", "HEAD", "--not", "--remotes"])
    if result.returncode != 0:
        return None
    try:
        return int(result.stdout.strip())
    except ValueError:
        return None


def get_stash_count(repo: Path) -> int:
    result = run_git(repo, ["stash", "list"])
    if result.returncode != 0 or not result.stdout.strip():
        return 0
    return len(result.stdout.splitlines())


def get_latest_commit(repo: Path) -> tuple[str | None, str | None, str | None]:
    result = run_git(repo, ["log", "-1", "--format=%cd%x00%h%x00%s", "--date=iso-strict-local"])
    if result.returncode != 0 or not result.stdout:
        return None, None, None

    parts = result.stdout.rstrip("\n").split("\0", 2)
    if len(parts) != 3:
        return None, None, None
    return parts[0], parts[1], parts[2]


def fetch_repo(repo: Path) -> str | None:
    result = run_git(repo, ["fetch", "--all", "--prune", "--quiet"])
    if result.returncode == 0:
        return None
    return clean_error(result.stderr)


def summarize_repo(repo: Path, *, fetch: bool) -> RepoSummary:
    fetch_error = fetch_repo(repo) if fetch else None

    try:
        counts = get_status_counts(repo)
        branch = get_branch(repo)
        remotes = get_remotes(repo)
        upstream = get_upstream(repo)
        ahead: int | None = None
        behind: int | None = None
        commits_not_on_any_remote: int | None = None

        if not remotes:
            remote_state = "no_remote"
        elif upstream:
            remote_state = "tracking"
            ahead, behind = get_ahead_behind(repo, upstream)
        else:
            remote_state = "no_upstream"
            commits_not_on_any_remote = count_commits_not_on_any_remote(repo)

        latest_date, latest_sha, latest_subject = get_latest_commit(repo)
        return RepoSummary(
            path=str(repo),
            branch=branch,
            commit_files=counts.total,
            staged_files=counts.staged,
            unstaged_files=counts.unstaged,
            untracked_files=counts.untracked,
            conflict_files=counts.conflicts,
            remotes=remotes,
            upstream=upstream,
            remote_state=remote_state,
            ahead_commits=ahead,
            behind_commits=behind,
            commits_not_on_any_remote=commits_not_on_any_remote,
            stash_count=get_stash_count(repo),
            latest_commit_date=latest_date,
            latest_commit_sha=latest_sha,
            latest_commit_subject=latest_subject,
            fetch_error=fetch_error,
            error=None,
        )
    except Exception as exc:  # noqa: BLE001 - keep one bad repo from hiding the rest.
        return RepoSummary(
            path=str(repo),
            branch="unknown",
            commit_files=0,
            staged_files=0,
            unstaged_files=0,
            untracked_files=0,
            conflict_files=0,
            remotes=[],
            upstream=None,
            remote_state="error",
            ahead_commits=None,
            behind_commits=None,
            commits_not_on_any_remote=None,
            stash_count=0,
            latest_commit_date=None,
            latest_commit_sha=None,
            latest_commit_subject=None,
            fetch_error=fetch_error,
            error=str(exc),
        )


def clean_error(value: str | bytes) -> str:
    if isinstance(value, bytes):
        value = value.decode("utf-8", errors="replace")
    return " ".join(value.strip().split())


def should_use_color(mode: str) -> bool:
    if mode == "always":
        return True
    if mode == "never":
        return False
    if os.environ.get("NO_COLOR"):
        return False
    return sys.stdout.isatty() and os.environ.get("TERM") != "dumb"


def colorize(value: str, style: str, enabled: bool) -> str:
    if not enabled or not value:
        return value
    return f"{COLORS[style]}{value}{COLORS['reset']}"


def visible_width(value: str) -> int:
    return len(ANSI_RE.sub("", value))


def sort_summaries(summaries: list[RepoSummary], mode: str) -> list[RepoSummary]:
    if mode == "path":
        return sorted(summaries, key=lambda item: item.path.lower())
    if mode == "recent":
        return sorted(
            summaries,
            key=lambda item: (item.latest_commit_date or ""),
            reverse=True,
        )
    return sorted(
        summaries,
        key=lambda item: (
            0 if item.needs_action else 1,
            -importance_score(item),
            item.path.lower(),
        ),
    )


def importance_score(summary: RepoSummary) -> int:
    score = 0

    if summary.error:
        score += 1_000_000
    if summary.conflict_files:
        score += 900_000 + summary.conflict_files * 1_000
    if summary.commit_files:
        score += (
            800_000
            + summary.commit_files * 1_000
            + summary.staged_files * 100
            + summary.unstaged_files * 10
        )
    if (summary.ahead_commits or 0) > 0:
        score += 700_000 + (summary.ahead_commits or 0) * 1_000
    if summary.remote_state == "no_remote":
        score += 650_000
    elif summary.remote_state == "no_upstream":
        score += 600_000 + (summary.commits_not_on_any_remote or 0) * 1_000
    if (summary.behind_commits or 0) > 0:
        score += 500_000 + (summary.behind_commits or 0) * 1_000
    if summary.stash_count:
        score += 400_000 + summary.stash_count * 1_000
    if summary.fetch_error:
        score += 300_000

    return score


def display_path(summary: RepoSummary, base: Path, *, absolute: bool) -> str:
    path = Path(summary.path)
    if absolute:
        return str(path)

    try:
        relative = path.relative_to(base)
        return path.name if str(relative) == "." else str(relative)
    except ValueError:
        return str(path)


def push_value(summary: RepoSummary) -> str:
    if summary.remote_state == "no_remote":
        return "set remote"
    if summary.remote_state == "no_upstream":
        if summary.commits_not_on_any_remote and summary.commits_not_on_any_remote > 0:
            return f"set upstream ({summary.commits_not_on_any_remote})"
        return "set upstream"
    if summary.ahead_commits is None:
        return "?"
    return str(summary.ahead_commits)


def pull_value(summary: RepoSummary) -> str:
    if summary.remote_state != "tracking":
        return "-"
    if summary.behind_commits is None:
        return "?"
    return str(summary.behind_commits)


def latest_commit_value(summary: RepoSummary) -> str:
    if not summary.latest_commit_date:
        return "no commits"
    return summary.latest_commit_date.replace("T", " ")[:16]


def latest_commit_day_value(summary: RepoSummary) -> str:
    if not summary.latest_commit_date:
        return "no commits"
    return summary.latest_commit_date[:10]


def work_value(summary: RepoSummary) -> str:
    if summary.conflict_files:
        return f"conflict {summary.conflict_files}"
    if summary.commit_files:
        return f"{summary.commit_files} {noun(summary.commit_files, 'file')}"
    return "clean"


def sync_value(summary: RepoSummary) -> str:
    if summary.remote_state == "no_remote":
        return "no remote"
    if summary.remote_state == "no_upstream":
        return "no upstream"
    if summary.remote_state != "tracking":
        return "sync ?"

    actions: list[str] = []
    if (summary.ahead_commits or 0) > 0:
        actions.append(f"push {summary.ahead_commits}")
    if (summary.behind_commits or 0) > 0:
        actions.append(f"pull {summary.behind_commits}")
    return ", ".join(actions) if actions else "synced"


def action_text(summary: RepoSummary) -> str:
    actions: list[str] = []

    if summary.error:
        actions.append("inspect error")
    if summary.conflict_files:
        actions.append(f"resolve conflicts {summary.conflict_files}")
    if summary.commit_files:
        actions.append(f"commit {summary.commit_files}")
    if summary.remote_state == "no_remote":
        actions.append("set remote")
    elif summary.remote_state == "no_upstream":
        actions.append("set upstream")
        if summary.commits_not_on_any_remote and summary.commits_not_on_any_remote > 0:
            actions.append(f"push maybe {summary.commits_not_on_any_remote}")
    elif (summary.ahead_commits or 0) > 0:
        actions.append(f"push {summary.ahead_commits}")
    if (summary.behind_commits or 0) > 0:
        actions.append(f"pull {summary.behind_commits}")
    if summary.stash_count:
        actions.append(f"review stash {summary.stash_count}")
    if summary.fetch_error:
        actions.append("fetch failed")

    return ", ".join(actions) if actions else "ok"


def action_style(summary: RepoSummary) -> str:
    if summary.error or summary.fetch_error:
        return "red_bold"
    if summary.conflict_files:
        return "red_bold"
    if summary.commit_files:
        return "yellow_bold"
    if (summary.ahead_commits or 0) > 0:
        return "magenta_bold"
    if summary.remote_state == "no_remote":
        return "red"
    if summary.remote_state == "no_upstream":
        return "yellow"
    if (summary.behind_commits or 0) > 0:
        return "blue_bold"
    if summary.stash_count:
        return "yellow"
    return "green"


def commit_files_style(summary: RepoSummary) -> str:
    if summary.conflict_files:
        return "red_bold"
    if summary.commit_files:
        return "yellow_bold"
    return "green"


def push_style(summary: RepoSummary) -> str:
    if summary.remote_state == "no_remote":
        return "red"
    if summary.remote_state == "no_upstream":
        return "yellow"
    if summary.ahead_commits is None:
        return "red"
    if summary.ahead_commits > 0:
        return "magenta_bold"
    return "green"


def pull_style(summary: RepoSummary) -> str:
    if summary.remote_state != "tracking":
        return "dim"
    if summary.behind_commits is None:
        return "red"
    if summary.behind_commits > 0:
        return "blue_bold"
    return "green"


def stash_style(summary: RepoSummary) -> str:
    return "yellow_bold" if summary.stash_count else "green"


def upstream_style(summary: RepoSummary) -> str:
    if summary.remote_state == "no_remote":
        return "red"
    if summary.remote_state == "no_upstream":
        return "yellow"
    return "cyan"


def sync_style(summary: RepoSummary) -> str:
    if summary.remote_state == "no_remote":
        return "red"
    if summary.remote_state == "no_upstream":
        return "yellow"
    if summary.remote_state != "tracking" or summary.ahead_commits is None:
        return "red"
    if summary.ahead_commits > 0:
        return "magenta_bold"
    if (summary.behind_commits or 0) > 0:
        return "blue_bold"
    return "green"


def truncate_plain(value: str, width: int) -> str:
    if width <= 0:
        return ""
    if len(value) <= width:
        return value
    if width <= 3:
        return value[:width]
    return value[: width - 3] + "..."


def truncate_project_path(value: str, width: int) -> str:
    if len(value) <= width:
        return value
    if width <= 8 or "/" not in value:
        return truncate_plain(value, width)

    leaf = value.rsplit("/", 1)[-1]
    if len(leaf) + 4 <= width:
        return ".../" + leaf

    return truncate_plain(value, width)


def table_rows(
    summaries: Iterable[RepoSummary],
    *,
    base: Path,
    absolute: bool,
    color_enabled: bool,
) -> list[list[str]]:
    rows: list[list[str]] = []
    for summary in summaries:
        rows.append(
            [
                colorize(display_path(summary, base, absolute=absolute), action_style(summary), color_enabled),
                colorize(summary.branch, "cyan", color_enabled),
                colorize(str(summary.commit_files), commit_files_style(summary), color_enabled),
                colorize(push_value(summary), push_style(summary), color_enabled),
                colorize(pull_value(summary), pull_style(summary), color_enabled),
                colorize(str(summary.stash_count), stash_style(summary), color_enabled),
                colorize(
                    summary.upstream or ("none" if summary.remote_state == "no_remote" else "-"),
                    upstream_style(summary),
                    color_enabled,
                ),
                colorize(latest_commit_value(summary), "dim", color_enabled),
                colorize(action_text(summary), action_style(summary), color_enabled),
            ]
        )
    return rows


def print_table(
    summaries: list[RepoSummary],
    *,
    base: Path,
    absolute: bool,
    color_enabled: bool,
    view: str,
    width: int,
) -> None:
    if view == "full":
        print_full_table(summaries, base=base, absolute=absolute, color_enabled=color_enabled)
        return

    print_compact_table(
        summaries,
        base=base,
        absolute=absolute,
        color_enabled=color_enabled,
        width=width,
    )


def print_full_table(
    summaries: list[RepoSummary],
    *,
    base: Path,
    absolute: bool,
    color_enabled: bool,
) -> None:
    headers = [
        "Project",
        "Branch",
        "Commit files",
        "Push",
        "Pull",
        "Stash",
        "Upstream",
        "Latest commit",
        "Actions",
    ]
    header_row = [colorize(header, "bold", color_enabled) for header in headers]
    rows = table_rows(summaries, base=base, absolute=absolute, color_enabled=color_enabled)
    widths = [
        max(visible_width(headers[index]), *(visible_width(row[index]) for row in rows))
        for index in range(len(headers))
    ]

    print(format_row(header_row, widths))
    print(colorize(format_row(["-" * width for width in widths], widths), "dim", color_enabled))
    for row in rows:
        print(format_row(row, widths))


def print_compact_table(
    summaries: list[RepoSummary],
    *,
    base: Path,
    absolute: bool,
    color_enabled: bool,
    width: int,
) -> None:
    headers = ["Project", "Branch", "Work", "Sync", "Last", "Action"]
    plain_rows = compact_table_rows(summaries, base=base, absolute=absolute)
    widths = compact_widths(headers, plain_rows, width)
    header_row = [colorize(header, "bold", color_enabled) for header in headers]

    print(format_row(header_row, widths))
    print(colorize(format_row(["-" * width for width in widths], widths), "dim", color_enabled))

    for summary, row in zip(summaries, plain_rows, strict=True):
        styles = [
            action_style(summary),
            "cyan",
            commit_files_style(summary),
            sync_style(summary),
            "dim",
            action_style(summary),
        ]
        rendered = [
            colorize(truncate_cell(value, widths[index], index), styles[index], color_enabled)
            for index, value in enumerate(row)
        ]
        print(format_row(rendered, widths))


def compact_table_rows(
    summaries: Iterable[RepoSummary],
    *,
    base: Path,
    absolute: bool,
) -> list[list[str]]:
    rows: list[list[str]] = []
    for summary in summaries:
        rows.append(
            [
                display_path(summary, base, absolute=absolute),
                summary.branch,
                work_value(summary),
                sync_value(summary),
                latest_commit_day_value(summary),
                action_text(summary),
            ]
        )
    return rows


def compact_widths(headers: list[str], rows: list[list[str]], target_width: int) -> list[int]:
    target_width = max(64, target_width)
    separator_width = 2 * (len(headers) - 1)
    min_widths = [16, 10, 8, 10, 10, 14]
    max_widths = [60, 18, 12, 18, 10, 34]

    content_widths = [
        max(len(headers[index]), *(len(row[index]) for row in rows))
        for index in range(len(headers))
    ]
    widths = [
        min(max(content_widths[index], min_widths[index]), max_widths[index])
        for index in range(len(headers))
    ]

    def total_width() -> int:
        return sum(widths) + separator_width

    shrink_order = [5, 0, 1, 3, 2]
    while total_width() > target_width:
        changed = False
        for index in shrink_order:
            if total_width() <= target_width:
                break
            if widths[index] > min_widths[index]:
                widths[index] -= 1
                changed = True
        if not changed:
            break

    grow_order = [0, 5, 1, 3]
    while total_width() < target_width:
        changed = False
        for index in grow_order:
            if total_width() >= target_width:
                break
            if widths[index] < min(content_widths[index], max_widths[index]):
                widths[index] += 1
                changed = True
        if not changed:
            break

    return widths


def truncate_cell(value: str, width: int, column_index: int) -> str:
    if column_index == 0:
        return truncate_project_path(value, width)
    return truncate_plain(value, width)


def format_row(values: list[str], widths: list[int]) -> str:
    padded_values = []
    for index, value in enumerate(values):
        padding = max(0, widths[index] - visible_width(value))
        padded_values.append(value + " " * padding)
    return "  ".join(padded_values)


def print_run_summary(
    summaries: list[RepoSummary],
    *,
    repo_count: int,
    listed_count: int,
    input_path: Path,
    fetched: bool,
    color_enabled: bool,
) -> None:
    needs_action_count = sum(1 for summary in summaries if summary.needs_action)
    commit_repo_count = sum(1 for summary in summaries if summary.commit_files)
    commit_file_count = sum(summary.commit_files for summary in summaries)
    push_repo_count = sum(1 for summary in summaries if (summary.ahead_commits or 0) > 0)
    push_commit_count = sum(summary.ahead_commits or 0 for summary in summaries)
    pull_repo_count = sum(1 for summary in summaries if (summary.behind_commits or 0) > 0)
    pull_commit_count = sum(summary.behind_commits or 0 for summary in summaries)
    no_remote_count = sum(1 for summary in summaries if summary.remote_state == "no_remote")
    no_upstream_count = sum(1 for summary in summaries if summary.remote_state == "no_upstream")
    stash_count = sum(summary.stash_count for summary in summaries)
    error_count = sum(1 for summary in summaries if summary.error or summary.fetch_error)

    refresh_note = "after fetch" if fetched else "use --fetch to refresh"
    print(
        colorize(f"Repos: {repo_count}", "cyan_bold", color_enabled)
        + " | "
        + colorize(
            f"Need action: {needs_action_count} {noun(needs_action_count, 'repo')}",
            count_style(needs_action_count),
            color_enabled,
        )
        + f" | Refresh: {refresh_note}"
    )
    print(colorize(f"Path: {input_path}", "dim", color_enabled))
    print(
        colorize("Risks:", "bold", color_enabled)
        + " "
        + colorize(
            f"commit {commit_file_count} {noun(commit_file_count, 'file')}/{commit_repo_count} {noun(commit_repo_count, 'repo')}",
            count_style(commit_file_count),
            color_enabled,
        )
        + " | "
        + colorize(
            f"push {push_commit_count} {noun(push_commit_count, 'commit')}/{push_repo_count} {noun(push_repo_count, 'repo')}",
            count_style(push_commit_count),
            color_enabled,
        )
    )
    print(
        "       "
        + colorize(
            f"no remote {no_remote_count} {noun(no_remote_count, 'repo')}",
            count_style(no_remote_count),
            color_enabled,
        )
        + " | "
        + colorize(
            f"no upstream {no_upstream_count} {noun(no_upstream_count, 'repo')}",
            count_style(no_upstream_count),
            color_enabled,
        )
    )
    print(
        "       "
        + colorize(
            f"pull {pull_commit_count} {noun(pull_commit_count, 'commit')}/{pull_repo_count} {noun(pull_repo_count, 'repo')}",
            count_style(pull_commit_count),
            color_enabled,
        )
        + " | "
        + colorize(
            f"stash {stash_count}",
            count_style(stash_count),
            color_enabled,
        )
        + " | "
        + colorize(f"errors {error_count}", count_style(error_count), color_enabled)
    )
    if listed_count != len(summaries):
        print(colorize(f"Showing {listed_count} repositories after filters.", "dim", color_enabled))


def count_style(count: int) -> str:
    return "yellow_bold" if count else "green"


def noun(count: int, singular: str, plural: str | None = None) -> str:
    if count == 1:
        return singular
    return plural if plural is not None else f"{singular}s"


def output_width(requested_width: int | None) -> int:
    if requested_width is not None:
        return max(64, requested_width)
    return shutil.get_terminal_size((120, 24)).columns


def output_row_limit(requested_limit: int | None, row_count: int) -> int | None:
    if requested_limit is not None:
        return None if requested_limit <= 0 else requested_limit
    if not sys.stdout.isatty():
        return None

    terminal_height = shutil.get_terminal_size((120, 24)).lines
    one_page_rows = max(8, terminal_height - 13)
    if row_count <= one_page_rows:
        return None
    return one_page_rows


def print_next_actions(
    summaries: list[RepoSummary],
    *,
    base: Path,
    absolute: bool,
    top_count: int,
    width: int,
    color_enabled: bool,
) -> None:
    if top_count <= 0:
        return

    actions = [summary for summary in summaries if summary.needs_action][:top_count]
    if not actions:
        return

    print(colorize("Next actions:", "bold", color_enabled))
    for index, summary in enumerate(actions, start=1):
        prefix = f"{index}. "
        project = display_path(summary, base, absolute=absolute)
        text = f"{project}: {action_text(summary)}"
        available_width = max(20, width - len(prefix))
        line = prefix + truncate_plain(text, available_width)
        print(colorize(line, action_style(summary), color_enabled))


def print_limit_notice(
    *,
    shown_count: int,
    total_count: int,
    color_enabled: bool,
) -> None:
    if shown_count >= total_count:
        return
    print(
        colorize(
            f"Showing first {shown_count} of {total_count} table rows. Use --limit 0 to show all.",
            "dim",
            color_enabled,
        )
    )


def print_verbose(summaries: list[RepoSummary], *, base: Path, absolute: bool) -> None:
    for summary in summaries:
        print()
        print(display_path(summary, base, absolute=absolute))
        print(f"  path: {summary.path}")
        print(
            "  files: "
            f"{summary.commit_files} total, "
            f"{summary.staged_files} staged, "
            f"{summary.unstaged_files} unstaged, "
            f"{summary.untracked_files} untracked, "
            f"{summary.conflict_files} conflicts"
        )
        print(f"  branch: {summary.branch}")
        print(f"  remotes: {', '.join(summary.remotes) if summary.remotes else 'none'}")
        print(f"  upstream: {summary.upstream or 'none'}")
        print(f"  push commits: {push_value(summary)}")
        print(f"  pull commits: {pull_value(summary)}")
        if summary.latest_commit_sha:
            print(
                "  latest commit: "
                f"{summary.latest_commit_date} "
                f"{summary.latest_commit_sha} "
                f"{summary.latest_commit_subject}"
            )
        else:
            print("  latest commit: no commits")
        if summary.fetch_error:
            print(f"  fetch error: {summary.fetch_error}")
        if summary.error:
            print(f"  error: {summary.error}")


def main() -> int:
    args = parse_args()
    color_enabled = should_use_color(args.color) and not args.json
    table_width = output_width(args.width)

    if shutil.which("git") is None:
        print("Error: git is not installed or is not available in PATH.", file=sys.stderr)
        return 1

    input_path = Path(args.path).expanduser().resolve()
    if not input_path.exists():
        print(f"Error: path does not exist: {input_path}", file=sys.stderr)
        return 1

    base = input_path.parent if input_path.is_file() else input_path
    repositories = discover_repositories(
        input_path,
        max_depth=args.max_depth,
        include_hidden=args.include_hidden,
        include_nested=args.include_nested,
    )

    if not repositories:
        print(f"No Git repositories found under: {input_path}", file=sys.stderr)
        return 1

    all_summaries = [summarize_repo(repo, fetch=args.fetch) for repo in repositories]
    summaries = all_summaries
    if args.only_needs_action:
        summaries = [summary for summary in summaries if summary.needs_action]
    summaries = sort_summaries(summaries, args.sort)
    row_limit = output_row_limit(args.limit, len(summaries)) if not args.json else None
    table_summaries = summaries[:row_limit] if row_limit is not None else summaries

    if args.json:
        print(json.dumps([asdict(summary) for summary in summaries], indent=2))
    else:
        print_run_summary(
            all_summaries,
            repo_count=len(repositories),
            listed_count=len(summaries),
            input_path=input_path,
            fetched=args.fetch,
            color_enabled=color_enabled,
        )
        print_next_actions(
            summaries,
            base=base,
            absolute=args.absolute,
            top_count=args.top,
            width=table_width,
            color_enabled=color_enabled,
        )
        if table_summaries:
            print_limit_notice(
                shown_count=len(table_summaries),
                total_count=len(summaries),
                color_enabled=color_enabled,
            )
            print_table(
                table_summaries,
                base=base,
                absolute=args.absolute,
                color_enabled=color_enabled,
                view=args.view,
                width=table_width,
            )
            if args.verbose:
                print_verbose(table_summaries, base=base, absolute=args.absolute)
        else:
            print(colorize("No repositories need action.", "green", color_enabled))

    if args.fail_on_action and any(summary.needs_action for summary in summaries):
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

#!/bin/bash

add_to_path_if_missing() {
    [ -d "$1" ] || return 0

    case ":$PATH:" in
        *":$1:"*) ;; # already in PATH
        *) PATH="$PATH:$1" ;;
    esac
}


if [ -d "$HOME/.dotnet" ]; then
    export DOTNET_ROOT=$HOME/.dotnet

    add_to_path_if_missing $DOTNET_ROOT
    add_to_path_if_missing $DOTNET_ROOT/tools
    export PATH
fi

if [ -f "$HOME/scripts/exports" ]; then
    source "$HOME/scripts/exports"
fi

export GPG_TTY=$(tty)

if [ -d "$HOME/.nvm" ]; then
    export NVM_DIR="$HOME/.nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
fi

# GapCode
add_to_path_if_missing "$HOME/.gapcode/bin"

# Flatpak exports
add_to_path_if_missing "/var/lib/flatpak/exports/bin"
add_to_path_if_missing "$HOME/.local/share/flatpak/exports/bin"

# APK analysis tools
export APK_MCP_ApkAnalysis__ToolPaths__Jadx="/var/lib/flatpak/exports/bin/com.github.skylot.jadx"
export APK_MCP_ApkAnalysis__ToolPaths__Apktool="/usr/bin/apktool"

# Disable NuGet vulnerability auditing during restore to avoid
# requests to api.nuget.org vulnerability endpoints on restricted networks.
export NuGetAudit=false
